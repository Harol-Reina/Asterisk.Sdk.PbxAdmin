FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src

# Copy solution and project files for restore
COPY Asterisk.NetAot.slnx .
COPY Directory.Build.props .
COPY Directory.Packages.props .
COPY global.json .

COPY src/Asterisk.NetAot.Abstractions/*.csproj src/Asterisk.NetAot.Abstractions/
COPY src/Asterisk.NetAot.Ami/*.csproj src/Asterisk.NetAot.Ami/
COPY src/Asterisk.NetAot.Ami.SourceGenerators/*.csproj src/Asterisk.NetAot.Ami.SourceGenerators/
COPY src/Asterisk.NetAot.Agi/*.csproj src/Asterisk.NetAot.Agi/
COPY src/Asterisk.NetAot.Live/*.csproj src/Asterisk.NetAot.Live/
COPY src/Asterisk.NetAot.Pbx/*.csproj src/Asterisk.NetAot.Pbx/
COPY src/Asterisk.NetAot.Ari/*.csproj src/Asterisk.NetAot.Ari/
COPY src/Asterisk.NetAot.Config/*.csproj src/Asterisk.NetAot.Config/
COPY src/Asterisk.NetAot/*.csproj src/Asterisk.NetAot/

COPY Tests/Asterisk.NetAot.IntegrationTests/*.csproj Tests/Asterisk.NetAot.IntegrationTests/

# Restore only integration test project (and transitive deps)
RUN dotnet restore Tests/Asterisk.NetAot.IntegrationTests/

# Copy all source code
COPY src/ src/
COPY Tests/Asterisk.NetAot.IntegrationTests/ Tests/Asterisk.NetAot.IntegrationTests/

# Build
RUN dotnet build Tests/Asterisk.NetAot.IntegrationTests/ -c Release --no-restore

# Run integration tests
ENTRYPOINT ["dotnet", "test", "Tests/Asterisk.NetAot.IntegrationTests/", "-c", "Release", "--no-build", "--logger", "console;verbosity=detailed"]
