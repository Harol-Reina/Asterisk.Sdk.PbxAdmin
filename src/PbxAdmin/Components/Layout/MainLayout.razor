@inherits LayoutComponentBase
@using PbxAdmin.Services
@using Asterisk.Sdk.Enums
@inject IStringLocalizer<SharedStrings> L
@inject AsteriskMonitorService Monitor
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IToastService Toast
@implements IDisposable

@if (!ServerSvc.HasSelection)
{
    @* Redirect to server selection — OnInitialized handles navigation *@
}
else
{
    <div class="layout">
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>@L["SidebarTitle"]</h2>
            </div>
            <div class="nav-section">@L["Nav_Monitoring"]</div>
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">@L["Nav_Home"]</NavLink>
            <NavLink href="/calls" class="nav-item">@L["Nav_Calls"]</NavLink>
            <NavLink href="/queues" class="nav-item">@L["Nav_Queues"]</NavLink>
            <NavLink href="/channels" class="nav-item">@L["Nav_Channels"]</NavLink>

            <div class="nav-section">@L["Nav_PbxManagement"]</div>
            <NavLink href="/extensions" class="nav-item">@L["Nav_Extensions"]</NavLink>
            <NavLink href="/trunks" class="nav-item">@L["Nav_Trunks"]</NavLink>
            <NavLink href="/routes" class="nav-item">@L["Nav_Routes"]</NavLink>
            <NavLink href="/ivr-menus" class="nav-item">@L["Nav_IvrMenus"]</NavLink>
            <NavLink href="/time-conditions" class="nav-item">@L["Nav_TimeConds"]</NavLink>
            <NavLink href="/call-flow" class="nav-item">@L["Nav_CallFlow"]</NavLink>

            <div class="nav-section">@L["Nav_MediaFeatures"]</div>
            <NavLink href="/recordings" class="nav-item">@L["Nav_Recordings"]</NavLink>
            <NavLink href="/moh" class="nav-item">@L["Nav_MusicOnHold"]</NavLink>
            <NavLink href="/conferences" class="nav-item">@L["Nav_Conferences"]</NavLink>
            <NavLink href="/feature-codes" class="nav-item">@L["Nav_FeatureCodes"]</NavLink>
            <NavLink href="/parking" class="nav-item">@L["Nav_Parking"]</NavLink>
            <NavLink href="/voicemail" class="nav-item">@L["Nav_Voicemail"]</NavLink>

            <div class="nav-section">@L["Nav_System"]</div>
            <NavLink href="/metrics" class="nav-item">@L["Nav_Metrics"]</NavLink>
            <NavLink href="/events" class="nav-item">@L["Nav_Events"]</NavLink>
            <NavLink href="/console" class="nav-item">@L["Nav_Console"]</NavLink>
            <NavLink href="/dialplan" class="nav-item">@L["Nav_AdvDialplan"]</NavLink>
            <NavLink href="/traffic" class="nav-item">@L["Nav_Traffic"]</NavLink>
        </nav>

        <div class="main-area">
            <header class="header">
                <div class="header-left">
                    <h1>@L["AppTitle"]</h1>
                </div>
                <div class="header-center">
                    @{
                        var selectedEntry = ServerSvc.GetSelectedServer();
                        if (selectedEntry is not null)
                        {
                            var state = selectedEntry.Connection.State;
                            var dotClass = state switch
                            {
                                AmiConnectionState.Connected => "dot-green",
                                AmiConnectionState.Reconnecting or AmiConnectionState.Connecting => "dot-yellow",
                                _ => "dot-red"
                            };
                            var modeBadge = selectedEntry.ConfigMode == ConfigMode.Realtime ? "badge-realtime" : "badge-file";
                            <span class="connection-dot @dotClass" title="@ServerSvc.SelectedServerId: @state"></span>
                            <span class="badge @modeBadge">@selectedEntry.ConfigMode</span>
                        }
                    }
                    @if (Monitor.Servers.Count() > 1)
                    {
                        <select class="server-switcher" value="@ServerSvc.SelectedServerId" @onchange="OnServerSwitch">
                            @foreach (var (id, _) in Monitor.Servers)
                            {
                                <option value="@id">@id</option>
                            }
                        </select>
                    }
                    else
                    {
                        <span class="connection-label">@ServerSvc.SelectedServerId</span>
                    }
                </div>
                <div class="header-right">
                    <span class="header-stat">@_totalChannels @L["Stat_Calls"]</span>
                    <span class="header-stat">@_totalQueues @L["Stat_Queues"]</span>
                    <NotificationCenter />
                    <button class="btn btn-sm btn-muted" @onclick="() => _glossaryOpen = !_glossaryOpen" title="@L["Glossary_Title"]">📖</button>
                    <button class="btn btn-sm btn-muted lang-switch" @onclick="SwitchLanguage">
                        @(_isSpanish ? "EN" : "ES")
                    </button>
                    <form method="post" action="/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-sm btn-muted">@L["Btn_Logout"]</button>
                    </form>
                </div>
            </header>

            <HeaderProgressBar />
            <main class="content">
                @Body
            </main>
        </div>
    </div>

    <GlossarySidebar IsOpen="_glossaryOpen" OnClose="() => _glossaryOpen = false" />
    <SoftphoneWidget />
    <ToastContainer />

    @if (ConfigOp.IsBusy)
    {
        var op = ConfigOp.Current!;
        <div class="config-overlay">
            <div class="config-overlay-card">
                <div class="config-overlay-spinner"></div>
                <div class="config-overlay-text">
                    <div class="config-overlay-title">@op.Operation</div>
                    <div class="config-overlay-detail">
                        @op.ServerId
                        @if (op.Detail is not null)
                        {
                            <span> &mdash; @op.Detail</span>
                        }
                    </div>
                    <div class="config-overlay-elapsed text-muted">@FormatElapsed(op.Elapsed)</div>
                </div>
            </div>
        </div>
    }
}

@code {
    private Timer? _timer;
    private int _totalChannels;
    private int _totalQueues;
    private bool _isSpanish;
    private bool _glossaryOpen;

    protected override void OnInitialized()
    {
        if (!ServerSvc.HasSelection)
        {
            var servers = Monitor.Servers.ToList();
            if (servers.Count == 1)
            {
                ServerSvc.Select(servers[0].Key);
            }
            else
            {
                Nav.NavigateTo("/select-server", replace: true);
                return;
            }
        }

        _isSpanish = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es";

        ServerSvc.OnChanged += OnServerChanged;
        ConfigOp.OnChanged += OnConfigOpChanged;

        _timer = new Timer(_ =>
        {
            RefreshStats();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private void RefreshStats()
    {
        foreach (var (_, entry) in ServerSvc.GetServers())
        {
            _totalChannels = entry.Server.Channels.ChannelCount;
            _totalQueues = entry.Server.Queues.QueueCount;
        }
    }

    private void OnServerSwitch(ChangeEventArgs e)
    {
        var serverId = e.Value?.ToString();
        if (!string.IsNullOrEmpty(serverId))
        {
            ServerSvc.Select(serverId);
        }
    }

    private void OnServerChanged()
    {
        RefreshStats();
        InvokeAsync(StateHasChanged);
    }

    private void OnConfigOpChanged() => InvokeAsync(StateHasChanged);

    private void SwitchLanguage() =>
        Nav.NavigateTo($"/set-language/{(_isSpanish ? "en" : "es")}", forceLoad: true);

    private static string FormatElapsed(TimeSpan ts) =>
        ts.TotalSeconds < 1 ? "starting..." : $"{ts.TotalSeconds:F0}s elapsed";

    public void Dispose()
    {
        _timer?.Dispose();
        ServerSvc.OnChanged -= OnServerChanged;
        ConfigOp.OnChanged -= OnConfigOpChanged;
    }
}
