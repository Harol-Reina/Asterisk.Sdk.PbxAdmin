@namespace PbxAdmin.Components.Shared
@implements IDisposable
@inject IToastService Toast

<div class="toast-container">
    @foreach (var msg in Toast.ActiveToasts)
    {
        <ToastItem Message="msg" OnDismiss="HandleDismiss" />
    }
</div>

@code {
    protected override void OnInitialized() => Toast.OnChanged += Refresh;

    private void HandleDismiss(string id) => Toast.Dismiss(id);

    private async void Refresh()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Toast.OnChanged -= Refresh;
}
