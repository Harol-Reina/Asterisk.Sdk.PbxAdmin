@namespace PbxAdmin.Components.Shared

<div class="toast-item toast-@Level" @onclick="() => OnDismiss.InvokeAsync(Message.Id)">
    <span class="toast-icon">@Icon</span>
    <div class="toast-body">
        <div class="toast-title">@Message.Title</div>
        @if (Message.Detail is not null)
        {
            <div class="toast-detail">@Message.Detail</div>
        }
    </div>
    <span class="toast-dismiss" @onclick="() => OnDismiss.InvokeAsync(Message.Id)" @onclick:stopPropagation="true">&times;</span>
</div>

@code {
    [Parameter, EditorRequired] public ToastMessage Message { get; set; } = default!;
    [Parameter] public EventCallback<string> OnDismiss { get; set; }

    private string Level => Message.Level.ToString().ToLowerInvariant();

    private string Icon => Message.Level switch
    {
        ToastLevel.Success => "\u2713",
        ToastLevel.Error => "\u2717",
        ToastLevel.Warning => "\u26A0",
        _ => "\u2139"
    };
}
