@namespace PbxAdmin.Components.Shared
@implements IDisposable
@inject SoftphoneService Phone
@inject IJSRuntime JS

<div class="softphone-call-info">
    <div class="softphone-call-number">@(Phone.RemoteNumber ?? "Unknown")</div>
    @if (Phone.RemoteName is not null)
    {
        <div class="softphone-call-name">@Phone.RemoteName</div>
    }
    <div class="softphone-call-duration">@_duration</div>
</div>

<div class="softphone-controls">
    <button class="softphone-ctrl-btn @(Phone.IsMuted ? "muted" : "")" @onclick="Phone.ToggleMuteAsync" title="@(Phone.IsMuted ? "Unmute" : "Mute")">
        @(Phone.IsMuted ? "🔇" : "🔊")
    </button>
    <button class="softphone-ctrl-btn @(Phone.IsOnHold ? "active" : "")" @onclick="Phone.ToggleHoldAsync" title="@(Phone.IsOnHold ? "Resume" : "Hold")">
        ⏸
    </button>
    <button class="softphone-ctrl-btn" @onclick="ToggleDtmf" title="DTMF">
        🔢
    </button>
    <button class="softphone-ctrl-btn hangup" @onclick="Phone.HangupAsync" title="Hangup">
        📵
    </button>
</div>

<div class="softphone-volume-wrap">
    <span style="font-size:0.7rem;">🔈</span>
    <input type="range" min="0" max="100" value="@_volume" @oninput="OnVolumeChange" class="softphone-volume" />
    <span style="font-size:0.7rem;">🔊</span>
</div>

@if (_showDtmf)
{
    @if (_dtmfInput.Length > 0)
    {
        <div class="softphone-dtmf-display">@_dtmfInput</div>
    }
    <div class="softphone-dialpad" style="padding-bottom:0.5rem;">
        @foreach (var key in _keys)
        {
            <div class="softphone-key" @onclick="() => SendDtmfWithTone(key.Digit)">
                @key.Digit
                <div class="softphone-key-sub">@key.Letters</div>
            </div>
        }
    </div>
}

@code {
    private string _duration = "00:00";
    private bool _showDtmf;
    private string _dtmfInput = "";
    private int _volume = 80;
    private Timer? _timer;

    private static readonly (string Digit, string Letters)[] _keys =
    [
        ("1", " "), ("2", "ABC"), ("3", "DEF"),
        ("4", "GHI"), ("5", "JKL"), ("6", "MNO"),
        ("7", "PQRS"), ("8", "TUV"), ("9", "WXYZ"),
        ("*", ""), ("0", "+"), ("#", "")
    ];

    protected override void OnInitialized()
    {
        _timer = new Timer(_ =>
        {
            if (Phone.CallStartedAt is not null)
            {
                var elapsed = DateTimeOffset.UtcNow - Phone.CallStartedAt.Value;
                _duration = elapsed.ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            }
        }, null, 0, 1000);
    }

    private async Task SendDtmfWithTone(string digit)
    {
        await Phone.SendDtmfAsync(digit);
        await JS.InvokeVoidAsync("Softphone.playDtmfTone", digit);
        _dtmfInput += digit;
    }

    private void ToggleDtmf()
    {
        _showDtmf = !_showDtmf;
        if (!_showDtmf) _dtmfInput = "";
    }

    private async Task OnVolumeChange(ChangeEventArgs e)
    {
        _volume = int.Parse(e.Value?.ToString() ?? "80");
        await JS.InvokeVoidAsync("Softphone.setVolume", _volume / 100.0);
    }

    public void Dispose() => _timer?.Dispose();
}
