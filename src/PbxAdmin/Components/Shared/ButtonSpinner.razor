@namespace PbxAdmin.Components.Shared

<button class="btn @CssClass @(Loading ? "btn-loading" : "")" disabled="@Loading" @onclick="OnClick">
    @if (Loading)
    {
        <span class="btn-spinner"></span>@LoadingText
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string CssClass { get; set; } = "btn-sm btn-green";
    [Parameter] public string LoadingText { get; set; } = "Saving...";
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
