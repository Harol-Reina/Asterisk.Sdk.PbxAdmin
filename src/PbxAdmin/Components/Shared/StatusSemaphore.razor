@using Asterisk.Sdk.Enums
@using Asterisk.Sdk.Live.Agents
@using Asterisk.Sdk.Live.Queues

@inject IStringLocalizer<SharedStrings> L
@inject ISelectedServerService SelectedServer

<div class="semaphore-bar">
    @foreach (var item in _items)
    {
        <a class="semaphore-item" href="@item.Href">
            <span class="status-dot @item.DotClass"></span>
            <span class="semaphore-label">@item.Label</span>
            <span class="semaphore-value">@item.Value</span>
        </a>
    }
</div>

@code {
    private record SemaphoreItem(string DotClass, string Label, string Value, string Href);

    private IReadOnlyList<SemaphoreItem> _items = [];

    protected override void OnInitialized()
    {
        Refresh();
        SelectedServer.OnChanged += OnServerChanged;
    }

    private void OnServerChanged()
    {
        Refresh();
        InvokeAsync(StateHasChanged);
    }

    private void Refresh()
    {
        var entry = SelectedServer.GetSelectedServer();
        _items = BuildItems(entry);
    }

    private IReadOnlyList<SemaphoreItem> BuildItems(AsteriskMonitorService.ServerEntry? entry)
    {
        if (entry is null)
        {
            var noServer = L["Sem_NoServer"].Value;
            return
            [
                new("dot-red", L["Sem_PBX"],         noServer, "#"),
                new("dot-red", L["Sem_Extensions"],  noServer, "/extensions"),
                new("dot-red", L["Sem_Queues"],      noServer, "/queues"),
                new("dot-red", L["Sem_Trunks"],      noServer, "/trunks"),
                new("dot-red", L["Sem_Parking"],     noServer, "/parking"),
                new("dot-red", L["Sem_Agents"],      noServer, "/agents"),
            ];
        }

        var server = entry.Server;
        var isConnected = entry.Connection.State == AmiConnectionState.Connected;

        // --- PBX ---
        var pbxDot = isConnected ? "dot-green" : "dot-red";
        var pbxValue = isConnected ? L["Sem_Connected"].Value : L["Sem_Disconnected"].Value;

        // --- Extensions (Channels) ---
        var channelCount = server.Channels.ChannelCount;
        var activeChannels = server.Channels.ActiveChannels
            .Count(c => c.State == ChannelState.Up || c.State == ChannelState.Ringing);
        string extDot;
        string extValue;
        if (channelCount == 0)
        {
            extDot = "dot-red";
            extValue = "0";
        }
        else
        {
            var pct = (double)activeChannels / channelCount * 100.0;
            extDot = pct >= 80.0 ? "dot-green" : pct >= 50.0 ? "dot-yellow" : "dot-red";
            extValue = activeChannels.ToString();
        }

        // --- Queues ---
        var allQueues = server.Queues.Queues.ToList();
        var queueCount = allQueues.Count;
        string queueDot;
        string queueValue;
        if (queueCount == 0)
        {
            queueDot = "dot-red";
            queueValue = "0";
        }
        else
        {
            var queuesWithMembers = allQueues.Count(q => q.MemberCount > 0);
            if (queuesWithMembers == queueCount)
                queueDot = "dot-green";
            else if (queuesWithMembers > 0)
                queueDot = "dot-yellow";
            else
                queueDot = "dot-red";
            queueValue = queueCount.ToString();
        }

        // --- Trunks (no trunk-specific Live API — always green) ---
        var trunkDot = "dot-green";
        var trunkValue = L["Sem_Online"].Value;

        // --- Parking (proxy: channels in "parked" context) ---
        var parkedCount = server.Channels.ActiveChannels
            .Count(c => string.Equals(c.Context, "parkedcalls", StringComparison.OrdinalIgnoreCase)
                     || string.Equals(c.Context, "park", StringComparison.OrdinalIgnoreCase));
        var parkDot = parkedCount == 0 ? "dot-green" : "dot-yellow";
        var parkValue = parkedCount == 0 ? "0" : parkedCount.ToString();

        // --- Agents ---
        var agents = server.Agents.Agents.ToList();
        var agentCount = agents.Count;
        string agentDot;
        string agentValue;
        if (agentCount == 0)
        {
            agentDot = "dot-red";
            agentValue = "0";
        }
        else
        {
            var availableCount = agents.Count(a => a.State == AgentState.Available);
            var pausedCount = agents.Count(a => a.State == AgentState.Paused);
            if (availableCount >= 1)
            {
                agentDot = "dot-green";
                agentValue = availableCount.ToString();
            }
            else if (pausedCount > 0)
            {
                agentDot = "dot-yellow";
                agentValue = pausedCount.ToString();
            }
            else
            {
                agentDot = "dot-red";
                agentValue = agentCount.ToString();
            }
        }

        return
        [
            new(pbxDot,    L["Sem_PBX"],        pbxValue,    "#"),
            new(extDot,    L["Sem_Extensions"], extValue,    "/extensions"),
            new(queueDot,  L["Sem_Queues"],     queueValue,  "/queues"),
            new(trunkDot,  L["Sem_Trunks"],     trunkValue,  "/trunks"),
            new(parkDot,   L["Sem_Parking"],    parkValue,   "/parking"),
            new(agentDot,  L["Sem_Agents"],     agentValue,  "/agents"),
        ];
    }

    public void Dispose()
    {
        SelectedServer.OnChanged -= OnServerChanged;
    }
}
