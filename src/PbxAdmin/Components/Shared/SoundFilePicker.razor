@using PbxAdmin.Models
@inject SystemSoundService SoundSvc
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L

<div class="sound-picker">
    <div class="sound-picker-row">
        <input class="input sound-picker-input" type="text" value="@Value"
               @oninput="OnInput" placeholder="@Placeholder"
               list="@_listId" />
        <datalist id="@_listId">
            @foreach (var s in _filteredSounds.Take(20))
            {
                <option value="@s.Name">@s.Category/@s.Name</option>
            }
        </datalist>
        @if (!string.IsNullOrEmpty(Value))
        {
            <span class="sound-status @_statusClass" title="@_statusText">@_statusIcon</span>
            <button type="button" class="btn btn-sm btn-muted" @onclick="Preview"
                    title="@L["Lbl_Play"]">&#9654;</button>
        }
    </div>

    @if (_playing && _audioUrl is not null)
    {
        <div class="audio-player mt-1">
            <audio controls autoplay src="@_audioUrl" @onended="StopPreview"></audio>
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public SoundPickerMode Mode { get; set; } = SoundPickerMode.SystemSound;
    [Parameter] public string? ServerId { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Type or select sound...";

    private string _listId = $"sp-{Guid.NewGuid():N}";
    private List<SoundFileInfo> _allSounds = [];
    private List<SoundFileInfo> _filteredSounds = [];
    private bool _playing;
    private string? _audioUrl;
    private string _statusClass = "indicator-gray";
    private string _statusIcon = "?";
    private string _statusText = "";

    protected override async Task OnInitializedAsync()
    {
        var sid = ServerId ?? ServerSvc.SelectedServerId ?? "default";
        if (Mode is SoundPickerMode.SystemSound or SoundPickerMode.Both)
        {
            _allSounds = await SoundSvc.GetSystemSoundsAsync(sid);
        }
        _filteredSounds = _allSounds;
        UpdateStatus();
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        _filteredSounds = string.IsNullOrWhiteSpace(Value)
            ? _allSounds
            : _allSounds.Where(s => s.Name.Contains(Value, StringComparison.OrdinalIgnoreCase)).ToList();
        UpdateStatus();
        await ValueChanged.InvokeAsync(Value);
    }

    private void UpdateStatus()
    {
        if (string.IsNullOrEmpty(Value))
        {
            _statusClass = "indicator-gray";
            _statusIcon = "?";
            _statusText = "";
            return;
        }

        var sid = ServerId ?? ServerSvc.SelectedServerId ?? "default";
        var exists = SoundSvc.SoundExists(sid, Value);
        _statusClass = exists ? "indicator-green" : "indicator-red";
        _statusIcon = exists ? "✓" : "✗";
        _statusText = exists ? "Sound found" : "Sound not found";
    }

    private void Preview()
    {
        var sid = ServerId ?? ServerSvc.SelectedServerId ?? "default";
        var match = _allSounds.FirstOrDefault(s =>
            string.Equals(s.Name, Value, StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            _audioUrl = $"/api/sounds/{match.RelativePath}?serverId={sid}";
            _playing = true;
        }
    }

    private void StopPreview() => _playing = false;
}
