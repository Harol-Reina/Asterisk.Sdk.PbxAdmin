@namespace PbxAdmin.Components.Shared
@implements IDisposable
@inject IToastService Toast
@inject IStringLocalizer<SharedStrings> L

<div class="notification-bell" @onclick="Toggle" @onclick:stopPropagation="true" style="position:relative;display:inline-block;">
    <span style="font-size:1.1rem;">&#128276;</span>
    @if (Toast.UnreadCount > 0)
    {
        <span class="notification-badge">@(Toast.UnreadCount > 9 ? "9+" : Toast.UnreadCount.ToString())</span>
    }

    @if (_open)
    {
        <div class="notification-panel" @onclick:stopPropagation="true">
            <div class="notification-header">
                <span class="notification-header-title">@L["Notif_Title"]</span>
                @if (Toast.Notifications.Count > 0)
                {
                    <span class="notification-header-action" @onclick="ClearAll">@L["Notif_ClearAll"]</span>
                }
            </div>
            <div class="notification-list">
                @if (Toast.Notifications.Count == 0)
                {
                    <div class="notification-empty">@L["Notif_Empty"]</div>
                }
                else
                {
                    @foreach (var entry in Toast.Notifications)
                    {
                        <div class="notification-entry @(entry.IsRead ? "" : "unread")">
                            <div class="notification-dot @entry.Level.ToString().ToLowerInvariant()"></div>
                            <div class="notification-text">
                                <div class="notification-title-text">@entry.Title</div>
                                <div class="notification-time">@FormatTimeAgo(entry.Timestamp)</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _open;

    protected override void OnInitialized() => Toast.OnChanged += Refresh;

    private void Toggle()
    {
        _open = !_open;
        if (_open) Toast.MarkAllRead();
    }

    private void ClearAll()
    {
        Toast.ClearNotifications();
        _open = false;
    }

    private static string FormatTimeAgo(DateTimeOffset timestamp)
    {
        var diff = DateTimeOffset.UtcNow - timestamp;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        return $"{(int)diff.TotalHours}h ago";
    }

    private async void Refresh() => await InvokeAsync(StateHasChanged);

    public void Dispose() => Toast.OnChanged -= Refresh;
}
