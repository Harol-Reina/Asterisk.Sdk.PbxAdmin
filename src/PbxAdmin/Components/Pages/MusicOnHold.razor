@page "/moh"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject MohService MohSvc
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["Moh_Title"]</PageTitle>

<div class="page-header-row">
    <h2>@L["Moh_Heading"]</h2>
    <button class="btn btn-primary" @onclick="NewClass">@L["Moh_NewClass"]</button>
</div>
<HelpPanel SectionKey="MusicOnHold_Overview">@L["Moh_Heading"]</HelpPanel>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_classes.Count == 0)
{
    <p class="text-muted">@L["Moh_NoClasses"]</p>
}
else
{
    <div class="card-grid">
        @foreach (var cls in _classes)
        {
            <div class="card clickable" @onclick="() => EditClass(cls.Id)">
                <div class="card-header">
                    <strong>@cls.Name</strong>
                    @if (cls.Mode == "mp3")
                    {
                        <span class="badge badge-warning" title="Deprecated since Asterisk 14+">mp3</span>
                    }
                </div>
                <div class="card-body">
                    <div class="stat-row">
                        <span class="text-muted">Mode:</span> @cls.Mode
                    </div>
                    @if (!string.IsNullOrEmpty(cls.Directory))
                    {
                        <div class="stat-row">
                            <span class="text-muted">Directory:</span> @cls.Directory
                        </div>
                        <div class="stat-row">
                            <span class="text-muted">Sort:</span> @cls.Sort
                        </div>
                    }
                    @if (_fileCounts.TryGetValue(cls.Id, out var info))
                    {
                        <div class="stat-row">
                            <span class="text-muted">Files:</span> @info.Count (@FormatSize(info.TotalSize))
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button class="btn btn-sm btn-danger" @onclick:stopPropagation="true"
                            @onclick="() => DeleteClass(cls)">@L["Btn_Delete"]</button>
                </div>
            </div>
        }
    </div>
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private List<MohClass> _classes = [];
    private Dictionary<int, (int Count, long TotalSize)> _fileCounts = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is not null)
        {
            _classes = await MohSvc.GetClassesAsync(serverId);

            foreach (var cls in _classes)
            {
                var files = await MohSvc.GetAudioFilesAsync(cls.Id);
                _fileCounts[cls.Id] = (files.Count, files.Sum(f => f.Size));
            }
        }
        _loading = false;
    }

    private void NewClass() => Nav.NavigateTo("/moh/edit/new");
    private void EditClass(int id) => Nav.NavigateTo($"/moh/edit/{id}");

    private async Task DeleteClass(MohClass cls)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var (success, error) = await MohSvc.DeleteClassAsync(serverId, cls.Id);
        if (success)
        {
            _classes.Remove(cls);
            _fileCounts.Remove(cls.Id);
        }
        else
            _error = error;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
