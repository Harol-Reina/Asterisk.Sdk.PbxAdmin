@page "/events"
@using PbxAdmin.Services
@inject EventLogService EventLog
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>@L["Evt_Title"]</PageTitle>

<h2>@L["Evt_Heading"]</h2>
<HelpPanel SectionKey="Events_Overview">@L["Evt_Heading"]</HelpPanel>

<div class="chip-bar">
    <button class="chip @(_typeFilter is null ? "chip-active" : "")" @onclick="() => _typeFilter = null">@L["Evt_All"]</button>
    <button class="chip @(_typeFilter == "Channel" ? "chip-active" : "")" @onclick='() => _typeFilter = "Channel"'>Channel</button>
    <button class="chip @(_typeFilter == "Queue" ? "chip-active" : "")" @onclick='() => _typeFilter = "Queue"'>Queue</button>
    <button class="chip @(_typeFilter == "Agent" ? "chip-active" : "")" @onclick='() => _typeFilter = "Agent"'>Agent</button>
</div>

<div class="event-log">
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_Time"]</th>
                <th>@L["Col_Event"]</th>
                <th>@L["Col_UniqueId"]</th>
                <th>@L["Col_Channel"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in GetFilteredEntries())
            {
                <tr>
                    <td class="mono">@entry.Timestamp.ToString("HH:mm:ss.fff")</td>
                    <td><strong>@entry.EventType</strong></td>
                    <td class="mono">@entry.UniqueId</td>
                    <td>@entry.Channel</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private Timer? _timer;
    private string? _typeFilter;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => InvokeAsync(StateHasChanged),
            null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private IEnumerable<EventLogEntry> GetFilteredEntries()
    {
        var entries = EventLog.GetRecent(50)
            .Where(e => e.ServerId == ServerSvc.SelectedServerId);

        if (_typeFilter is not null)
            entries = entries.Where(e => e.EventType.Contains(_typeFilter, StringComparison.OrdinalIgnoreCase));

        return entries;
    }

    public void Dispose() => _timer?.Dispose();
}
