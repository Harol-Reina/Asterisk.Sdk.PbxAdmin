@page "/time-conditions/new"
@page "/time-conditions/edit/{Id:int}"
@using PbxAdmin.Services
@using PbxAdmin.Models
@inject TimeConditionService TcSvc
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast

<PageTitle>@(_isNew ? L["TCEdit_NewTitle"] : L["TCEdit_EditTitle", _config.Name]) — Asterisk PBX Admin</PageTitle>

<a href="/time-conditions" class="back-link">@L["TCEdit_BackToList"]</a>
<h2>@(_isNew ? L["TCEdit_New"] : L["TCEdit_Edit", _config.Name])</h2>

@if (_loading)
{
    <p class="text-muted">@L["Lbl_Loading"]</p>
}
else
{
    <!-- Name -->
    <div class="form-section">
        <HelpPanel SectionKey="TcEdit_Identity">@L["ExtEdit_Identity"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Name"] <HelpIcon HelpKey="TcName" /></label>
                <input class="input" @bind="_config.Name" placeholder="business-hours" />
                <span class="text-muted" style="font-size:0.85rem;">@L["TCEdit_NameHint"]</span>
            </div>
            <div class="form-field">
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.Enabled" />
                    @L["Lbl_Enabled"] <HelpIcon HelpKey="TcEnabled" />
                </label>
            </div>
        </div>
    </div>

    <!-- Schedule Builder -->
    <div class="form-section">
        <HelpPanel SectionKey="TcEdit_Schedule">@L["TCEdit_Schedule"]</HelpPanel>
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Col_Day"]</th>
                    <th>@L["Col_Enable"]</th>
                    <th>@L["Col_Start"]</th>
                    <th>@L["Col_End"]</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < 7; i++)
                {
                    var dayIndex = i;
                    var day = (DayOfWeek)(((int)DayOfWeek.Monday + dayIndex) % 7);
                    <tr>
                        <td>@day</td>
                        <td>
                            <input type="checkbox" checked="@_dayEnabled[dayIndex]"
                                   @onchange="e => _dayEnabled[dayIndex] = (bool)(e.Value ?? false)" />
                        </td>
                        <td>
                            <input type="time" value="@_dayStart[dayIndex]" disabled="@(!_dayEnabled[dayIndex])"
                                   @onchange="e => _dayStart[dayIndex] = e.Value?.ToString() ?? DefaultStart"
                                   style="background: var(--card-bg); color: var(--text); border: 1px solid var(--border); border-radius: 4px; padding: 0.3rem;" />
                        </td>
                        <td>
                            <input type="time" value="@_dayEnd[dayIndex]" disabled="@(!_dayEnabled[dayIndex])"
                                   @onchange="e => _dayEnd[dayIndex] = e.Value?.ToString() ?? DefaultEnd"
                                   style="background: var(--card-bg); color: var(--text); border: 1px solid var(--border); border-radius: 4px; padding: 0.3rem;" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Holidays -->
    <div class="form-section">
        <HelpPanel SectionKey="TcEdit_Holidays">@L["TCEdit_HolidaysSection"]</HelpPanel>
        @if (_holidays.Count > 0)
        {
            <table class="data-table" style="margin-bottom: 0.75rem;">
                <thead>
                    <tr>
                        <th>@L["Lbl_Name"]</th>
                        <th>@L["Col_Month"]</th>
                        <th>@L["Col_Day"]</th>
                        <th>@L["Col_Recurring"]</th>
                        <th>@L["Lbl_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var holiday in _holidays)
                    {
                        <tr>
                            <td><input class="input" @bind="holiday.Name" style="width: 12rem;" /></td>
                            <td>
                                <select class="input" @bind="holiday.Month" style="width: 6rem;">
                                    @for (var m = 1; m <= 12; m++)
                                    {
                                        <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <input class="input" type="number" @bind="holiday.Day" min="1" max="31" style="width: 4rem;" />
                            </td>
                            <td>
                                <input type="checkbox" @bind="holiday.Recurring" />
                            </td>
                            <td>
                                <button class="btn btn-sm btn-red" @onclick="() => _holidays.Remove(holiday)">@L["Btn_Remove"]</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <button class="btn" @onclick="AddHoliday">@L["TCEdit_AddHoliday"]</button>
    </div>

    <!-- Match / No-Match Destinations -->
    <div class="form-section">
        <HelpPanel SectionKey="TcEdit_Destinations">@L["TCEdit_MatchDest"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Type"] <HelpIcon HelpKey="TcMatchType" /></label>
                <select class="input" @bind="_config.MatchDestType">
                    <option value="">@L["Lbl_SelectType"]</option>
                    <option value="extension">@L["Lbl_Extension"]</option>
                    <option value="queue">@L["Lbl_Queue"]</option>
                    <option value="time_condition">@L["Lbl_TimeCondition"]</option>
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Lbl_Target"] <HelpIcon HelpKey="TcMatchTarget" /></label>
                <input class="input" @bind="_config.MatchDest" placeholder="Destination" />
            </div>
        </div>
        <h4 style="margin-top: 1rem;">@L["TCEdit_NoMatchDest"]</h4>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Type"] <HelpIcon HelpKey="TcNoMatchType" /></label>
                <select class="input" @bind="_config.NoMatchDestType">
                    <option value="">@L["Lbl_SelectType"]</option>
                    <option value="extension">@L["Lbl_Extension"]</option>
                    <option value="queue">@L["Lbl_Queue"]</option>
                    <option value="time_condition">@L["Lbl_TimeCondition"]</option>
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Lbl_Target"] <HelpIcon HelpKey="TcNoMatchTarget" /></label>
                <input class="input" @bind="_config.NoMatchDest" placeholder="Destination" />
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button class="btn btn-green" @onclick="Save" disabled="@_saving">@(_saving ? L["Btn_Saving"] : L["Btn_Save"])</button>
        <button class="btn" @onclick="NavigateBack">@L["Btn_Cancel"]</button>
    </div>

}

<style>
    .data-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--card-bg);
        border-radius: 8px;
        overflow: hidden;
    }
    .data-table th, .data-table td {
        padding: 0.6rem 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
    }
    .data-table th {
        background: rgba(255,255,255,0.04);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--text-muted);
    }
</style>

@code {
    private const string DefaultStart = "09:00";
    private const string DefaultEnd = "17:00";

    [Parameter] public int Id { get; set; }

    private bool _isNew => Id == 0;
    private bool _loading = true;
    private bool _saving;

    private TimeConditionConfig _config = new();
    private List<HolidayEntry> _holidays = [];

    // Schedule state: 7 rows (Mon-Sun)
    private bool[] _dayEnabled = new bool[7];
    private string[] _dayStart = ["09:00", "09:00", "09:00", "09:00", "09:00", "09:00", "09:00"];
    private string[] _dayEnd = ["17:00", "17:00", "17:00", "17:00", "17:00", "17:00", "17:00"];

    protected override async Task OnInitializedAsync()
    {
        if (!_isNew)
        {
            var existing = await TcSvc.GetTimeConditionAsync(Id);
            if (existing is not null)
            {
                _config = existing;
                _holidays = [.. existing.Holidays];

                // Populate schedule from ranges
                foreach (var range in existing.Ranges)
                {
                    var dayIndex = DayToIndex(range.DayOfWeek);
                    _dayEnabled[dayIndex] = true;
                    _dayStart[dayIndex] = range.StartTime.ToString("HH:mm");
                    _dayEnd[dayIndex] = range.EndTime.ToString("HH:mm");
                }
            }
        }
        else
        {
            _config.ServerId = ServerSvc.SelectedServerId ?? "";
            // Enable weekdays by default
            for (var i = 0; i < 5; i++)
                _dayEnabled[i] = true;
        }

        _loading = false;
    }

    private void AddHoliday()
    {
        _holidays.Add(new HolidayEntry { Name = "", Month = 1, Day = 1, Recurring = true });
    }

    private void BuildRangesFromSchedule()
    {
        _config.Ranges.Clear();
        for (var i = 0; i < 7; i++)
        {
            if (!_dayEnabled[i]) continue;

            var day = IndexToDay(i);
            if (TimeOnly.TryParse(_dayStart[i], out var start) && TimeOnly.TryParse(_dayEnd[i], out var end))
            {
                _config.Ranges.Add(new TimeRangeEntry
                {
                    DayOfWeek = day,
                    StartTime = start,
                    EndTime = end,
                });
            }
        }
    }

    private async Task Save()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (string.IsNullOrEmpty(serverId))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, "No server selected.");
            return;
        }

        // Validate name
        if (string.IsNullOrWhiteSpace(_config.Name))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "Name is required.");
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(_config.Name, @"^[a-zA-Z0-9\-]+$"))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "Name must contain only alphanumeric characters and hyphens.");
            return;
        }

        if (_dayEnabled.All(d => !d))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "At least one day must be enabled.");
            return;
        }

        _saving = true;

        try
        {
            _config.ServerId = serverId;
            _config.Holidays = [.. _holidays];
            BuildRangesFromSchedule();

            var opName = _isNew ? "Creating Time Condition" : "Updating Time Condition";
            using var _ = ConfigOp.Begin(opName, serverId, _config.Name);

            var (success, error) = _isNew
                ? await TcSvc.CreateTimeConditionAsync(_config)
                : await TcSvc.UpdateTimeConditionAsync(_config);

            if (success)
                Nav.NavigateTo("/time-conditions");
            else
                Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
        catch (Exception ex)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private static int DayToIndex(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => 0,
        DayOfWeek.Tuesday => 1,
        DayOfWeek.Wednesday => 2,
        DayOfWeek.Thursday => 3,
        DayOfWeek.Friday => 4,
        DayOfWeek.Saturday => 5,
        DayOfWeek.Sunday => 6,
        _ => 0
    };

    private static DayOfWeek IndexToDay(int index) => index switch
    {
        0 => DayOfWeek.Monday,
        1 => DayOfWeek.Tuesday,
        2 => DayOfWeek.Wednesday,
        3 => DayOfWeek.Thursday,
        4 => DayOfWeek.Friday,
        5 => DayOfWeek.Saturday,
        6 => DayOfWeek.Sunday,
        _ => DayOfWeek.Monday
    };

    private void NavigateBack() => Nav.NavigateTo("/time-conditions");
}
