@page "/feature-codes"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject FeatureCodeService FeatureSvc
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["FC_Title"]</PageTitle>

<h2>@L["FC_Heading"]</h2>
<HelpPanel SectionKey="FeatureCodes_Overview">@L["FC_Heading"]</HelpPanel>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="page-header-row">
    <h3>@L["FC_StarCodes"]</h3>
    <button class="btn btn-primary" @onclick="ShowNewCode">@L["FC_NewCode"]</button>
</div>

@if (_codes.Count == 0)
{
    <p class="text-muted">@L["FC_NoCodes"]</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_Code"]</th>
                <th>@L["Lbl_Name"]</th>
                <th>@L["Lbl_Description"]</th>
                <th>@L["Lbl_Enabled"]</th>
                <th>@L["Lbl_Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fc in _codes)
            {
                <tr>
                    <td class="mono"><strong>@fc.Code</strong></td>
                    <td>@fc.Name</td>
                    <td class="text-muted">@fc.Description</td>
                    <td>
                        <button class="btn btn-sm @(fc.Enabled ? "btn-green" : "btn-muted")"
                                @onclick="() => ToggleCode(fc)">
                            @(fc.Enabled ? L["Lbl_On"] : L["Lbl_Off"])
                        </button>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-blue" @onclick="() => EditCode(fc)">@L["Btn_Edit"]</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => _deleteConfirmId = fc.Id">@L["Btn_Delete"]</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_deleteConfirmId is not null)
{
    <div class="confirm-bar confirm-bar-danger">
        <span>@L["FC_DeleteCode"] <strong>@_codes.FirstOrDefault(c => c.Id == _deleteConfirmId)?.Code</strong>?</span>
        <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(_deleteConfirmId!.Value)">@L["Btn_Confirm"]</button>
        <button class="btn btn-sm btn-muted" @onclick="() => _deleteConfirmId = null">@L["Btn_Cancel"]</button>
    </div>
}

@* ---------- Inline Edit Form ---------- *@

@if (_editingCode is not null)
{
    <div class="form-section mt-2">
        <h4>@(_editingCode.Id == 0 ? L["FC_NewFeatureCode"] : $"{L["FC_EditCode"]}: {_editingCode.Code}")</h4>

        <div class="form-group">
            <label>@L["Col_Code"] <HelpIcon HelpKey="FcCode" /></label>
            <input type="text" @bind="_editingCode.Code" class="form-control"
                   placeholder="e.g. *72, #21" />
        </div>

        <div class="form-group">
            <label>@L["Lbl_Name"] <HelpIcon HelpKey="FcName" /></label>
            <input type="text" @bind="_editingCode.Name" class="form-control"
                   placeholder="Call Forward Activate" />
        </div>

        <div class="form-group">
            <label>@L["Lbl_Description"] <HelpIcon HelpKey="FcDescription" /></label>
            <input type="text" @bind="_editingCode.Description" class="form-control"
                   placeholder="Optional description" />
        </div>

        <div class="form-group">
            <label>
                <input type="checkbox" @bind="_editingCode.Enabled" />
                @L["Lbl_Enabled"] <HelpIcon HelpKey="FcEnabled" />
            </label>
        </div>

        <div class="form-actions">
            <button class="btn btn-muted" @onclick="CancelEdit">@L["Btn_Cancel"]</button>
            <button class="btn btn-primary" @onclick="SaveCode" disabled="@_saving">
                @(_saving ? L["Btn_Saving"] : L["Btn_Save"])
            </button>
        </div>
    </div>
}

@code {
    private List<FeatureCode> _codes = [];
    private FeatureCode? _editingCode;
    private bool _saving;
    private string? _error;
    private int? _deleteConfirmId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        try
        {
            _codes = await FeatureSvc.GetFeatureCodesAsync(serverId);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load feature codes: {ex.Message}";
        }
    }

    private void ShowNewCode()
    {
        _editingCode = new FeatureCode { Enabled = true };
    }

    private void EditCode(FeatureCode code)
    {
        _editingCode = code with { };
    }

    private void CancelEdit() => _editingCode = null;

    private async Task SaveCode()
    {
        if (_editingCode is null) return;

        if (string.IsNullOrWhiteSpace(_editingCode.Code))
        {
            _error = "Code is required";
            return;
        }

        _saving = true;
        _error = null;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) { _error = "No server selected"; _saving = false; return; }

        var (success, error) = _editingCode.Id == 0
            ? await FeatureSvc.CreateFeatureCodeAsync(serverId, _editingCode)
            : await FeatureSvc.UpdateFeatureCodeAsync(serverId, _editingCode);

        _saving = false;

        if (success)
        {
            _editingCode = null;
            await LoadAsync();
        }
        else
        {
            _error = error;
        }
    }

    private async Task ToggleCode(FeatureCode code)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var updated = code with { Enabled = !code.Enabled };
        var (success, error) = await FeatureSvc.UpdateFeatureCodeAsync(serverId, updated);
        if (success)
            await LoadAsync();
        else
            _error = error;
    }

    private async Task ConfirmDelete(int id)
    {
        _deleteConfirmId = null;
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var (success, error) = await FeatureSvc.DeleteFeatureCodeAsync(serverId, id);
        if (success)
            await LoadAsync();
        else
            _error = error;
    }
}
