@page "/traffic"
@inject ICallSessionManager Sessions
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>@L["Traf_Title"]</PageTitle>

<h2>@L["Traf_Heading"]</h2>
<HelpPanel SectionKey="Traffic_Overview">@L["Traf_Heading"]</HelpPanel>

<div class="kpi-grid">
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_originated</div>
        <div class="kpi-label">@L["Traf_Originated"]</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@_answered (@_answeredPct%)</div>
        <div class="kpi-label">@L["Traf_Answered"]</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-value">@_unanswered (@_unansweredPct%)</div>
        <div class="kpi-label">@L["Traf_Unanswered"]</div>
    </div>
    <div class="kpi-card kpi-purple">
        <div class="kpi-value">@_bridged (@_bridgedPct%)</div>
        <div class="kpi-label">@L["Traf_BridgedToAgent"]</div>
    </div>
</div>

<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-orange">
        <div class="kpi-value">@_activeNow</div>
        <div class="kpi-label">@L["Traf_ActiveNow"]</div>
    </div>
    <div class="kpi-card kpi-gray">
        <div class="kpi-value">@_completed</div>
        <div class="kpi-label">@L["Calls_Completed"]</div>
    </div>
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_avgDuration</div>
        <div class="kpi-label">@L["Traf_AvgDuration"]</div>
    </div>
    <div class="kpi-card kpi-yellow">
        <div class="kpi-value">@_avgWait</div>
        <div class="kpi-label">@L["Home_AvgWait"]</div>
    </div>
</div>

<label style="margin: 1rem 0; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer;">
    <input type="checkbox" @bind="_showAdvanced" />
    @L["Traf_ShowAdvanced"]
</label>

@if (_showAdvanced)
{
    <h3>@L["Traf_StateBreakdown"]</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_State"]</th>
                <th>@L["Col_Count"]</th>
                <th>%</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _stateBreakdown)
            {
                <tr>
                    <td>@row.State</td>
                    <td>@row.Count</td>
                    <td>@row.Pct%</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>@L["Traf_TopQueues"]</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_Queue"]</th>
                <th>@L["Col_Count"]</th>
                <th>@L["Traf_Answered"]</th>
                <th>@L["Traf_AnswerRate"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _topQueues)
            {
                <tr>
                    <td>@row.Queue</td>
                    <td>@row.Calls</td>
                    <td>@row.Answered</td>
                    <td>@row.AnswerRate%</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>@L["Traf_TopAgents"]</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Calls_Agent"]</th>
                <th>@L["Traf_CallsHandled"]</th>
                <th>@L["Col_AvgTalk"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _topAgents)
            {
                <tr>
                    <td>@row.Agent</td>
                    <td>@row.Calls</td>
                    <td>@row.AvgDuration</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Timer? _timer;
    private bool _showAdvanced;

    private int _originated, _answered, _unanswered, _bridged, _activeNow, _completed;
    private string _answeredPct = "0", _unansweredPct = "0", _bridgedPct = "0";
    private string _avgDuration = "\u2014", _avgWait = "\u2014";

    private List<StateRow> _stateBreakdown = [];
    private List<QueueRow> _topQueues = [];
    private List<AgentRow> _topAgents = [];

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => { Refresh(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private void Refresh()
    {
        var sessions = Sessions.ActiveSessions.Concat(Sessions.GetRecentCompleted(500))
            .Where(s => s.ServerId == ServerSvc.SelectedServerId)
            .ToList();

        _originated = sessions.Count;
        _answered = sessions.Count(s => s.ConnectedAt is not null);
        _unanswered = _originated - _answered;
        _bridged = sessions.Count(s => s.AgentId is not null);

        _answeredPct = _originated > 0 ? ((double)_answered / _originated * 100).ToString("F0") : "0";
        _unansweredPct = _originated > 0 ? ((double)_unanswered / _originated * 100).ToString("F0") : "0";
        _bridgedPct = _answered > 0 ? ((double)_bridged / _answered * 100).ToString("F0") : "0";

        _activeNow = sessions.Count(s => s.State is not (CallSessionState.Completed or CallSessionState.Failed or CallSessionState.TimedOut));
        _completed = sessions.Count(s => s.State is CallSessionState.Completed or CallSessionState.Failed or CallSessionState.TimedOut);

        var completedSessions = sessions.Where(s => s.State is CallSessionState.Completed or CallSessionState.Failed or CallSessionState.TimedOut).ToList();
        _avgDuration = completedSessions.Count > 0
            ? FormatSeconds((int)completedSessions.Average(s => s.Duration.TotalSeconds))
            : "\u2014";

        var waitTimes = sessions
            .Select(s => s.WaitTime)
            .Where(t => t.HasValue)
            .Select(t => t!.Value)
            .ToList();
        _avgWait = waitTimes.Count > 0
            ? FormatSeconds((int)waitTimes.Average(t => t.TotalSeconds))
            : "\u2014";

        if (_showAdvanced)
            RefreshAdvanced(sessions);
    }

    private void RefreshAdvanced(List<CallSession> sessions)
    {
        _stateBreakdown = Enum.GetValues<CallSessionState>()
            .Select(s =>
            {
                var count = sessions.Count(c => c.State == s);
                return new StateRow
                {
                    State = s,
                    Count = count,
                    Pct = _originated > 0 ? ((double)count / _originated * 100).ToString("F0") : "0"
                };
            })
            .Where(r => r.Count > 0)
            .ToList();

        _topQueues = sessions
            .Where(s => s.QueueName is not null)
            .GroupBy(s => s.QueueName!)
            .Select(g =>
            {
                var total = g.Count();
                var ans = g.Count(s => s.ConnectedAt is not null);
                return new QueueRow
                {
                    Queue = g.Key,
                    Calls = total,
                    Answered = ans,
                    AnswerRate = total > 0 ? ((double)ans / total * 100).ToString("F0") : "0"
                };
            })
            .OrderByDescending(r => r.Calls)
            .Take(10)
            .ToList();

        _topAgents = sessions
            .Where(s => s.AgentId is not null)
            .GroupBy(s => s.AgentId!)
            .Select(g => new AgentRow
            {
                Agent = g.Key,
                Calls = g.Count(),
                AvgDuration = FormatSeconds((int)g.Average(s => s.Duration.TotalSeconds))
            })
            .OrderByDescending(r => r.Calls)
            .Take(10)
            .ToList();
    }

    private static string FormatSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}m{ts.Seconds:D2}s" : $"{ts.Seconds}s";
    }

    public void Dispose() => _timer?.Dispose();

    private sealed class StateRow
    {
        public CallSessionState State { get; init; }
        public int Count { get; init; }
        public string Pct { get; init; } = "0";
    }

    private sealed class QueueRow
    {
        public string Queue { get; init; } = "";
        public int Calls { get; init; }
        public int Answered { get; init; }
        public string AnswerRate { get; init; } = "0";
    }

    private sealed class AgentRow
    {
        public string Agent { get; init; } = "";
        public int Calls { get; init; }
        public string AvgDuration { get; init; } = "\u2014";
    }
}
