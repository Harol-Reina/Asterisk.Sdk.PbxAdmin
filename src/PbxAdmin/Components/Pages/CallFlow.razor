@code {
    private CallFlowGraph? _graph;
    private List<DidNode> _filteredDids = [];
    private DidNode? _selectedDid;
    private string _search = "";
    private bool _loading = true;
    private HashSet<string> _expandedDialplan = new(StringComparer.Ordinal);

    // ── Tracer state ──
    private string _traceNumber = "";
    private DateTime _traceTime = DateTime.Now;
    private string _traceOverrideMode = "Live";
    private CallFlowTrace? _traceResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null)
        {
            _loading = false;
            return;
        }

        _graph = await FlowSvc.BuildFlowAsync(serverId);
        ApplyFilter();
        _loading = false;
    }

    private void ApplyFilter()
    {
        if (_graph is null)
        {
            _filteredDids = [];
            return;
        }

        if (string.IsNullOrWhiteSpace(_search))
        {
            _filteredDids = _graph.InboundFlows;
        }
        else
        {
            _filteredDids = _graph.InboundFlows
                .Where(d => d.DidPattern.Contains(_search, StringComparison.OrdinalIgnoreCase)
                    || d.RouteName.Contains(_search, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SelectDid(DidNode did)
    {
        _selectedDid = did;
        _expandedDialplan.Clear();
    }

    // ── Tracer methods ──

    private async Task ExecuteTrace()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || string.IsNullOrWhiteSpace(_traceNumber)) return;
        _traceResult = await FlowSvc.TraceCallAsync(serverId, _traceNumber.Trim(), _traceTime, _traceOverrideMode);
    }

    private void ClearTrace()
    {
        _traceResult = null;
    }

    // ── KPI computations ──

    private int ActiveDidCount => _graph?.InboundFlows.Count ?? 0;

    private string TcSummary
    {
        get
        {
            if (_graph is null) return "0";
            var tcNodes = CollectNodes<TimeConditionNode>(_graph);
            var open = tcNodes.Count(tc => string.Equals(tc.CurrentState, "Active", StringComparison.OrdinalIgnoreCase));
            var closed = tcNodes.Count(tc => string.Equals(tc.CurrentState, "Disabled", StringComparison.OrdinalIgnoreCase));
            var overrideCount = _graph.Warnings.Count(w =>
                string.Equals(w.Category, "Operational", StringComparison.OrdinalIgnoreCase) &&
                w.Message.Contains("override", StringComparison.OrdinalIgnoreCase));
            return $"{open} open / {closed} closed / {overrideCount} override";
        }
    }

    private string QueueHealthSummary
    {
        get
        {
            if (_graph is null) return "0";
            var qNodes = CollectNodes<QueueNode>(_graph);
            var healthy = qNodes.Count(q => q.OnlineCount > 0);
            var empty = qNodes.Count(q => q.OnlineCount == 0);
            return $"{healthy} healthy / {empty} empty";
        }
    }

    private string TrunkStatusSummary
    {
        get
        {
            if (_graph is null) return "0";
            var trunkDownCount = _graph.Warnings.Count(w =>
                string.Equals(w.Severity, "Error", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(w.Category, "BrokenRef", StringComparison.OrdinalIgnoreCase) &&
                w.Message.Contains("trunk", StringComparison.OrdinalIgnoreCase));
            if (trunkDownCount > 0)
                return $"{trunkDownCount} down";
            return "All OK";
        }
    }

    // ── Node collector ──

    private static List<T> CollectNodes<T>(CallFlowGraph graph) where T : CallFlowNode
    {
        var result = new List<T>();
        foreach (var did in graph.InboundFlows)
        {
            CollectNodesRecursive(did.Destination, result);
        }
        return result;
    }

    private static void CollectNodesRecursive<T>(CallFlowNode? node, List<T> result) where T : CallFlowNode
    {
        if (node is null) return;

        if (node is T typed)
            result.Add(typed);

        switch (node)
        {
            case TimeConditionNode tc:
                CollectNodesRecursive(tc.OpenBranch, result);
                CollectNodesRecursive(tc.ClosedBranch, result);
                break;
            case IvrNode ivr:
                foreach (var opt in ivr.Options)
                    CollectNodesRecursive(opt.Destination, result);
                break;
        }
    }

    // ── Warning helpers ──

    private static string GetWarningSeverityClass(string severity) => severity switch
    {
        "Error" => "severity-error",
        "Warning" => "severity-warning",
        "Info" => "severity-info",
        _ => ""
    };

    private static string GetWarningIcon(string severity) => severity switch
    {
        "Error" => "\u26d4",
        "Warning" => "\u26a0\ufe0f",
        "Info" => "\u2139\ufe0f",
        _ => ""
    };

    private void NavigateToWarning(HealthWarning warning)
    {
        if (warning.NavigateUrl is not null)
            Nav.NavigateTo(warning.NavigateUrl);
    }

    // ── Destination badge helpers ──

    private static string GetDestBadgeClass(CallFlowNode? dest) => dest switch
    {
        TimeConditionNode => "badge-green",
        QueueNode => "badge-blue",
        ExtensionNode => "badge-purple",
        IvrNode => "badge-orange",
        VoicemailNode => "badge-cyan",
        HangupNode => "badge-red",
        _ => "badge-muted"
    };

    private static string GetDestTypeName(CallFlowNode? dest) => dest switch
    {
        TimeConditionNode => "TC",
        QueueNode => "Queue",
        ExtensionNode => "Ext",
        IvrNode => "IVR",
        VoicemailNode => "VM",
        HangupNode => "Hangup",
        _ => "None"
    };

    // ── Flow rendering ──

    private RenderFragment RenderFlowNode(CallFlowNode node) => builder =>
    {
        switch (node)
        {
            case TimeConditionNode tc:
                RenderTcCard(tc)(builder);
                break;
            case IvrNode ivr:
                RenderIvrCard(ivr)(builder);
                break;
            case QueueNode queue:
                RenderQueueCard(queue)(builder);
                break;
            case ExtensionNode ext:
                RenderExtensionCard(ext)(builder);
                break;
            case VoicemailNode vm:
                RenderVoicemailCard(vm)(builder);
                break;
            case HangupNode:
                RenderHangupCard()(builder);
                break;
        }
    };

    private RenderFragment RenderTcCard(TimeConditionNode tc) => __builder =>
    {
        <div class="cf-flow-card tc @(tc.EditUrl is not null ? "clickable" : "")"
             @onclick="() => NavigateEdit(tc.EditUrl)">
            <div class="cf-flow-type">Time Condition</div>
            <div class="cf-flow-name">@tc.Label</div>
            <div class="cf-flow-meta">@tc.ScheduleSummary</div>
            <div class="cf-flow-state">@tc.CurrentState</div>
            <div style="display:flex; gap:0.5rem; align-items:center; margin-top:0.25rem;">
                @RenderDialplanToggle(tc)
                <a href="@($"/dialplan?context=tc-{Uri.EscapeDataString(tc.Label)}")" class="btn btn-sm" style="font-size:0.75rem;" @onclick:stopPropagation="true">Adv. Dialplan</a>
            </div>
        </div>

        @if (tc.OpenBranch is not null)
        {
            <div class="cf-branch">
                <div class="cf-branch-label">Open:</div>
                @RenderFlowNode(tc.OpenBranch)
            </div>
        }

        @if (tc.ClosedBranch is not null)
        {
            <div class="cf-branch">
                <div class="cf-branch-label">Closed:</div>
                @RenderFlowNode(tc.ClosedBranch)
            </div>
        }
    };

    private RenderFragment RenderIvrCard(IvrNode ivr) => __builder =>
    {
        <div class="cf-flow-card ivr @(ivr.EditUrl is not null ? "clickable" : "")"
             @onclick="() => NavigateEdit(ivr.EditUrl)">
            <div class="cf-flow-type">IVR Menu</div>
            <div class="cf-flow-name">@ivr.Label</div>
            @if (ivr.Greeting is not null)
            {
                <div class="cf-flow-meta">Greeting: @ivr.Greeting</div>
            }
            <div style="display:flex; gap:0.5rem; align-items:center; margin-top:0.25rem;">
                @RenderDialplanToggle(ivr)
                <a href="@($"/dialplan?context=ivr-{Uri.EscapeDataString(ivr.Label)}")" class="btn btn-sm" style="font-size:0.75rem;" @onclick:stopPropagation="true">Adv. Dialplan</a>
            </div>
        </div>

        @foreach (var option in ivr.Options)
        {
            <div class="cf-branch">
                <div class="cf-branch-label">@option.Digit:</div>
                @if (option.Destination is not null)
                {
                    @RenderFlowNode(option.Destination)
                }
                else
                {
                    <span class="text-muted" style="font-size: 0.85rem;">@(option.OptionLabel ?? "No destination")</span>
                }
            </div>
        }
    };

    private RenderFragment RenderQueueCard(QueueNode queue) => __builder =>
    {
        <div class="cf-flow-card queue @(queue.EditUrl is not null ? "clickable" : "")"
             @onclick="() => NavigateEdit(queue.EditUrl)">
            <div class="cf-flow-type">Queue</div>
            <div class="cf-flow-name">@queue.Label</div>
            <div class="cf-flow-meta">Strategy: @queue.Strategy</div>
            <div class="cf-flow-meta">Agents: @queue.OnlineCount/@queue.MemberCount online</div>
            @RenderDialplanToggle(queue)
        </div>
    };

    private RenderFragment RenderExtensionCard(ExtensionNode ext) => __builder =>
    {
        <div class="cf-flow-card ext @(ext.EditUrl is not null ? "clickable" : "")"
             @onclick="() => NavigateEdit(ext.EditUrl)">
            <div class="cf-flow-type">Extension</div>
            <div class="cf-flow-name">@ext.Number @(ext.DisplayName is not null ? $"— {ext.DisplayName}" : "")</div>
            <div class="cf-flow-meta">
                @ext.Technology
                <span style="color: @(ext.IsRegistered ? "#4ade80" : "#f87171")">
                    @(ext.IsRegistered ? "Registered" : "Unregistered")
                </span>
            </div>
            @RenderDialplanToggle(ext)
        </div>
    };

    private RenderFragment RenderVoicemailCard(VoicemailNode vm) => __builder =>
    {
        <div class="cf-flow-card vm">
            <div class="cf-flow-type">Voicemail</div>
            <div class="cf-flow-name">@vm.Extension</div>
            @if (vm.Email is not null)
            {
                <div class="cf-flow-meta">@vm.Email</div>
            }
            @RenderDialplanToggle(vm)
        </div>
    };

    private RenderFragment RenderHangupCard() => __builder =>
    {
        <div class="cf-flow-card hangup">
            <div class="cf-flow-type">Hangup</div>
        </div>
    };

    private RenderFragment RenderDialplanToggle(CallFlowNode node) => __builder =>
    {
        if (node.DialplanLines.Count > 0)
        {
            var nodeKey = $"{node.EntityType}:{node.EntityId}";
            var isExpanded = _expandedDialplan.Contains(nodeKey);

            <span class="cf-dialplan-toggle" @onclick="() => ToggleDialplan(nodeKey)" @onclick:stopPropagation="true">
                @(isExpanded ? "Hide dialplan" : "Show dialplan")
            </span>

            if (isExpanded)
            {
                <pre class="cf-dialplan-pre">@string.Join("\n", node.DialplanLines)</pre>
            }
        }
    };

    private void ToggleDialplan(string nodeKey)
    {
        if (!_expandedDialplan.Remove(nodeKey))
            _expandedDialplan.Add(nodeKey);
    }

    private void NavigateEdit(string? url)
    {
        if (url is not null)
            Nav.NavigateTo(url);
    }
}
