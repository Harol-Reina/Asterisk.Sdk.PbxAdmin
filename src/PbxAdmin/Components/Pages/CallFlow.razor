@page "/call-flow"
@using PbxAdmin.Services
@using PbxAdmin.Services.CallFlow
@using PbxAdmin.Models
@inject CallFlowService FlowSvc
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L
@inject NavigationManager Nav

<PageTitle>@L["CF_Title"]</PageTitle>

<h2>@L["CF_Heading"]</h2>

@if (_loading)
{
    <p class="text-muted">Loading...</p>
}
else
{
    @* ── Zone 1: Call Tracer ── *@
    <div class="cf-tracer">
        <div class="cf-tracer-inputs">
            <div class="cf-tracer-field">
                <label>@L["CF_TraceNumber"]</label>
                <input type="text" class="form-control" placeholder="5551234"
                       @bind="_traceNumber" @bind:event="oninput" />
            </div>
            <div class="cf-tracer-field">
                <label>@L["CF_TraceTime"]</label>
                <input type="datetime-local" class="form-control" @bind="_traceTime" />
            </div>
            <div class="cf-tracer-field">
                <label>@L["CF_TraceOverride"]</label>
                <select class="form-control" @bind="_traceOverrideMode">
                    <option value="Live">@L["CF_OverrideLive"]</option>
                    <option value="None">@L["CF_OverrideNone"]</option>
                    <option value="AllOpen">@L["CF_OverrideAllOpen"]</option>
                    <option value="AllClosed">@L["CF_OverrideAllClosed"]</option>
                </select>
            </div>
            <button class="btn btn-primary" @onclick="ExecuteTrace"
                    disabled="@string.IsNullOrWhiteSpace(_traceNumber)">
                @L["CF_TraceBtn"]
            </button>
            @if (_traceResult is not null)
            {
                <button class="btn btn-outline" @onclick="ClearTrace">
                    @L["CF_TraceClear"]
                </button>
            }
        </div>
    </div>

    @* ── Trace Results ── *@
    @if (_traceResult is not null)
    {
        <div class="cf-trace-result">
            <h3>
                @L["CF_TraceResult"]: @_traceResult.InputNumber
                @if (string.Equals(_traceResult.Direction, "Inbound", StringComparison.OrdinalIgnoreCase))
                {
                    <span class="badge badge-green" style="margin-left: 0.5rem;">@L["CF_TraceInbound"]</span>
                }
                else
                {
                    <span class="badge badge-blue" style="margin-left: 0.5rem;">@L["CF_TraceOutbound"]</span>
                }
            </h3>

            @if (!_traceResult.RouteFound)
            {
                <p class="cf-trace-no-route">@L["CF_TraceNoRoute"]</p>
            }
            else
            {
                @foreach (var step in _traceResult.Steps)
                {
                    var stepClass = step.Result switch
                    {
                        "Matched" => "step-matched",
                        "NotMatched" => "step-not-matched",
                        _ => ""
                    };
                    <div class="cf-trace-step @stepClass">
                        <div class="cf-trace-step-header">
                            <span class="cf-trace-step-num">@L["CF_TraceStep"] @step.StepNumber</span>
                            <span>@step.Description</span>
                            @{
                                var badgeClass = step.Result switch
                                {
                                    "Matched" => "badge-green",
                                    "NotMatched" => "badge-red",
                                    _ => "badge-muted"
                                };
                                var badgeLabel = step.Result switch
                                {
                                    "Matched" => L["CF_TraceMatched"].Value,
                                    "NotMatched" => L["CF_TraceNotMatched"].Value,
                                    "Skipped" => L["CF_TraceSkipped"].Value,
                                    _ => step.Result
                                };
                            }
                            <span class="badge @badgeClass">@badgeLabel</span>
                        </div>
                        @if (step.Evaluation is not null)
                        {
                            <div class="cf-trace-step-eval">@step.Evaluation</div>
                        }
                        @if (step.DialplanLines.Count > 0)
                        {
                            <div class="cf-trace-inspect">
                                <details>
                                    <summary style="cursor: pointer; font-size: 0.85rem; color: var(--accent);">
                                        @L["CF_TraceInspect"]
                                    </summary>
                                    <pre>@string.Join("\n", step.DialplanLines)</pre>
                                </details>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }

    @* ── Zone 2: Overview Dashboard ── *@
    <div class="cf-kpi-row">
        <div class="cf-kpi-card">
            <div class="cf-kpi-value accent">@ActiveDidCount</div>
            <div class="cf-kpi-label">@L["CF_ActiveDids"]</div>
        </div>
        <div class="cf-kpi-card">
            <div class="cf-kpi-value">@TcSummary</div>
            <div class="cf-kpi-label">@L["CF_TimeConditions"]</div>
        </div>
        <div class="cf-kpi-card">
            <div class="cf-kpi-value">@QueueHealthSummary</div>
            <div class="cf-kpi-label">@L["CF_QueueHealth"]</div>
        </div>
        <div class="cf-kpi-card">
            <div class="cf-kpi-value">@TrunkStatusSummary</div>
            <div class="cf-kpi-label">@L["CF_TrunkStatus"]</div>
        </div>
    </div>

    @* Health Warnings *@
    @if (_graph is not null && _graph.Warnings.Count > 0)
    {
        <div class="cf-warnings">
            @foreach (var w in _graph.Warnings)
            {
                <div class="cf-warning-card @GetWarningSeverityClass(w.Severity)"
                     @onclick="() => NavigateToWarning(w)"
                     style="cursor: @(w.NavigateUrl is not null ? "pointer" : "default")">
                    <span class="cf-warning-icon">@GetWarningIcon(w.Severity)</span>
                    <span>@w.Message</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="cf-healthy">
            <span>@L["CF_AllHealthy"]</span>
        </div>
    }

    @* ── Zone 3: Two-Panel Inbound Flow (hidden when trace is active) ── *@
    @if (_traceResult is null)
    {
    <div class="cf-layout">
        @* Left panel: DID list *@
        <div class="cf-did-list">
            <div class="cf-search-box">
                <input type="text" class="form-control" placeholder="@L["CF_SearchDids"]"
                       @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
            </div>

            @if (_filteredDids.Count == 0)
            {
                <p class="text-muted" style="padding: 1rem;">@L["CF_NoDids"]</p>
            }
            else
            {
                @foreach (var did in _filteredDids)
                {
                    var isSelected = _selectedDid is not null
                        && string.Equals(_selectedDid.EntityId, did.EntityId, StringComparison.Ordinal);
                    <div class="cf-did-card @(isSelected ? "selected" : "")"
                         @onclick="() => SelectDid(did)">
                        <div class="cf-did-pattern">@did.DidPattern</div>
                        <div class="cf-did-route">@did.RouteName</div>
                        <span class="badge @GetDestBadgeClass(did.Destination)">
                            @GetDestTypeName(did.Destination)
                        </span>
                    </div>
                }
            }
        </div>

        @* Right panel: Flow detail *@
        <div class="cf-detail">
            @if (_selectedDid is null)
            {
                <p class="text-muted">@L["CF_SelectDid"]</p>
            }
            else
            {
                <h3>@L["CF_FlowFor"] @_selectedDid.DidPattern — @_selectedDid.RouteName</h3>

                @if (_selectedDid.Destination is null)
                {
                    <p class="text-muted">@L["CF_NoDestination"]</p>
                }
                else
                {
                    @RenderFlowNode(_selectedDid.Destination)
                }
            }
        </div>
    </div>
    }
}

