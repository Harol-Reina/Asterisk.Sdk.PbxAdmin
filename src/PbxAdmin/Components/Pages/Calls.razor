@page "/calls"
@using PbxAdmin.Services
@using Asterisk.Sdk.Ami.Actions
@using Asterisk.Sdk.Sessions
@inject ICallSessionManager Sessions
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>@L["Calls_Title"]</PageTitle>

<div class="calls-header">
    <h2>@L["Calls_Heading"]</h2>
    <div class="view-toggle">
        <button class="chip @(_viewMode == ViewMode.Kanban ? "chip-active" : "")" @onclick="() => _viewMode = ViewMode.Kanban" title="Kanban view — low concurrency">
            <span class="view-toggle-icon">&#9638;&#9638;&#9638;</span> @L["Calls_Kanban"]
        </button>
        <button class="chip @(_viewMode == ViewMode.Table ? "chip-active" : "")" @onclick="() => _viewMode = ViewMode.Table" title="Table view — high concurrency">
            <span class="view-toggle-icon">&#9776;</span> @L["Calls_Table"]
        </button>
        <button class="chip @(_viewMode == ViewMode.Matrix ? "chip-active" : "")" @onclick="() => _viewMode = ViewMode.Matrix" title="Matrix wallboard — supervisor overview">
            <span class="view-toggle-icon">&#9641;&#9641;</span> @L["Calls_Matrix"]
        </button>
    </div>
</div>

<HelpPanel SectionKey="Calls_Overview">@L["Calls_Heading"]</HelpPanel>

<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@CountConnected()</div>
        <div class="kpi-label">@L["Calls_Connected"]</div>
    </div>
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@CountByState(CallSessionState.Ringing)</div>
        <div class="kpi-label">@L["Calls_Ringing"]</div>
    </div>
    <div class="kpi-card kpi-yellow">
        <div class="kpi-value">@CountByState(CallSessionState.Queued)</div>
        <div class="kpi-label">@L["Calls_Queued"]</div>
    </div>
    <div class="kpi-card kpi-orange">
        <div class="kpi-value">@CountByState(CallSessionState.OnHold)</div>
        <div class="kpi-label">@L["Calls_OnHold"]</div>
    </div>
    <div class="kpi-card kpi-gray">
        <div class="kpi-value">@_recentCompleted</div>
        <div class="kpi-label">@L["Calls_Completed"]</div>
    </div>
</div>

<div class="inline-form" style="margin:0.75rem 0">
    <input @bind="_searchQuery" @bind:event="oninput" placeholder="@L["Calls_SearchPh"]" class="input" style="max-width:320px" />
    @if (!string.IsNullOrEmpty(_searchQuery))
    {
        <button class="btn btn-sm btn-muted" @onclick='() => _searchQuery = ""'>@L["Calls_Clear"]</button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(_searchQuery))
{
    @* Search mode — flat grid regardless of view *@
    @if (!_searchResults.Any())
    {
        <p class="text-muted">@L["Calls_NoMatch"]</p>
    }
    else
    {
        <div class="card-grid">
            @foreach (var session in _searchResults)
            {
                RenderCallCard(session);
            }
        </div>
    }
}
else if (_viewMode == ViewMode.Kanban)
{
    @* ═══ KANBAN VIEW ═══ *@
    <div class="kanban-board">
        <div class="kanban-lane">
            <div class="kanban-lane-header kanban-header-green">
                <span class="kanban-lane-icon">&#9679;</span>
                @L["Calls_Connected"]
                <span class="kanban-lane-count">@_connected.Count</span>
            </div>
            <div class="kanban-lane-body">
                @if (_connected.Count == 0)
                {
                    <div class="kanban-empty">@L["Calls_NoActiveCalls"]</div>
                }
                @foreach (var session in _connected)
                {
                    RenderCallCard(session);
                }
            </div>
        </div>

        <div class="kanban-lane">
            <div class="kanban-lane-header kanban-header-blue">
                <span class="kanban-lane-icon">&#9711;</span>
                @L["Calls_RingingQueued"]
                <span class="kanban-lane-count">@_pending.Count</span>
            </div>
            <div class="kanban-lane-body">
                @if (_pending.Count == 0)
                {
                    <div class="kanban-empty">@L["Calls_NoPendingCalls"]</div>
                }
                @foreach (var session in _pending)
                {
                    RenderCallCard(session);
                }
            </div>
        </div>

        <div class="kanban-lane">
            <div class="kanban-lane-header kanban-header-gray">
                <span class="kanban-lane-icon">&#9632;</span>
                @L["Calls_Completed"]
                <span class="kanban-lane-count">@_fadingCompleted.Count</span>
            </div>
            <div class="kanban-lane-body">
                @if (_fadingCompleted.Count == 0)
                {
                    <div class="kanban-empty">@L["Calls_CompletedFade"]</div>
                }
                @foreach (var (session, remaining) in _fadingCompleted)
                {
                    RenderCompletedCard(session, remaining);
                }
            </div>
        </div>
    </div>
}
else if (_viewMode == ViewMode.Table)
{
    @* ═══ TABLE VIEW ═══ *@
    @if (_allActive.Count == 0 && _fadingCompleted.Count == 0)
    {
        <p class="text-muted">@L["Calls_NoCallsDisplay"]</p>
    }
    else
    {
        @if (_allActive.Count > 0)
        {
            <div class="calls-table-wrap">
                <table class="calls-table">
                    <thead>
                        <tr>
                            <th class="col-state">@L["Col_State"]</th>
                            <th class="col-caller">@L["Col_Caller"]</th>
                            <th class="col-arrow"></th>
                            <th class="col-dest">@L["Col_Destination"]</th>
                            <th class="col-queue">@L["Col_Queue"]</th>
                            <th class="col-tech">@L["Col_Tech"]</th>
                            <th class="col-duration">@L["Col_Duration"]</th>
                            <th class="col-events">Ev</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in _allActive)
                        {
                            var caller = session.GetCaller();
                            var dest = session.GetDestination();
                            var (borderClass, stateLabel, stateIcon) = GetCallStyle(session);
                            <tr class="calls-table-row @borderClass" @onclick="() => NavigateToDetail(session.SessionId)">
                                <td><span class="call-state-badge @borderClass">@stateIcon @stateLabel</span></td>
                                <td class="cell-caller">
                                    <span class="cell-id">@(caller?.CallerIdNum ?? "unknown")</span>
                                    <span class="cell-channel text-muted">@ShortChannel(caller?.Channel)</span>
                                </td>
                                <td class="cell-arrow">
                                    @if (IsConnected(session.State))
                                    {
                                        <span class="arrow-connected">&harr;</span>
                                    }
                                    else if (session.State == CallSessionState.OnHold)
                                    {
                                        <span class="arrow-hold">||</span>
                                    }
                                    else
                                    {
                                        <span class="arrow-dialing">&rarr;</span>
                                    }
                                </td>
                                <td class="cell-dest">
                                    @if (session.AgentId is not null)
                                    {
                                        <span class="cell-id">@session.AgentId</span>
                                        <span class="cell-channel text-muted">@ShortChannel(session.AgentInterface)</span>
                                    }
                                    else if (dest is not null)
                                    {
                                        <span class="cell-id">@(dest.CallerIdNum ?? ShortChannel(dest.Channel))</span>
                                        <span class="cell-channel text-muted">@ShortChannel(dest.Channel)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">...</span>
                                    }
                                </td>
                                <td>
                                    @if (session.QueueName is not null)
                                    {
                                        <span class="badge badge-muted">@session.QueueName</span>
                                    }
                                </td>
                                <td>
                                    @if (caller?.Technology is not null)
                                    {
                                        <span class="badge @TechBadgeClass(caller.Technology)">@caller.Technology</span>
                                    }
                                </td>
                                <td class="cell-duration">@FormatDuration(session.Duration)</td>
                                <td class="cell-events text-muted">@session.Events.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (_fadingCompleted.Count > 0)
        {
            <div class="completed-section">
                <div class="completed-section-header">
                    <span>@L["Calls_RecentlyCompleted"]</span>
                    <span class="text-muted">@_fadingCompleted.Count</span>
                </div>
                <div class="card-grid">
                    @foreach (var (session, remaining) in _fadingCompleted)
                    {
                        RenderCompletedCard(session, remaining);
                    }
                </div>
            </div>
        }
    }
}

@* ═══ MATRIX VIEW ═══ *@
else
{
    @if (_allActive.Count == 0)
    {
        <p class="text-muted">@L["Calls_NoActiveDisplay"]</p>
    }
    else
    {
        <div class="call-matrix">
            @foreach (var session in _allActive)
            {
                var caller = session.GetCaller();
                var dest = session.GetDestination();
                var (borderClass, stateLabel, stateIcon) = GetCallStyle(session);
                var stateClass = session.State switch
                {
                    CallSessionState.Connected or CallSessionState.Conference => "state-connected",
                    CallSessionState.Ringing or CallSessionState.Dialing or CallSessionState.Created => "state-ringing",
                    CallSessionState.OnHold => "state-hold",
                    CallSessionState.Queued => "state-queued",
                    CallSessionState.Transferring => "state-ringing",
                    CallSessionState.Completed or CallSessionState.Failed or CallSessionState.TimedOut => "state-completed",
                    _ => ""
                };
                <div class="matrix-card @stateClass">
                    <div class="matrix-card-header">
                        <span class="call-state-badge @borderClass">@stateIcon @stateLabel</span>
                        <span class="call-duration">@FormatDuration(session.Duration)</span>
                    </div>
                    <div class="matrix-card-body" @onclick="() => NavigateToDetail(session.SessionId)">
                        <div class="matrix-flow">
                            <span class="matrix-caller">@(caller?.CallerIdNum ?? "unknown")</span>
                            <span class="matrix-arrow">&rarr;</span>
                            <span class="matrix-dest">
                                @if (session.AgentId is not null)
                                {
                                    @session.AgentId
                                }
                                else if (dest is not null)
                                {
                                    @(dest.CallerIdNum ?? ShortChannel(dest.Channel))
                                }
                                else
                                {
                                    <span class="text-muted">...</span>
                                }
                            </span>
                        </div>
                        @if (session.QueueName is not null)
                        {
                            <span class="matrix-queue-label">@session.QueueName</span>
                        }
                    </div>
                    <div class="matrix-card-actions">
                        <button class="matrix-action-btn" title="Hold / Park" @onclick="() => HoldCall(session)" @onclick:stopPropagation="true">
                            &#9646;&#9646; @L["Calls_Hold"]
                        </button>
                        <button class="matrix-action-btn" title="Transfer" @onclick="() => ShowTransferDialog(session)" @onclick:stopPropagation="true">
                            &#8644; @L["Calls_Xfer"]
                        </button>
                        <button class="matrix-action-btn matrix-action-hangup" title="Hangup" @onclick="() => HangupCall(session)" @onclick:stopPropagation="true">
                            &#9747; @L["Calls_Drop"]
                        </button>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_showTransferDialog)
{
    <div class="confirm-overlay" @onclick="CloseTransferDialog">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <h4>@L["Calls_TransferCall"]</h4>
            <p>@L["Calls_TransferTo"] <strong>@(_transferSession?.GetCaller()?.CallerIdNum ?? "unknown")</strong></p>
            <div class="form-field" style="margin-bottom:1rem">
                <label class="form-label">@L["Calls_Extension"]</label>
                <input @bind="_transferExtension" class="input" placeholder="e.g. 2001" />
            </div>
            <div class="form-field" style="margin-bottom:1rem">
                <label class="form-label">@L["Calls_ContextOptional"]</label>
                <input @bind="_transferContext" class="input" placeholder="default" />
            </div>
            <div class="confirm-dialog-actions">
                <button class="btn btn-sm btn-muted" @onclick="CloseTransferDialog">@L["Btn_Cancel"]</button>
                <button class="btn btn-sm btn-accent" @onclick="ExecuteTransfer">@L["Calls_Transfer"]</button>
            </div>
        </div>
    </div>
}

@* ═══ Shared card render fragments ═══ *@

@{ void RenderCallCard(CallSession session)
    {
        var caller = session.GetCaller();
        var dest = session.GetDestination();
        var (borderClass, stateLabel, stateIcon) = GetCallStyle(session);
        <div class="call-card @borderClass" @onclick="() => NavigateToDetail(session.SessionId)">
            <div class="call-card-header">
                <span class="call-state-badge @borderClass">@stateIcon @stateLabel</span>
                <span class="call-duration">@FormatDuration(session.Duration)</span>
            </div>
            <div class="call-participants">
                <div class="call-endpoint">
                    <div class="call-endpoint-label">@L["Calls_Caller"]</div>
                    <div class="call-endpoint-id">@(caller?.CallerIdNum ?? "unknown")</div>
                    <div class="call-endpoint-channel text-muted">@ShortChannel(caller?.Channel)</div>
                </div>
                <div class="call-arrow">
                    @if (IsConnected(session.State))
                    {
                        <span class="arrow-connected">&harr;</span>
                    }
                    else if (session.State == CallSessionState.OnHold)
                    {
                        <span class="arrow-hold">| |</span>
                    }
                    else
                    {
                        <span class="arrow-dialing">&rarr;</span>
                    }
                </div>
                <div class="call-endpoint">
                    @if (session.AgentId is not null)
                    {
                        <div class="call-endpoint-label">@L["Calls_Agent"]</div>
                        <div class="call-endpoint-id">@session.AgentId</div>
                        <div class="call-endpoint-channel text-muted">@ShortChannel(session.AgentInterface)</div>
                    }
                    else if (session.QueueName is not null)
                    {
                        <div class="call-endpoint-label">@L["Col_Queue"]</div>
                        <div class="call-endpoint-id">@session.QueueName</div>
                    }
                    else if (dest is not null)
                    {
                        <div class="call-endpoint-label">@L["Calls_Destination"]</div>
                        <div class="call-endpoint-id">@(dest.CallerIdNum ?? ShortChannel(dest.Channel))</div>
                        <div class="call-endpoint-channel text-muted">@ShortChannel(dest.Channel)</div>
                    }
                    else
                    {
                        <div class="call-endpoint-label">@L["Calls_Destination"]</div>
                        <div class="call-endpoint-id text-muted">...</div>
                    }
                </div>
            </div>
            <div class="call-card-footer">
                @if (caller?.Technology is not null)
                {
                    <span class="badge @TechBadgeClass(caller.Technology)">@caller.Technology</span>
                }
                @if (session.QueueName is not null && session.AgentId is not null)
                {
                    <span class="badge badge-muted">@session.QueueName</span>
                }
                @if (session.HangupCause.HasValue)
                {
                    <span class="badge badge-muted">@session.HangupCause</span>
                }
                <span class="text-muted call-events-count">@session.Events.Count events</span>
            </div>
        </div>;
    }
}

@{ void RenderCompletedCard(CallSession session, double remainingSecs)
    {
        var caller = session.GetCaller();
        var dest = session.GetDestination();
        var pct = Math.Clamp(remainingSecs / FadeSeconds * 100, 0, 100);
        var isFading = remainingSecs <= 1.5;
        <div class="call-card call-completed @(isFading ? "call-fade-out" : "")" @onclick="() => NavigateToDetail(session.SessionId)">
            <div class="call-card-header">
                <span class="call-state-badge call-completed">-- Completed</span>
                <span class="call-duration">@FormatDuration(session.Duration)</span>
            </div>
            <div class="call-participants">
                <div class="call-endpoint">
                    <div class="call-endpoint-label">@L["Calls_Caller"]</div>
                    <div class="call-endpoint-id">@(caller?.CallerIdNum ?? "unknown")</div>
                    <div class="call-endpoint-channel text-muted">@ShortChannel(caller?.Channel)</div>
                </div>
                <div class="call-arrow">
                    <span class="arrow-completed">&#10005;</span>
                </div>
                <div class="call-endpoint">
                    @if (session.AgentId is not null)
                    {
                        <div class="call-endpoint-label">@L["Calls_Agent"]</div>
                        <div class="call-endpoint-id">@session.AgentId</div>
                    }
                    else if (dest is not null)
                    {
                        <div class="call-endpoint-label">@L["Calls_Destination"]</div>
                        <div class="call-endpoint-id">@(dest.CallerIdNum ?? ShortChannel(dest.Channel))</div>
                    }
                    else
                    {
                        <div class="call-endpoint-label">@L["Calls_Destination"]</div>
                        <div class="call-endpoint-id text-muted">...</div>
                    }
                </div>
            </div>
            <div class="call-card-footer">
                @if (session.HangupCause.HasValue)
                {
                    <span class="badge badge-muted">@session.HangupCause</span>
                }
                <span class="text-muted call-events-count">@session.Events.Count events</span>
            </div>
            <div class="call-fade-bar">
                <div class="call-fade-bar-fill" style="width:@($"{pct:F0}")%"></div>
            </div>
        </div>;
    }
}

@code {
    private const double FadeSeconds = 5.0;

    private enum ViewMode { Kanban, Table, Matrix }

    private Timer? _timer;
    private ViewMode _viewMode = ViewMode.Kanban;
    private string _searchQuery = "";
    private int _recentCompleted;

    // Kanban buckets
    private IReadOnlyList<CallSession> _connected = [];
    private IReadOnlyList<CallSession> _pending = [];

    // Table bucket
    private IReadOnlyList<CallSession> _allActive = [];

    // Shared
    private IReadOnlyList<(CallSession Session, double Remaining)> _fadingCompleted = [];
    private IReadOnlyList<CallSession> _searchResults = [];

    protected override void OnInitialized()
    {
        RefreshCalls();
        _timer = new Timer(_ => { RefreshCalls(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private IEnumerable<CallSession> FilterByServer(IEnumerable<CallSession> sessions) =>
        sessions.Where(s => s.ServerId == ServerSvc.SelectedServerId);

    private void RefreshCalls()
    {
        var now = DateTimeOffset.UtcNow;

        _recentCompleted = FilterByServer(Sessions.GetRecentCompleted(100)).Count();

        // Recently completed with fade timer (last N seconds)
        _fadingCompleted = FilterByServer(Sessions.GetRecentCompleted(20))
            .Where(s => s.CompletedAt.HasValue && (now - s.CompletedAt.Value).TotalSeconds < FadeSeconds)
            .Select(s => (Session: s, Remaining: FadeSeconds - (now - s.CompletedAt!.Value).TotalSeconds))
            .OrderByDescending(x => x.Remaining)
            .ToList();

        // Search mode
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResults = FilterByServer(Sessions.Search(_searchQuery, 100)).ToList();
            return;
        }

        _searchResults = [];

        var active = FilterByServer(Sessions.ActiveSessions)
            .OrderByDescending(s => s.CreatedAt)
            .ToList();

        // Kanban buckets
        _connected = active.Where(s => IsConnected(s.State)).ToList();
        _pending = active.Where(s => IsPending(s.State)).ToList();

        // Table bucket (all active)
        _allActive = active;
    }

    // State bucketing helpers
    static bool IsConnected(CallSessionState s) =>
        s is CallSessionState.Connected or CallSessionState.OnHold or CallSessionState.Conference;

    static bool IsPending(CallSessionState s) =>
        s is CallSessionState.Created or CallSessionState.Dialing or CallSessionState.Ringing
        or CallSessionState.Queued or CallSessionState.Transferring;

    static bool IsTerminal(CallSessionState s) =>
        s is CallSessionState.Completed or CallSessionState.Failed or CallSessionState.TimedOut;

    private int CountByState(CallSessionState state) =>
        FilterByServer(Sessions.ActiveSessions).Count(s => s.State == state);

    private int CountConnected() =>
        FilterByServer(Sessions.ActiveSessions).Count(s => IsConnected(s.State));

    private void NavigateToDetail(string sessionId) =>
        Nav.NavigateTo($"/calls/{Uri.EscapeDataString(sessionId)}");

    private static (string borderClass, string stateLabel, string stateIcon) GetCallStyle(CallSession session) =>
        session.State switch
        {
            CallSessionState.Created => ("call-dialing", "Created", "~"),
            CallSessionState.Dialing => ("call-dialing", "Dialing", "~"),
            CallSessionState.Ringing => ("call-ringing", "Ringing", ">>"),
            CallSessionState.Queued => ("call-queued", "Queued", "#"),
            CallSessionState.Connected => ("call-connected", "Connected", "<<>>"),
            CallSessionState.OnHold => ("call-hold", "On Hold", "||"),
            CallSessionState.Transferring => ("call-ringing", "Transferring", "=>"),
            CallSessionState.Conference => ("call-connected", "Conference", "<*>"),
            CallSessionState.Completed => ("call-completed", "Completed", "--"),
            CallSessionState.Failed => ("call-completed", "Failed", "!!"),
            CallSessionState.TimedOut => ("call-completed", "Timed Out", ".."),
            _ => ("call-unknown", "Unknown", "?")
        };

    private static string TechBadgeClass(string tech) => tech switch
    {
        "PJSIP" => "badge-blue",
        "SIP" => "badge-yellow",
        _ => "badge-muted"
    };

    private static string ShortChannel(string? channel)
    {
        if (channel is null) return "";
        var dash = channel.LastIndexOf('-');
        return dash > 0 ? channel[..dash] : channel;
    }

    private static string FormatDuration(TimeSpan ts)
    {
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours}:{ts.Minutes:D2}:{ts.Seconds:D2}";
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";
    }

    // Matrix quick actions
    private bool _showTransferDialog;
    private CallSession? _transferSession;
    private string _transferExtension = "";
    private string _transferContext = "";
    private string? _actionResult;

    private async Task HoldCall(CallSession session)
    {
        var entry = ServerSvc.GetSelectedServer();
        var callerChannel = session.GetCaller()?.Channel;
        if (entry is null || callerChannel is null) return;

        var action = new ParkAction
        {
            Channel = callerChannel,
            Channel2 = callerChannel,
            Timeout = 120
        };
        var response = await entry.Connection.SendActionAsync(action);
        _actionResult = string.Equals(response.Response, "Success", StringComparison.OrdinalIgnoreCase)
            ? "Call parked"
            : $"Park failed: {response.Message}";
    }

    private async Task HangupCall(CallSession session)
    {
        var entry = ServerSvc.GetSelectedServer();
        var callerChannel = session.GetCaller()?.Channel;
        if (entry is null || callerChannel is null) return;

        var action = new HangupAction { Channel = callerChannel };
        await entry.Connection.SendActionAsync(action);
    }

    private void ShowTransferDialog(CallSession session)
    {
        _transferSession = session;
        _transferExtension = "";
        _transferContext = "";
        _showTransferDialog = true;
    }

    private void CloseTransferDialog()
    {
        _showTransferDialog = false;
        _transferSession = null;
    }

    private async Task ExecuteTransfer()
    {
        var entry = ServerSvc.GetSelectedServer();
        var callerChannel = _transferSession?.GetCaller()?.Channel;
        if (entry is null || callerChannel is null || string.IsNullOrWhiteSpace(_transferExtension))
        {
            CloseTransferDialog();
            return;
        }

        var action = new RedirectAction
        {
            Channel = callerChannel,
            Exten = _transferExtension.Trim(),
            Context = string.IsNullOrWhiteSpace(_transferContext) ? "default" : _transferContext.Trim(),
            Priority = 1
        };
        await entry.Connection.SendActionAsync(action);
        CloseTransferDialog();
    }

    public void Dispose() => _timer?.Dispose();
}
