@page "/dialplan"
@using PbxAdmin.Services
@using PbxAdmin.Services.CallFlow
@using PbxAdmin.Services.Dialplan
@using PbxAdmin.Models
@inject DialplanDiscoveryService DiscoverySvc
@inject DialplanEditorService EditorSvc
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast
@inject NavigationManager Nav

<PageTitle>@L["DP_Title"]</PageTitle>

<h2>@L["DP_Heading"]</h2>

@if (_loading)
{
    <p class="text-muted">Loading...</p>
}
else
{
    @* KPI Row *@
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-value">@(_snapshot?.Contexts.Count ?? 0)</div>
            <div class="kpi-label">@L["DP_TotalContexts"]</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-value">@(_snapshot?.Contexts.Count(c => !c.IsSystem) ?? 0)</div>
            <div class="kpi-label">@L["DP_UserContexts"]</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-value">@(_snapshot?.Contexts.Sum(c => c.Extensions.Count) ?? 0)</div>
            <div class="kpi-label">@L["DP_TotalExtensions"]</div>
        </div>
    </div>

    @* Action Bar *@
    <div class="dp-action-bar">
        <input type="text" class="form-control dp-search" placeholder="@L["DP_SearchContexts"]"
               @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
        <button class="btn btn-blue" @onclick="ShowNewContextModal">@L["DP_NewContext"]</button>
        <button class="btn" @onclick="RefreshData">@L["DP_Refresh"]</button>
        @if (_snapshot is not null)
        {
            <span class="text-muted dp-refresh-time">@L["DP_LastRefresh"]: @_snapshot.RefreshedAt.ToLocalTime().ToString("HH:mm:ss")</span>
        }
    </div>

    @* Two-panel layout *@
    <div class="dp-layout">
        @* Left panel: Context list *@
        <div class="dp-list">
            @if (_filteredContexts.Count == 0)
            {
                <p class="text-muted" style="padding: 1rem;">@L["DP_NoContexts"]</p>
            }
            else
            {
                @foreach (var ctx in _filteredContexts)
                {
                    var isSelected = _selectedContext is not null
                        && string.Equals(_selectedContext.Name, ctx.Name, StringComparison.Ordinal);
                    <div class="dp-card @(isSelected ? "selected" : "") @(ctx.IsSystem ? "system" : "")"
                         @onclick="() => SelectContext(ctx)">
                        <div class="dp-card-header">
                            <strong>@ctx.Name</strong>
                            <span style="display:flex; gap:0.35rem;">
                                <span class="badge @(ctx.IsSystem ? "badge-muted" : "badge-green")">
                                    @(ctx.IsSystem ? L["DP_System"] : L["DP_User"])
                                </span>
                                @{ var ctxType = GetContextType(ctx.Name); }
                                @if (!string.IsNullOrEmpty(ctxType.Label))
                                {
                                    <span class="badge @ctxType.CssClass">@ctxType.Label</span>
                                }
                            </span>
                        </div>
                        <div class="dp-card-meta">
                            <span>@ctx.Extensions.Count @L["DP_Extensions"]</span>
                            @if (ctx.Includes.Count > 0)
                            {
                                <span> · @ctx.Includes.Count @L["DP_Includes"]</span>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        @* Right panel: Context detail *@
        <div class="dp-detail">
            @if (_selectedContext is null)
            {
                <p class="text-muted">@L["DP_SelectContext"]</p>
            }
            else
            {
                <div style="display: flex; align-items: center;">
                    <h3 style="margin: 0;">@_selectedContext.Name</h3>
                    @if (IsManagedContext(_selectedContext.Name))
                    {
                        <a href="/call-flow" class="btn btn-sm" style="margin-left: 0.5rem;">View in Call Flow</a>
                    }
                </div>
                <div class="dp-detail-badges">
                    <span class="badge badge-muted">@L["DP_CreatedBy"]: @_selectedContext.CreatedBy</span>
                    <span class="badge @(_selectedContext.IsSystem ? "badge-muted" : "badge-green")">
                        @(_selectedContext.IsSystem ? L["DP_System"] : L["DP_User"])
                    </span>
                </div>

                @* Includes section *@
                <h4>@L["DP_IncludesSection"]</h4>
                @if (_selectedContext.Includes.Count == 0)
                {
                    <p class="text-muted" style="font-size: 0.85rem;">None</p>
                }
                else
                {
                    <ul class="dp-include-list">
                        @foreach (var inc in _selectedContext.Includes)
                        {
                            <li>
                                <span>@inc</span>
                                @if (!_selectedContext.IsSystem)
                                {
                                    <button class="btn btn-sm btn-red" @onclick="() => RemoveInclude(inc)">@L["DP_RemoveInclude"]</button>
                                }
                            </li>
                        }
                    </ul>
                }

                @if (!_selectedContext.IsSystem)
                {
                    <div class="dp-add-include-row">
                        <select class="form-control dp-include-select" @bind="_newIncludeContext">
                            <option value="">-- @L["DP_AddInclude"] --</option>
                            @if (_snapshot is not null)
                            {
                                @foreach (var ctx in _snapshot.Contexts.Where(c =>
                                    !string.Equals(c.Name, _selectedContext.Name, StringComparison.Ordinal)
                                    && !_selectedContext.Includes.Contains(c.Name)))
                                {
                                    <option value="@ctx.Name">@ctx.Name</option>
                                }
                            }
                        </select>
                        <button class="btn btn-sm btn-blue" disabled="@string.IsNullOrEmpty(_newIncludeContext)" @onclick="AddInclude">@L["DP_AddInclude"]</button>
                    </div>
                }

                <button class="btn btn-sm" style="margin-top: 0.5rem;" @onclick="ToggleIncludeTree">@L["DP_ViewTree"]</button>

                @if (_showIncludeTree)
                {
                    <div class="dp-tree">
                        @RenderIncludeTree(_selectedContext.Name, [], 0)
                    </div>
                }

                @* Included By section *@
                <h4>@L["DP_IncludedBy"]</h4>
                @if (GetIncludedBy(_selectedContext.Name) is { Count: > 0 } includedBy)
                {
                    <ul class="dp-include-list">
                        @foreach (var parent in includedBy)
                        {
                            <li><span>@parent</span></li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted" style="font-size: 0.85rem;">None</p>
                }

                @* Extensions section *@
                <h4>@L["DP_ExtensionsSection"] (@_selectedContext.Extensions.Count)</h4>
                @if (_selectedContext.Extensions.Count > 0)
                {
                    <table class="dp-table">
                        <thead>
                            <tr>
                                <th>@L["DP_Pattern"]</th>
                                <th>@L["DP_Priorities"]</th>
                                <th>@L["DP_Application"]</th>
                                <th>@L["DP_Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ext in _selectedContext.Extensions)
                            {
                                var isExpanded = string.Equals(_expandedExten, ext.Pattern, StringComparison.Ordinal);
                                <tr class="dp-ext-row" @onclick="() => ToggleExten(ext.Pattern)">
                                    <td>@ext.Pattern</td>
                                    <td>@ext.Priorities.Count</td>
                                    <td>@(ext.Priorities.Count > 0 ? ext.Priorities[0].Application : "")</td>
                                    <td @onclick:stopPropagation="true">
                                        @if (!_selectedContext.IsSystem)
                                        {
                                            <button class="btn btn-sm btn-red" @onclick="() => RemoveExtension(ext.Pattern)">@L["DP_RemoveExtension"]</button>
                                        }
                                    </td>
                                </tr>
                                @if (isExpanded)
                                {
                                    <tr class="dp-ext-detail">
                                        <td colspan="5">
                                            <table class="dp-priority-table">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Label</th>
                                                        <th>@L["DP_Application"]</th>
                                                        <th>@L["DP_AppData"]</th>
                                                        <th>Description</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var p in ext.Priorities.OrderBy(p => p.Number))
                                                    {
                                                        <tr>
                                                            <td>@p.Number</td>
                                                            <td>@(p.Label ?? "")</td>
                                                            <td>@p.Application</td>
                                                            <td>@p.ApplicationData</td>
                                                            <td>@DialplanHumanizer.Humanize(p.Application, p.ApplicationData)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }

                @* Add Extension form *@
                @if (!_selectedContext.IsSystem)
                {
                    <button class="btn btn-sm btn-blue" style="margin-top: 0.75rem;" @onclick="() => _showAddExtenForm = !_showAddExtenForm">
                        @L["DP_AddExtension"]
                    </button>

                    @if (_showAddExtenForm)
                    {
                        <div class="dp-add-exten-form">
                            <div class="dp-form-row">
                                <label>@L["DP_Pattern"]</label>
                                <input type="text" class="form-control" @bind="_newExtenPattern" />
                            </div>
                            <div class="dp-form-row">
                                <label>@L["DP_Priority"]</label>
                                <input type="number" class="form-control" @bind="_newExtenPriority" min="1" />
                            </div>
                            <div class="dp-form-row">
                                <label>@L["DP_Application"]</label>
                                <select class="form-control" @bind="_newExtenApp">
                                    @foreach (var app in DialplanApps)
                                    {
                                        <option value="@app">@app</option>
                                    }
                                </select>
                            </div>
                            <div class="dp-form-row">
                                <label>@L["DP_AppData"]</label>
                                <input type="text" class="form-control" @bind="_newExtenAppData" />
                            </div>
                            <button class="btn btn-blue" @onclick="AddExtension"
                                    disabled="@string.IsNullOrWhiteSpace(_newExtenPattern)">
                                @L["DP_AddExtension"]
                            </button>
                        </div>
                    }

                    @* Delete Context *@
                    <div style="margin-top: 1.5rem; border-top: 1px solid var(--border); padding-top: 1rem;">
                        <button class="btn btn-red" @onclick="ConfirmDeleteContext">@L["DP_DeleteContext"]</button>
                    </div>
                }
            }
        </div>
    </div>

    @* New Context Modal *@
    @if (_showNewContextModal)
    {
        <div class="modal-backdrop" @onclick="() => _showNewContextModal = false">
            <div class="modal-card" @onclick:stopPropagation="true">
                <h3>@L["DP_NewContext"]</h3>
                <div class="dp-form-row">
                    <label>@L["DP_ContextName"]</label>
                    <input type="text" class="form-control" @bind="_newContextName" />
                </div>
                <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                    <button class="btn btn-blue" @onclick="CreateContext"
                            disabled="@string.IsNullOrWhiteSpace(_newContextName)">
                        @L["DP_NewContext"]
                    </button>
                    <button class="btn" @onclick="() => _showNewContextModal = false">@L["Btn_Cancel"]</button>
                </div>
            </div>
        </div>
    }

    <ConfirmDialog @ref="_deleteDialog"
        Title="@L["DP_DeleteContext"]"
        Message="@L["DP_DeleteContextConfirm", _selectedContext?.Name ?? ""]"
        ConfirmText="@L["Btn_Delete"]"
        CancelText="@L["Btn_Cancel"]"
        ConfirmStyle="danger"
        OnConfirm="ExecuteDeleteContext" />
}

