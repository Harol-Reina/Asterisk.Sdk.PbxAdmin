@code {
    [SupplyParameterFromQuery]
    public string? Context { get; set; }

    private static readonly string[] DialplanApps =
    [
        "Answer", "AGI", "Background", "Dial", "ExecIf", "Goto", "GotoIfTime",
        "Hangup", "NoOp", "Playback", "Queue", "Read", "Set", "VoiceMail",
        "VoiceMailMain"
    ];

    private DialplanSnapshot? _snapshot;
    private List<DiscoveredContext> _filteredContexts = [];
    private DiscoveredContext? _selectedContext;
    private string _search = "";
    private bool _loading = true;
    private string _newContextName = "";
    private bool _showNewContextModal;
    private string _newExtenPattern = "";
    private int _newExtenPriority = 1;
    private string _newExtenApp = "NoOp";
    private string _newExtenAppData = "";
    private bool _showAddExtenForm;
    private string? _expandedExten;
    private bool _showIncludeTree;
    private string _newIncludeContext = "";
    private ConfirmDialog? _deleteDialog;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        if (Context is not null)
        {
            _selectedContext = _snapshot?.Contexts.FirstOrDefault(c =>
                string.Equals(c.Name, Context, StringComparison.OrdinalIgnoreCase));
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null)
        {
            _loading = false;
            return;
        }

        _snapshot = await DiscoverySvc.GetSnapshotAsync(serverId);
        ApplyFilter();
        _loading = false;
    }

    private async Task RefreshData()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        _loading = true;
        StateHasChanged();

        await DiscoverySvc.RefreshAsync(serverId);
        _snapshot = await DiscoverySvc.GetSnapshotAsync(serverId);
        ReSelectContext();
        ApplyFilter();
        _loading = false;
    }

    private void ApplyFilter()
    {
        if (_snapshot is null)
        {
            _filteredContexts = [];
            return;
        }

        if (string.IsNullOrWhiteSpace(_search))
        {
            _filteredContexts = _snapshot.Contexts.OrderBy(c => c.IsSystem).ThenBy(c => c.Name).ToList();
        }
        else
        {
            _filteredContexts = _snapshot.Contexts
                .Where(c => c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
                .OrderBy(c => c.IsSystem).ThenBy(c => c.Name)
                .ToList();
        }
    }

    private void SelectContext(DiscoveredContext ctx)
    {
        _selectedContext = ctx;
        _showAddExtenForm = false;
        _expandedExten = null;
        _showIncludeTree = false;
        _newIncludeContext = "";
    }

    private void ReSelectContext()
    {
        if (_selectedContext is null || _snapshot is null) return;

        _selectedContext = _snapshot.Contexts
            .FirstOrDefault(c => string.Equals(c.Name, _selectedContext.Name, StringComparison.Ordinal));
    }

    private void ToggleExten(string pattern)
    {
        _expandedExten = string.Equals(_expandedExten, pattern, StringComparison.Ordinal) ? null : pattern;
    }

    private void ToggleIncludeTree()
    {
        _showIncludeTree = !_showIncludeTree;
    }

    private List<string> GetIncludedBy(string contextName)
    {
        if (_snapshot is null) return [];
        return _snapshot.Contexts
            .Where(c => c.Includes.Contains(contextName))
            .Select(c => c.Name)
            .ToList();
    }

    private RenderFragment RenderIncludeTree(string contextName, HashSet<string> visited, int depth) => builder =>
    {
        var indent = new string(' ', depth * 2);
        var prefix = depth == 0 ? "" : "|- ";

        if (!visited.Add(contextName))
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "dp-tree-cycle");
            builder.AddContent(2, $"{indent}{prefix}{contextName} ({L["DP_Cycle"]})");
            builder.CloseElement();
            return;
        }

        builder.OpenElement(0, "div");
        builder.AddContent(1, $"{indent}{prefix}{contextName}");
        builder.CloseElement();

        var ctx = _snapshot?.Contexts.FirstOrDefault(c =>
            string.Equals(c.Name, contextName, StringComparison.Ordinal));

        if (ctx is not null)
        {
            foreach (var inc in ctx.Includes)
            {
                var childVisited = new HashSet<string>(visited, StringComparer.Ordinal);
                builder.AddContent(2, RenderIncludeTree(inc, childVisited, depth + 1));
            }
        }
    };

    // ── Editor actions ──

    private void ShowNewContextModal()
    {
        _newContextName = "";
        _showNewContextModal = true;
    }

    private async Task CreateContext()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || string.IsNullOrWhiteSpace(_newContextName)) return;

        using var _ = ConfigOp.Begin("Creating context", serverId, _newContextName);
        var (success, error) = await EditorSvc.CreateContextAsync(serverId, _newContextName.Trim());
        _showNewContextModal = false;

        if (success)
        {
            Toast.Show(L["Toast_Saved"], ToastLevel.Success, _newContextName);
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private async Task AddExtension()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || _selectedContext is null || string.IsNullOrWhiteSpace(_newExtenPattern)) return;

        using var _ = ConfigOp.Begin("Adding extension", serverId, _newExtenPattern);
        var (success, error) = await EditorSvc.AddExtensionAsync(
            serverId, _selectedContext.Name, _newExtenPattern.Trim(),
            _newExtenPriority, _newExtenApp, _newExtenAppData);

        if (success)
        {
            Toast.Show(L["Toast_Saved"], ToastLevel.Success, _newExtenPattern);
            _newExtenPattern = "";
            _newExtenPriority = 1;
            _newExtenApp = "NoOp";
            _newExtenAppData = "";
            _showAddExtenForm = false;
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private async Task RemoveExtension(string pattern)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || _selectedContext is null) return;

        using var _ = ConfigOp.Begin("Removing extension", serverId, pattern);
        var (success, error) = await EditorSvc.RemoveExtensionAsync(serverId, _selectedContext.Name, pattern);

        if (success)
        {
            Toast.Show(L["Toast_Deleted"], ToastLevel.Success, pattern);
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private async Task AddInclude()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || _selectedContext is null || string.IsNullOrEmpty(_newIncludeContext)) return;

        using var _ = ConfigOp.Begin("Adding include", serverId, _newIncludeContext);
        var (success, error) = await EditorSvc.AddIncludeAsync(serverId, _selectedContext.Name, _newIncludeContext);

        if (success)
        {
            Toast.Show(L["Toast_Saved"], ToastLevel.Success, _newIncludeContext);
            _newIncludeContext = "";
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private async Task RemoveInclude(string includeContext)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || _selectedContext is null) return;

        using var _ = ConfigOp.Begin("Removing include", serverId, includeContext);
        var (success, error) = await EditorSvc.RemoveIncludeAsync(serverId, _selectedContext.Name, includeContext);

        if (success)
        {
            Toast.Show(L["Toast_Deleted"], ToastLevel.Success, includeContext);
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private void ConfirmDeleteContext()
    {
        _deleteDialog?.Show();
    }

    private async Task ExecuteDeleteContext()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null || _selectedContext is null) return;

        var contextName = _selectedContext.Name;
        using var _ = ConfigOp.Begin("Deleting context", serverId, contextName);
        var (success, error) = await EditorSvc.RemoveContextAsync(serverId, contextName);

        if (success)
        {
            Toast.Show(L["Toast_Deleted"], ToastLevel.Success, contextName);
            _selectedContext = null;
            await RefreshData();
        }
        else
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
        }
    }

    private static (string Label, string CssClass) GetContextType(string name) => name switch
    {
        "from-trunk" => ("Inbound", "badge-green"),
        "outbound-routes" => ("Outbound", "badge-blue"),
        _ when name.StartsWith("tc-", StringComparison.Ordinal) => ("TC", "badge-yellow"),
        _ when name.StartsWith("ivr-", StringComparison.Ordinal) => ("IVR", "badge-purple"),
        "queues" => ("Queues", "badge-orange"),
        "default" => ("Main", "badge-muted"),
        _ => ("", "")
    };

    private static bool IsManagedContext(string name) =>
        name is "from-trunk" or "outbound-routes" ||
        name.StartsWith("tc-", StringComparison.Ordinal) ||
        name.StartsWith("ivr-", StringComparison.Ordinal);
}
