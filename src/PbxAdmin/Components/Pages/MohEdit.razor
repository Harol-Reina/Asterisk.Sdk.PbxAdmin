@page "/moh/edit/new"
@page "/moh/edit/{Id:int}"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject MohService MohSvc
@inject AudioFileService AudioSvc
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@(_isNew ? L["MohEdit_NewTitle"] : $"{L["MohEdit_EditTitle"]} {_mohClass.Name}")</PageTitle>

<div class="page-header-row">
    <button class="btn btn-sm btn-muted" @onclick="GoBack">&#8592; @L["Btn_Back"]</button>
    <h2>@(_isNew ? L["MohEdit_New"] : $"{L["MohEdit_Edit"]}: {_mohClass.Name}")</h2>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="form-section">
    <HelpPanel SectionKey="MohEdit_ClassSettings">@L["MohEdit_ClassSettings"]</HelpPanel>

    <div class="form-group">
        <label>@L["Lbl_Name"] <HelpIcon HelpKey="MohName" /></label>
        <input type="text" @bind="_mohClass.Name" class="form-control"
               placeholder="alphanumeric, hyphens, underscores" />
    </div>

    <div class="form-group">
        <label>@L["Col_Mode"] <HelpIcon HelpKey="MohMode" /></label>
        <select @bind="_mohClass.Mode" class="form-control">
            <option value="files">files</option>
            <option value="mp3">mp3</option>
            <option value="custom">custom</option>
        </select>
        @if (_mohClass.Mode == "mp3")
        {
            <div class="alert alert-warning mt-1">
                &#9888; @L["MohEdit_Mp3Deprecated"]
            </div>
        }
    </div>

    @if (_mohClass.Mode == "files" || _mohClass.Mode == "mp3")
    {
        <div class="form-group">
            <label>@L["MohEdit_Directory"] <HelpIcon HelpKey="MohDirectory" /></label>
            <input type="text" @bind="_mohClass.Directory" class="form-control" />
        </div>

        <div class="form-group">
            <label>@L["MohEdit_Sort"] <HelpIcon HelpKey="MohSort" /></label>
            <div class="radio-group">
                <label>
                    <input type="radio" name="sort" value="random"
                           checked="@(_mohClass.Sort == "random")"
                           @onchange='() => _mohClass.Sort = "random"' /> @L["MohEdit_Random"]
                </label>
                <label>
                    <input type="radio" name="sort" value="alpha"
                           checked="@(_mohClass.Sort == "alpha")"
                           @onchange='() => _mohClass.Sort = "alpha"' /> @L["MohEdit_Alphabetical"]
                </label>
            </div>
        </div>
    }

    @if (_mohClass.Mode == "custom")
    {
        <div class="form-group">
            <label>@L["MohEdit_CustomApp"] <HelpIcon HelpKey="MohCustomApp" /></label>
            <input type="text" @bind="_mohClass.CustomApplication" class="form-control"
                   placeholder="/usr/bin/mpg123 -q -s --mono -r 8000 http://stream" />
        </div>
    }
</div>

@if (!_isNew)
{
    <div class="form-section">
        <HelpPanel SectionKey="MohEdit_AudioFiles">@L["MohEdit_AudioFiles"]</HelpPanel>

        @if (!_fileAccessAvailable)
        {
            <div class="alert alert-warning">
                &#9888; @L["MohEdit_FileAccessUnavail"]
                <br/><small class="text-muted">@L["MohEdit_Directory"]: @_mohClass.Directory</small>
            </div>
        }
        else
        {
            <div class="stat-row mb-2">
                <span class="text-muted">Usage:</span>
                @FormatSize(_files.Sum(f => f.Size)) / @(_maxClassSizeMb) MB
                @if (AudioSvc.IsSoxAvailable())
                {
                    <span class="badge badge-success ms-2">sox &#10003;</span>
                }
                else
                {
                    <span class="badge badge-muted ms-2">sox unavailable</span>
                }
            </div>

            <div class="form-group">
                <label>@L["MohEdit_UploadAudio"]</label>
                <InputFile OnChange="OnFileSelected" accept=".wav,.wav49,.gsm,.ulaw,.alaw,.sln,.mp3,.ogg" />
                <small class="text-muted">Max @(_maxFileSizeMb)MB. Formats: wav, wav49, gsm, ulaw, alaw, sln, mp3, ogg</small>
                @if (!AudioSvc.IsSoxAvailable())
                {
                    <small class="text-muted"> (mp3/ogg require sox for conversion)</small>
                }
            </div>

            @if (_uploadError is not null)
            {
                <div class="alert alert-danger">@_uploadError</div>
            }

            @if (_files.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr><th>@L["Col_Filename"]</th><th>@L["Col_Size"]</th><th>@L["Col_Duration"]</th><th>@L["Lbl_Actions"]</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _files)
                        {
                            <tr>
                                <td>@f.Name</td>
                                <td>@FormatSize(f.Size)</td>
                                <td>@(f.Duration?.ToString(@"m\:ss") ?? "—")</td>
                                <td>
                                    <button class="btn btn-sm btn-muted" @onclick="() => PlayFile(f.Name)">&#9654;</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteFile(f.Name)">&#x2715;</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_playingFile is not null)
                {
                    <div class="audio-player">
                        <strong>@_playingFile</strong>
                        <audio controls autoplay src="/api/moh/@Id/files/@_playingFile"></audio>
                    </div>
                }
            }
        }
    </div>
}

<div class="form-actions">
    <button class="btn btn-muted" @onclick="GoBack">@L["Btn_Cancel"]</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
        @(_saving ? L["Btn_Saving"] : L["Btn_Save"])
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private MohClass _mohClass = new() { Mode = "files", Sort = "random" };
    private List<AudioFileInfo> _files = [];
    private bool _isNew => Id == 0;
    private bool _saving;
    private bool _fileAccessAvailable;
    private int _maxFileSizeMb = 20;
    private int _maxClassSizeMb = 200;
    private string? _error;
    private string? _uploadError;
    private string? _playingFile;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;

        if (serverId is not null)
        {
            var basePath = Config[$"Asterisk:Servers:{serverId}:MohBasePath"] ?? "/var/lib/asterisk/moh";
            _maxFileSizeMb = Config.GetValue($"Asterisk:Servers:{serverId}:MaxUploadSizeMb", 20);
            _maxClassSizeMb = Config.GetValue($"Asterisk:Servers:{serverId}:MaxMohClassSizeMb", 200);

            if (_isNew)
            {
                _mohClass.Directory = basePath + "/";
            }
            else
            {
                var existing = await MohSvc.GetClassAsync(Id);
                if (existing is not null)
                {
                    _mohClass = existing;
                    _fileAccessAvailable = Directory.Exists(_mohClass.Directory);
                    if (_fileAccessAvailable)
                        _files = await MohSvc.GetAudioFilesAsync(Id);
                }
            }
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        var file = e.File;

        using var stream = file.OpenReadStream(maxAllowedSize: _maxFileSizeMb * 1024L * 1024L);
        var (success, error) = await MohSvc.UploadAudioAsync(
            Id, file.Name, stream, file.Size, _maxFileSizeMb, _maxClassSizeMb);

        if (success)
            _files = await MohSvc.GetAudioFilesAsync(Id);
        else
            _uploadError = error;
    }

    private async Task DeleteFile(string filename)
    {
        var (success, error) = await MohSvc.DeleteAudioAsync(Id, filename);
        if (success)
            _files = await MohSvc.GetAudioFilesAsync(Id);
        else
            _uploadError = error;
    }

    private void PlayFile(string name) => _playingFile = name;

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is null) { _error = "No server selected"; return; }

            var (success, error) = _isNew
                ? await MohSvc.CreateClassAsync(serverId, _mohClass)
                : await MohSvc.UpdateClassAsync(serverId, _mohClass);

            if (success)
                Nav.NavigateTo("/moh");
            else
                _error = error;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/moh");

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
