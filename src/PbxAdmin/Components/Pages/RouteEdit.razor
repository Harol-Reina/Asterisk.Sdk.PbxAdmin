@page "/routes/inbound/new"
@page "/routes/inbound/edit/{Id:int}"
@page "/routes/outbound/new"
@page "/routes/outbound/edit/{Id:int}"
@using PbxAdmin.Services
@using PbxAdmin.Models
@inject RouteService RouteSvc
@inject ITrunkService TrunkSvc
@inject TimeConditionService TcSvc
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast
@inject IJSRuntime JS

<PageTitle>@(_isNew ? (_isInbound ? L["RouteEdit_NewInbound"] : L["RouteEdit_NewOutbound"]) : (_isInbound ? L["RouteEdit_EditInbound"] : L["RouteEdit_EditOutbound"])) — Asterisk PBX Admin</PageTitle>

<a href="/routes" class="back-link">@L["RouteEdit_BackToList"]</a>
<h2>@(_isNew ? (_isInbound ? L["RouteEdit_NewInbound"] : L["RouteEdit_NewOutbound"]) : (_isInbound ? L["RouteEdit_EditInbound"] : L["RouteEdit_EditOutbound"]))</h2>

@if (_loading)
{
    <p class="text-muted">@L["Lbl_Loading"]</p>
}
else if (_isInbound)
{
    <!-- Inbound Route Form -->
    <div class="form-section">
        <HelpPanel SectionKey="RouteEdit_RouteDetails">@L["RouteEdit_RouteDetails"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Name"] <span class="required-mark">*</span> <HelpIcon HelpKey="RouteName" /></label>
                <input class="input @ValidationCss(_inNameTouched, _inNameValid)" @bind="_inConfig.Name" placeholder="Main Line" @onfocusout="@(() => { _inNameTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_inNameValid" IsTouched="_inNameTouched" Message="@L["Err_RouteNameRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["RouteEdit_DIDPattern"] <span class="required-mark">*</span> <HelpIcon HelpKey="RouteDIDPattern" /></label>
                <input class="input @ValidationCss(_inDidTouched, _inDidValid)" @bind="_inConfig.DidPattern" placeholder="5551234567" @onfocusout="@(() => { _inDidTouched = true; })" />
                <span class="text-muted" style="font-size:0.85rem;">@L["RouteEdit_DIDHint"]</span>
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_inDidValid" IsTouched="_inDidTouched" Message="@L["Err_DIDRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["Col_Priority"] <HelpIcon HelpKey="RoutePriority" /></label>
                <input class="input" type="number" @bind="_inConfig.Priority" />
            </div>
        </div>
    </div>

    <div class="form-section">
        <h3>@L["Lbl_Destination"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Type"] <HelpIcon HelpKey="RouteDestType" /></label>
                <select class="input" @bind="_inConfig.DestinationType">
                    <option value="">@L["Lbl_SelectType"]</option>
                    <option value="extension">@L["Lbl_Extension"]</option>
                    <option value="queue">@L["Lbl_Queue"]</option>
                    <option value="time_condition">@L["Lbl_TimeCondition"]</option>
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Lbl_Target"] <HelpIcon HelpKey="RouteTarget" /></label>
                @if (_inConfig.DestinationType == "time_condition" && _timeConditions.Count > 0)
                {
                    <select class="input" @bind="_inConfig.Destination">
                        <option value="">@L["Lbl_SelectType"]</option>
                        @foreach (var tc in _timeConditions)
                        {
                            <option value="@tc.Name">@tc.Name</option>
                        }
                    </select>
                }
                else
                {
                    <input class="input" @bind="_inConfig.Destination" placeholder="@(_inConfig.DestinationType == "queue" ? "Queue name" : "Extension number")" />
                }
            </div>
        </div>
    </div>

    <AdvancedToggle IsAdvanced="_isAdvanced" IsAdvancedChanged="v => { _isAdvanced = v; StateHasChanged(); }" />
    @if (_isAdvanced)
    {
    <div class="form-section">
        <h3>@L["RouteEdit_Options"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="codec-check">
                    <input type="checkbox" @bind="_inConfig.Enabled" />
                    @L["Lbl_Enabled"]
                </label>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Lbl_Notes"]</label>
                <textarea class="input" @bind="_inConfig.Notes" rows="3" placeholder="Optional notes"></textarea>
            </div>
        </div>
    </div>
    }
}
else
{
    <!-- Outbound Route Form -->
    <div class="form-section">
        <h3>@L["RouteEdit_RouteDetails"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Name"] <span class="required-mark">*</span></label>
                <input class="input @ValidationCss(_outNameTouched, _outNameValid)" @bind="_outConfig.Name" placeholder="Local Calls" @onfocusout="@(() => { _outNameTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_outNameValid" IsTouched="_outNameTouched" Message="@L["Err_RouteNameRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["RouteEdit_DIDPattern"]</label>
                <input class="input" @bind="_outConfig.DialPattern" placeholder="_NXXNXXXXXX" />
                <span class="text-muted" style="font-size:0.85rem;">@L["RouteEdit_DIDHint"]</span>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Col_Priority"]</label>
                <input class="input" type="number" @bind="_outConfig.Priority" />
            </div>
        </div>
    </div>

    <div class="form-section">
        <HelpPanel SectionKey="RouteEdit_TrunksOrder">@L["RouteEdit_TrunksOrder"]</HelpPanel>
        <div style="margin-bottom: 0.75rem;">
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select class="input" @bind="_selectedTrunk" style="flex: 1;">
                    <option value="">@L["RouteEdit_SelectTrunk"]</option>
                    @foreach (var trunk in _availableTrunks.Where(t => !_outConfig.Trunks.Any(rt => rt.TrunkName == t.Name)))
                    {
                        <option value="@trunk.Name">@trunk.Name (@trunk.Technology)</option>
                    }
                </select>
                <button class="btn btn-blue" @onclick="AddTrunk">@L["Btn_Add"]</button>
            </div>
        </div>
        @if (_outConfig.Trunks.Count > 0)
        {
            <table class="data-table" style="margin-bottom: 0.5rem;">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@L["Col_Trunks"]</th>
                        <th>@L["Lbl_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trunk in _outConfig.Trunks.OrderBy(t => t.Sequence))
                    {
                        <tr>
                            <td>@(trunk.Sequence + 1)</td>
                            <td>@trunk.TrunkName</td>
                            <td>
                                <button class="btn btn-sm" @onclick="() => MoveTrunkUp(trunk)" disabled="@(trunk.Sequence == 0)">@L["Btn_Up"]</button>
                                <button class="btn btn-sm" @onclick="() => MoveTrunkDown(trunk)" disabled="@(trunk.Sequence == _outConfig.Trunks.Count - 1)">@L["Btn_Down"]</button>
                                <button class="btn btn-sm btn-red" @onclick="() => RemoveTrunk(trunk)">@L["Btn_Remove"]</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">@L["RouteEdit_NoTrunks"]</p>
        }
        <PbxAdmin.Components.Shared.ValidationMessage IsValid="_outTrunksValid" IsTouched="_outTrunksTouched" Message="@L["Err_NoTrunks"]" />
    </div>

    <AdvancedToggle IsAdvanced="_isAdvanced" IsAdvancedChanged="v => { _isAdvanced = v; StateHasChanged(); }" />
    @if (_isAdvanced)
    {
    <div class="form-section">
        <h3>@L["RouteEdit_DialManip"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["RouteEdit_Prepend"]</label>
                <input class="input" @bind="_outConfig.Prepend" placeholder="@L["RouteEdit_PrependHint"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["RouteEdit_Prefix"]</label>
                <input class="input" @bind="_outConfig.Prefix" placeholder="@L["RouteEdit_PrefixHint"]" />
            </div>
        </div>
    </div>

    <div class="form-section">
        <h3>@L["RouteEdit_Options"]</h3>
        <div class="form-grid">
            <div class="form-field">
                <label class="codec-check">
                    <input type="checkbox" @bind="_outConfig.Enabled" />
                    @L["Lbl_Enabled"]
                </label>
            </div>
            <div class="form-field">
                <label class="form-label">@L["Lbl_Notes"]</label>
                <textarea class="input" @bind="_outConfig.Notes" rows="3" placeholder="Optional notes"></textarea>
            </div>
        </div>
    </div>
    }
}

<div class="form-actions">
    <button class="btn btn-green" @onclick="Save" disabled="@(_saving || !IsFormValid)">@(_saving ? L["Btn_Saving"] : L["Btn_Save"])</button>
    <button class="btn" @onclick="NavigateBack">@L["Btn_Cancel"]</button>
</div>


<style>
    .data-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--card-bg);
        border-radius: 8px;
        overflow: hidden;
    }
    .data-table th, .data-table td {
        padding: 0.6rem 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
    }
    .data-table th {
        background: rgba(255,255,255,0.04);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--text-muted);
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private bool _isInbound;
    private bool _isNew;
    private bool _loading = true;
    private bool _saving;
    private string _selectedTrunk = "";

    private InboundRouteConfig _inConfig = new();
    private OutboundRouteConfig _outConfig = new();
    private List<TrunkViewModel> _availableTrunks = [];
    private List<TimeConditionViewModel> _timeConditions = [];

    private bool _isAdvanced;

    // Inbound validation
    private bool _inNameTouched, _inDidTouched;
    private bool _inNameValid => FormValidator.IsRequired(_inConfig.Name);
    private bool _inDidValid => FormValidator.IsRequired(_inConfig.DidPattern);

    // Outbound validation
    private bool _outNameTouched, _outTrunksTouched;
    private bool _outNameValid => FormValidator.IsRequired(_outConfig.Name);
    private bool _outTrunksValid => _outConfig.Trunks.Count > 0;

    private bool IsFormValid => _isInbound
        ? _inNameValid && _inDidValid
        : _outNameValid && _outTrunksValid;

    private string ValidationCss(bool touched, bool valid) =>
        !touched ? "" : valid ? "valid" : "invalid";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.Uri;
        _isInbound = uri.Contains("/inbound/", StringComparison.OrdinalIgnoreCase);
        _isNew = uri.Contains("/new", StringComparison.OrdinalIgnoreCase);

        var serverId = ServerSvc.SelectedServerId ?? "";

        // Load available trunks and time conditions
        if (!string.IsNullOrEmpty(serverId))
        {
            _availableTrunks = await TrunkSvc.GetTrunksAsync(serverId);
            _timeConditions = await TcSvc.GetTimeConditionsAsync(serverId);
        }

        if (!_isNew && Id > 0)
        {
            if (_isInbound)
            {
                var existing = await RouteSvc.GetInboundRouteAsync(Id);
                if (existing is not null) _inConfig = existing;
            }
            else
            {
                var existing = await RouteSvc.GetOutboundRouteAsync(Id);
                if (existing is not null) _outConfig = existing;
            }
        }
        else
        {
            _inConfig.ServerId = serverId;
            _outConfig.ServerId = serverId;
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isAdvanced = await JS.InvokeAsync<bool>("HelpInterop.getAdvanced");
            StateHasChanged();
        }
    }

    private void AddTrunk()
    {
        if (string.IsNullOrEmpty(_selectedTrunk)) return;

        var trunk = _availableTrunks.FirstOrDefault(t => t.Name == _selectedTrunk);
        if (trunk is null) return;

        _outConfig.Trunks.Add(new RouteTrunk
        {
            TrunkName = trunk.Name,
            TrunkTechnology = trunk.Technology.ToString(),
            Sequence = _outConfig.Trunks.Count,
        });
        _selectedTrunk = "";
    }

    private void RemoveTrunk(RouteTrunk trunk)
    {
        _outConfig.Trunks.Remove(trunk);
        ResequenceTrunks();
    }

    private void MoveTrunkUp(RouteTrunk trunk)
    {
        var idx = _outConfig.Trunks.IndexOf(trunk);
        if (idx <= 0) return;
        var other = _outConfig.Trunks.First(t => t.Sequence == trunk.Sequence - 1);
        other.Sequence++;
        trunk.Sequence--;
    }

    private void MoveTrunkDown(RouteTrunk trunk)
    {
        var idx = _outConfig.Trunks.IndexOf(trunk);
        if (idx >= _outConfig.Trunks.Count - 1) return;
        var other = _outConfig.Trunks.First(t => t.Sequence == trunk.Sequence + 1);
        other.Sequence--;
        trunk.Sequence++;
    }

    private void ResequenceTrunks()
    {
        var ordered = _outConfig.Trunks.OrderBy(t => t.Sequence).ToList();
        for (var i = 0; i < ordered.Count; i++)
            ordered[i].Sequence = i;
    }

    private async Task Save()
    {
        if (_isInbound)
        {
            _inNameTouched = _inDidTouched = true;
        }
        else
        {
            _outNameTouched = _outTrunksTouched = true;
        }

        if (!IsFormValid) return;

        var serverId = ServerSvc.SelectedServerId;
        if (string.IsNullOrEmpty(serverId))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, "No server selected.");
            return;
        }

        _saving = true;

        try
        {
            if (_isInbound)
            {
                _inConfig.ServerId = serverId;
                var opName = _isNew ? "Creating Inbound Route" : "Updating Inbound Route";
                using var _ = ConfigOp.Begin(opName, serverId, _inConfig.Name);

                var (success, error) = _isNew
                    ? await RouteSvc.CreateInboundRouteAsync(_inConfig)
                    : await RouteSvc.UpdateInboundRouteAsync(_inConfig);

                if (success)
                    Nav.NavigateTo("/routes");
                else
                    Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
            }
            else
            {
                _outConfig.ServerId = serverId;
                var opName = _isNew ? "Creating Outbound Route" : "Updating Outbound Route";
                using var _ = ConfigOp.Begin(opName, serverId, _outConfig.Name);

                var (success, error) = _isNew
                    ? await RouteSvc.CreateOutboundRouteAsync(_outConfig)
                    : await RouteSvc.UpdateOutboundRouteAsync(_outConfig);

                if (success)
                    Nav.NavigateTo("/routes");
                else
                    Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
            }
        }
        catch (Exception ex)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void NavigateBack() => Nav.NavigateTo("/routes");
}
