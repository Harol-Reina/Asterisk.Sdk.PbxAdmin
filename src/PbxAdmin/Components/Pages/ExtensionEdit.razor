@page "/extensions/new"
@page "/extensions/edit/{ServerId}/{Extension}"
@using PbxAdmin.Services
@using PbxAdmin.Services.Dialplan
@using PbxAdmin.Models
@inject IExtensionService ExtSvc
@inject ISelectedServerService ServerSvc
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IExtensionTemplateService TemplateSvc
@inject DialplanDiscoveryService DiscoverySvc

<PageTitle>@(_isNew ? L["ExtEdit_NewTitle"] : L["ExtEdit_EditTitle", Extension ?? ""]) — Asterisk PBX Admin</PageTitle>

<a href="/extensions" class="back-link">@L["ExtEdit_BackToList"]</a>
<h2>@(_isNew ? L["ExtEdit_New"] : $"{L["ExtEdit_Edit"]}: {Extension}")</h2>

@if (_loading)
{
    <p class="text-muted">@L["Lbl_Loading"]</p>
}
else
{
    @if (_isNew)
    {
        <div class="template-selector">
            <label class="form-label">@L["Template_StartFrom"]</label>
            <select class="input" @onchange="OnTemplateSelected">
                <option value="">@L["Template_Blank"]</option>
                @foreach (var t in _templates)
                {
                    <option value="@t.Id">@t.Name — @t.Description</option>
                }
            </select>
        </div>
    }

    <!-- Identity -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_Identity">@L["ExtEdit_Identity"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_ExtNumber"] <span class="required-mark">*</span> <HelpIcon HelpKey="ExtNumber" /></label>
                <input class="input @ValidationCss(_extTouched, _extValid)" type="number" @bind="_config.Extension" placeholder="@($"{_rangeStart}–{_rangeEnd}")" disabled="@(!_isNew)" @onfocusout="@(() => { _extTouched = true; })" />
                <span class="text-muted" style="font-size:0.85rem;">@L["ExtEdit_Range"] @_rangeStart – @_rangeEnd</span>
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_extValid" IsTouched="_extTouched" Message="@L["Err_ExtOutOfRange"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_DisplayName"] <span class="required-mark">*</span> <HelpIcon HelpKey="DisplayName" /></label>
                <input class="input @ValidationCss(_nameTouched, _nameValid)" @bind="_config.Name" placeholder="John Doe" @onfocusout="@(() => { _nameTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_nameValid" IsTouched="_nameTouched" Message="@L["Err_NameRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_Technology"] <HelpIcon HelpKey="Technology" /></label>
                <div class="radio-group">
                    <label class="radio-option">
                        <input type="radio" name="tech" value="@ExtensionTechnology.PjSip" checked="@(_config.Technology == ExtensionTechnology.PjSip)"
                               @onchange="() => _config.Technology = ExtensionTechnology.PjSip" />
                        PJSIP
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="tech" value="@ExtensionTechnology.Sip" checked="@(_config.Technology == ExtensionTechnology.Sip)"
                               @onchange="() => _config.Technology = ExtensionTechnology.Sip" />
                        SIP
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="tech" value="@ExtensionTechnology.Iax2" checked="@(_config.Technology == ExtensionTechnology.Iax2)"
                               @onchange="() => _config.Technology = ExtensionTechnology.Iax2" />
                        IAX2
                    </label>
                </div>
            </div>
        </div>
    </div>

    <!-- Authentication -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_Auth">@L["ExtEdit_Auth"]</HelpPanel>
        <div class="form-grid">
            @if (_isNew)
            {
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Password"] <span class="required-mark">*</span> <HelpIcon HelpKey="Password" /></label>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <input class="input @ValidationCss(_pwdTouched, _pwdValid)" type="password" @bind="_config.Password" placeholder="Required" @onfocusout="@(() => { _pwdTouched = true; })" />
                        <button class="btn" type="button" @onclick="GeneratePassword">@L["ExtEdit_Generate"]</button>
                    </div>
                    <PbxAdmin.Components.Shared.ValidationMessage IsValid="_pwdValid" IsTouched="_pwdTouched" Message="@L["Err_PasswordTooShort"]" />
                </div>
            }
            else
            {
                <div class="form-field">
                    <label class="codec-check">
                        <input type="checkbox" @bind="_changePassword" />
                        @L["ExtEdit_ChangePassword"]
                    </label>
                    @if (_changePassword)
                    {
                        <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.5rem;">
                            <input class="input" type="password" @bind="_config.Password" placeholder="New password (min 8 chars)" />
                            <button class="btn" type="button" @onclick="GeneratePassword">@L["ExtEdit_Generate"]</button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Voicemail -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_Voicemail">@L["ExtEdit_Voicemail"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.VoicemailEnabled" />
                    @L["ExtEdit_EnableVoicemail"]
                </label>
            </div>
            @if (_config.VoicemailEnabled)
            {
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Pin"] <span class="required-mark">*</span></label>
                    <input class="input @ValidationCss(_vmPinTouched, _vmPinValid)" type="text" @bind="_config.VoicemailPin" placeholder="1234" @onfocusout="@(() => { _vmPinTouched = true; })" />
                    <PbxAdmin.Components.Shared.ValidationMessage IsValid="_vmPinValid" IsTouched="_vmPinTouched" Message="@L["Err_VoicemailPinRequired"]" />
                </div>
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Email"]</label>
                    <input class="input" type="text" @bind="_config.VoicemailEmail" placeholder="user@example.com" />
                </div>
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_MaxMessages"]</label>
                    <input class="input" type="number" @bind="_config.VoicemailMaxMessages" />
                </div>
            }
        </div>
    </div>

    <AdvancedToggle IsAdvanced="_isAdvanced" IsAdvancedChanged="@(v => _isAdvanced = v)" />

    @if (_isAdvanced)
    {

    <!-- Dialplan -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_Dialplan">@L["ExtEdit_Dialplan"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Context"] <HelpIcon HelpKey="Context" /></label>
                <select class="input" @bind="_config.Context">
                    @if (_userContexts.Count == 0)
                    {
                        <option value="@_config.Context">@_config.Context</option>
                    }
                    else
                    {
                        @foreach (var ctx in _userContexts)
                        {
                            <option value="@ctx.Name">@ctx.Name (@ctx.Extensions.Count ext)</option>
                        }
                        @if (!_userContexts.Any(c => c.Name == _config.Context))
                        {
                            <option value="@_config.Context">@_config.Context (custom)</option>
                        }
                    }
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_CallGroup"] <HelpIcon HelpKey="CallGroup" /></label>
                <input class="input" @bind="_config.CallGroup" placeholder="1" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_PickupGroup"] <HelpIcon HelpKey="PickupGroup" /></label>
                <input class="input" @bind="_config.PickupGroup" placeholder="1" />
            </div>
        </div>
    </div>

    <!-- Media & Transport -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_MediaTransport">@L["ExtEdit_MediaTransport"]</HelpPanel>
        <div class="form-field" style="margin-bottom: 0.75rem;">
            <label class="form-label">@L["ExtEdit_Codecs"] <span class="required-mark">*</span> <HelpIcon HelpKey="Codecs" /></label>
            <div class="codec-grid">
                @foreach (var codec in _availableCodecs)
                {
                    <label class="codec-check">
                        <input type="checkbox" checked="@IsCodecEnabled(codec)"
                               @onchange="e => ToggleCodec(codec, (bool)(e.Value ?? false))" />
                        @codec
                    </label>
                }
            </div>
            <PbxAdmin.Components.Shared.ValidationMessage IsValid="_codecValid" IsTouched="_codecTouched" Message="@L["Err_NoCodecs"]" />
        </div>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_DtmfMode"] <HelpIcon HelpKey="DtmfMode" /></label>
                <select @bind="_config.DtmfMode">
                    <option value="rfc4733">RFC 4733</option>
                    <option value="inband">Inband</option>
                    <option value="info">SIP INFO</option>
                    <option value="auto">Auto</option>
                </select>
            </div>
            @if (_config.Technology != ExtensionTechnology.Iax2)
            {
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Transport"] <HelpIcon HelpKey="Transport" /></label>
                    <select @bind="_config.Transport">
                        <option value="udp">transport-udp</option>
                        <option value="tcp">transport-tcp</option>
                        <option value="tls">transport-tls</option>
                    </select>
                </div>
            }
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_NatOptions"]</label>
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.ForceRport" />
                    @L["ExtEdit_ForceRport"]
                </label>
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.DirectMedia" />
                    @L["ExtEdit_DirectMedia"]
                </label>
            </div>
        </div>
    </div>

    <!-- Call Features -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_CallFeatures">@L["ExtEdit_CallFeatures"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.DndEnabled" />
                    @L["ExtEdit_DND"]
                </label>
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_CFUnconditional"]</label>
                <input class="input" type="text" @bind="_config.CallForwardUnconditional" placeholder="@L["ExtEdit_DestNumber"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_CFBusy"]</label>
                <input class="input" type="text" @bind="_config.CallForwardBusy" placeholder="@L["ExtEdit_DestNumber"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["ExtEdit_CFNoAnswer"]</label>
                <div style="display:flex;gap:0.5rem;align-items:center;">
                    <input class="input" type="text" @bind="_config.CallForwardNoAnswer" placeholder="@L["ExtEdit_DestNumber"]" />
                    <input class="input @ValidationCss(_cfnaTouched, _cfnaValid)" type="number" @bind="_config.CallForwardNoAnswerTimeout" style="width:5rem;" @onfocusout="@(() => { _cfnaTouched = true; })" />
                    <span class="text-muted">sec</span>
                </div>
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_cfnaValid" IsTouched="_cfnaTouched" Message="@L["Err_CFNoAnswerTimeout"]" />
            </div>
        </div>
    </div>

    }

    <div class="form-actions">
        <button class="btn btn-green" @onclick="Save" disabled="@(_saving || !IsFormValid)">@(_saving ? L["Btn_Saving"] : L["Btn_Save"])</button>
        <button class="btn" @onclick="NavigateBack">@L["Btn_Cancel"]</button>
        <button class="btn btn-muted" @onclick="() => _showSaveTemplate = true">@L["Template_SaveAs"]</button>

        @if (_showSaveTemplate)
        {
            <div class="template-save-dialog">
                <input class="input" @bind="_templateName" placeholder="@L["Template_NamePlaceholder"]" />
                <input class="input" @bind="_templateDesc" placeholder="@L["Template_DescPlaceholder"]" />
                <button class="btn btn-green" @onclick="SaveAsTemplate">@L["Btn_Save"]</button>
                <button class="btn" @onclick="() => _showSaveTemplate = false">@L["Btn_Cancel"]</button>
            </div>
        }
    </div>

}

@code {
    [Parameter] public string? ServerId { get; set; }
    [Parameter] public string? Extension { get; set; }

    [SupplyParameterFromQuery] public string? Server { get; set; }
    [SupplyParameterFromQuery] public string? Tech { get; set; }

    private bool _isNew => Extension is null;
    private ExtensionConfig _config = new();
    private bool _loading = true;
    private bool _saving;
    private bool _changePassword;
    private int _rangeStart = 100;
    private int _rangeEnd = 999;

    private bool _isAdvanced;
    private List<DiscoveredContext> _userContexts = [];
    private List<ExtensionTemplate> _templates = [];
    private bool _extTouched, _nameTouched, _pwdTouched, _codecTouched, _vmPinTouched, _cfnaTouched;
    private bool _showSaveTemplate;
    private string _templateName = "";
    private string _templateDesc = "";

    private bool _extValid => !_isNew || FormValidator.IsValidExtension(_config.Extension, _rangeStart, _rangeEnd);
    private bool _nameValid => FormValidator.IsRequired(_config.Name);
    private bool _pwdValid => !_isNew || FormValidator.MinLength(_config.Password, 8);
    private bool _codecValid => FormValidator.HasCodecs(_config.Codecs);
    private bool _vmPinValid => !_config.VoicemailEnabled || FormValidator.IsRequired(_config.VoicemailPin);
    private bool _cfnaValid => string.IsNullOrEmpty(_config.CallForwardNoAnswer) || _config.CallForwardNoAnswerTimeout > 0;
    private bool IsFormValid => _extValid && _nameValid && _pwdValid && _codecValid && _vmPinValid && _cfnaValid;

    private string ValidationCss(bool touched, bool valid) =>
        !touched ? "" : valid ? "valid" : "invalid";

    private static readonly string[] _availableCodecs = ["ulaw", "alaw", "g729", "g722", "opus"];

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerId ?? Server ?? ServerSvc.SelectedServerId;

        if (serverId is not null)
        {
            var range = ExtSvc.GetExtensionRange(serverId);
            _rangeStart = range.Start;
            _rangeEnd = range.End;
        }

        if (!_isNew && serverId is not null)
        {
            var technology = Enum.TryParse<ExtensionTechnology>(Tech, true, out var t) ? t : ExtensionTechnology.PjSip;
            var detail = await ExtSvc.GetExtensionDetailAsync(serverId, Extension!, technology);
            if (detail is not null)
            {
                _config.Extension = detail.Extension;
                _config.Name = detail.Name;
                _config.Technology = detail.Technology;
                _config.Context = detail.Context ?? "default";
                _config.CallGroup = detail.CallGroup;
                _config.PickupGroup = detail.PickupGroup;
                _config.Codecs = detail.Codecs ?? "ulaw,alaw";
                _config.DndEnabled = detail.DndEnabled;
                _config.CallForwardUnconditional = detail.CallForwardTo;
                _config.CallForwardBusy = detail.CfBusy;
                _config.CallForwardNoAnswer = detail.CfNoAnswer;
                _config.CallForwardNoAnswerTimeout = detail.CfNoAnswerTimeout > 0 ? detail.CfNoAnswerTimeout : 20;
                _config.VoicemailEnabled = detail.VoicemailEnabled;
                _config.VoicemailEmail = detail.VoicemailEmail;
            }
        }

        if (_isNew) _templates = (await TemplateSvc.GetAllAsync()).ToList();

        // Load discovered contexts for dropdown
        if (serverId is not null)
        {
            var snapshot = await DiscoverySvc.GetSnapshotAsync(serverId);
            if (snapshot is not null)
                _userContexts = DialplanDiscoveryService.GetUserContexts(snapshot).ToList();
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isAdvanced = await JS.InvokeAsync<bool>("HelpInterop.getAdvanced");
            StateHasChanged();
        }
    }

    private bool IsCodecEnabled(string codec)
    {
        var codecs = _config.Codecs.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return codecs.Contains(codec, StringComparer.OrdinalIgnoreCase);
    }

    private void ToggleCodec(string codec, bool enabled)
    {
        var codecs = _config.Codecs
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (enabled && !codecs.Contains(codec, StringComparer.OrdinalIgnoreCase))
            codecs.Add(codec);
        else if (!enabled)
            codecs.RemoveAll(c => string.Equals(c, codec, StringComparison.OrdinalIgnoreCase));

        _config.Codecs = string.Join(",", codecs);
        _codecTouched = true;
    }

    private void GeneratePassword()
    {
        const string chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        _config.Password = string.Create(12, chars, static (span, chars) =>
        {
            for (var i = 0; i < span.Length; i++)
                span[i] = chars[Random.Shared.Next(chars.Length)];
        });
    }

    private async Task OnTemplateSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id) && id > 0)
            _config = await TemplateSvc.ApplyTemplateAsync(id);
    }

    private async Task SaveAsTemplate()
    {
        if (string.IsNullOrWhiteSpace(_templateName)) return;
        await TemplateSvc.SaveAsTemplateAsync(_templateName, _templateDesc, _config);
        _showSaveTemplate = false;
        _templateName = "";
        _templateDesc = "";
        _templates = (await TemplateSvc.GetAllAsync()).ToList();
    }

    private async Task Save()
    {
        _extTouched = _nameTouched = _pwdTouched = _codecTouched = _vmPinTouched = _cfnaTouched = true;
        if (!IsFormValid) return;

        var serverId = ServerId ?? Server ?? ServerSvc.SelectedServerId;
        if (serverId is null)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, "No server selected.");
            return;
        }

        // Validation: extension number within range
        if (!ExtensionService.IsInExtensionRange(_config.Extension, _rangeStart, _rangeEnd))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, $"Extension must be a number between {_rangeStart} and {_rangeEnd}.");
            return;
        }

        // Validation: password required on create or when changing
        if (_isNew || _changePassword)
        {
            if (string.IsNullOrEmpty(_config.Password) || _config.Password.Length < 8)
            {
                Toast.Show(L["Toast_Error"], ToastLevel.Warning, "Password is required and must be at least 8 characters.");
                return;
            }
        }
        else
        {
            // On edit without password change, clear password so service preserves existing
            _config.Password = null;
        }

        // Validation: at least 1 codec
        if (string.IsNullOrWhiteSpace(_config.Codecs))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "At least one codec must be selected.");
            return;
        }

        // Validation: voicemail PIN
        if (_config.VoicemailEnabled && !string.IsNullOrEmpty(_config.VoicemailPin) && _config.VoicemailPin.Length < 4)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "Voicemail PIN must be at least 4 digits.");
            return;
        }

        // Validation: CF destinations numeric only
        if (!IsValidCfDestination(_config.CallForwardUnconditional)
            || !IsValidCfDestination(_config.CallForwardBusy)
            || !IsValidCfDestination(_config.CallForwardNoAnswer))
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Warning, "Call forward destinations must be numeric.");
            return;
        }

        _saving = true;

        try
        {
            var opName = _isNew ? "Creating Extension" : "Updating Extension";
            using var _ = ConfigOp.Begin(opName, serverId, _config.Extension);
            bool success;
            if (_isNew)
            {
                success = await ExtSvc.CreateExtensionAsync(serverId, _config);
            }
            else
            {
                success = await ExtSvc.UpdateExtensionAsync(serverId, Extension!, _config);
            }

            if (success)
            {
                Nav.NavigateTo("/extensions");
            }
            else
            {
                Toast.Show(L["Toast_Error"], ToastLevel.Error, "Failed to save extension. Check server logs for details.");
            }
        }
        catch (Exception ex)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private static bool IsValidCfDestination(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return true;
        return value.Trim().All(char.IsDigit);
    }

    private void NavigateBack() => Nav.NavigateTo("/extensions");
}
