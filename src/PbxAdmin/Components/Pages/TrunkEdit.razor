@page "/trunks/new"
@page "/trunks/edit/{ServerId}/{TrunkName}"
@using PbxAdmin.Services
@using PbxAdmin.Services.Dialplan
@using PbxAdmin.Models
@inject AsteriskMonitorService Monitor
@inject DialplanDiscoveryService DiscoverySvc
@inject ITrunkService TrunkSvc
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(IsNew ? L["TrunkEdit_NewTitle"] : L["TrunkEdit_EditTitle", TrunkName ?? ""]) — Asterisk PBX Admin</PageTitle>

<a href="/trunks" class="back-link">@L["TrunkEdit_BackToList"]</a>
<h2>@(IsNew ? L["TrunkEdit_New"] : $"{L["TrunkEdit_Edit"]}: {TrunkName}")</h2>

@if (_loading)
{
    <p class="text-muted">@L["Lbl_Loading"]</p>
}
else
{
    <!-- Technology -->
    <div class="form-section">
        <h3>@L["ExtEdit_Technology"]</h3>
        <div class="radio-group">
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.PjSip" checked="@(_config.Technology == TrunkTechnology.PjSip)"
                       @onchange="() => _config.Technology = TrunkTechnology.PjSip" />
                PJSIP
            </label>
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.Sip" checked="@(_config.Technology == TrunkTechnology.Sip)"
                       @onchange="() => _config.Technology = TrunkTechnology.Sip" />
                SIP
            </label>
            <label class="radio-option">
                <input type="radio" name="tech" value="@TrunkTechnology.Iax2" checked="@(_config.Technology == TrunkTechnology.Iax2)"
                       @onchange="() => _config.Technology = TrunkTechnology.Iax2" />
                IAX2
            </label>
        </div>
    </div>

    <!-- Connection -->
    <div class="form-section">
        <HelpPanel SectionKey="TrunkEdit_Connection">@L["TrunkEdit_Connection"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["Lbl_Name"] <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkName" /></label>
                <input class="input @ValidationCss(_nameTouched, _nameValid)" @bind="_config.Name" placeholder="my-trunk" disabled="@(!IsNew)" @onfocusout="@(() => { _nameTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_nameValid" IsTouched="_nameTouched" Message="@L["Err_NameRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">Host <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkHost" /></label>
                <input class="input @ValidationCss(_hostTouched, _hostValid)" @bind="_config.Host" placeholder="sip.provider.com" @onfocusout="@(() => { _hostTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_hostValid" IsTouched="_hostTouched" Message="@L["Err_InvalidHost"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Port"] <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkPort" /></label>
                <input class="input @ValidationCss(_portTouched, _portValid)" type="number" @bind="_config.Port" @onfocusout="@(() => { _portTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_portValid" IsTouched="_portTouched" Message="@L["Err_InvalidPort"]" />
            </div>
            @if (_config.Technology != TrunkTechnology.Iax2)
            {
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_Transport"] <HelpIcon HelpKey="TrunkTransport" /></label>
                    <select @bind="_config.Transport">
                        <option value="udp">UDP</option>
                        <option value="tcp">TCP</option>
                        <option value="tls">TLS</option>
                        <option value="ws">WebSocket</option>
                        <option value="wss">WSS</option>
                    </select>
                </div>
            }
            <div class="form-field">
                <label class="form-label">@L["Lbl_Context"]</label>
                <select class="input" @bind="_config.Context">
                    @if (_userContexts.Count == 0)
                    {
                        <option value="@_config.Context">@_config.Context</option>
                    }
                    else
                    {
                        @foreach (var ctx in _userContexts)
                        {
                            <option value="@ctx.Name">@ctx.Name (@ctx.Extensions.Count ext)</option>
                        }
                        @if (!_userContexts.Any(c => c.Name == _config.Context))
                        {
                            <option value="@_config.Context">@_config.Context (custom)</option>
                        }
                    }
                </select>
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_MaxChannels"]</label>
                <input class="input" type="number" @bind="_config.MaxChannels" />
            </div>
        </div>
    </div>

    <!-- Authentication -->
    <div class="form-section">
        <HelpPanel SectionKey="ExtEdit_Auth_Trunk">@L["ExtEdit_Auth"]</HelpPanel>
        <div class="form-grid">
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Username"] <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkUsername" /></label>
                <input class="input @ValidationCss(_userTouched, _userValid)" @bind="_config.Username" placeholder="username" @onfocusout="@(() => { _userTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_userValid" IsTouched="_userTouched" Message="@L["Err_NameRequired"]" />
            </div>
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Secret"] <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkSecret" /></label>
                <input class="input @ValidationCss(_secretTouched, _secretValid)" type="password" @bind="_config.Secret" placeholder="password" @onfocusout="@(() => { _secretTouched = true; })" />
                <PbxAdmin.Components.Shared.ValidationMessage IsValid="_secretValid" IsTouched="_secretTouched" Message="@L["Err_PasswordTooShort"]" />
            </div>
            @if (_config.Technology == TrunkTechnology.PjSip)
            {
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_AuthType"] <HelpIcon HelpKey="TrunkAuthType" /></label>
                    <select @bind="_config.AuthType">
                        <option value="userpass">User/Pass</option>
                        <option value="md5">MD5</option>
                    </select>
                </div>
            }
            <div class="form-field">
                <label class="form-label">@L["TrunkEdit_Registration"]</label>
                <label class="codec-check">
                    <input type="checkbox" @bind="_config.RegistrationEnabled" />
                    @L["TrunkEdit_EnableReg"]
                </label>
            </div>
        </div>
    </div>

    <AdvancedToggle IsAdvanced="_isAdvanced" IsAdvancedChanged="v => { _isAdvanced = v; StateHasChanged(); }" />
    @if (_isAdvanced)
    {

    <!-- Media / Codecs -->
    <div class="form-section">
        <h3>@L["ExtEdit_Codecs"]</h3>
        <div class="form-field" style="margin-bottom: 0.75rem;">
            <label class="form-label">@L["ExtEdit_Codecs"] <span class="required-mark">*</span> <HelpIcon HelpKey="TrunkCodecs" /></label>
            <div class="codec-grid">
                @foreach (var codec in _availableCodecs)
                {
                    <label class="codec-check">
                        <input type="checkbox" checked="@IsCodecEnabled(codec)"
                               @onchange="e => ToggleCodec(codec, (bool)(e.Value ?? false))" />
                        @codec
                    </label>
                }
            </div>
            <PbxAdmin.Components.Shared.ValidationMessage IsValid="_codecValid" IsTouched="_codecTouched" Message="@L["Err_NoCodecs"]" />
        </div>
        @if (_config.Technology != TrunkTechnology.Iax2)
        {
            <div class="form-grid">
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_DtmfMode"]</label>
                    <select @bind="_config.DtmfMode">
                        <option value="rfc4733">RFC 4733</option>
                        <option value="rfc2833">RFC 2833</option>
                        <option value="inband">Inband</option>
                        <option value="info">SIP INFO</option>
                        <option value="auto">Auto</option>
                    </select>
                </div>
            </div>
        }
    </div>

    <!-- Advanced -->
    @if (_config.Technology != TrunkTechnology.Iax2)
    {
        <div class="form-section">
            <h3>@L["TrunkEdit_Advanced"]</h3>
            <div class="form-grid">
                @if (_config.Technology == TrunkTechnology.PjSip)
                {
                    <div class="form-field">
                        <label class="form-label">@L["TrunkEdit_QualifyFreq"]</label>
                        <input class="input" type="number" @bind="_config.QualifyFrequency" />
                    </div>
                }
                <div class="form-field">
                    <label class="form-label">@L["ExtEdit_NatOptions"]</label>
                    <label class="codec-check">
                        <input type="checkbox" @bind="_config.ForceRport" />
                        @L["ExtEdit_ForceRport"]
                    </label>
                    <label class="codec-check">
                        <input type="checkbox" @bind="_config.Comedia" />
                        @L["TrunkEdit_Comedia"]
                    </label>
                </div>
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_CallerIdNum"]</label>
                    <input class="input" @bind="_config.CallerIdNum" placeholder="5551234567" />
                </div>
                <div class="form-field">
                    <label class="form-label">@L["TrunkEdit_CallerIdName"]</label>
                    <input class="input" @bind="_config.CallerIdName" placeholder="My Company" />
                </div>
            </div>
        </div>
    }

    <!-- Notes -->
    <div class="form-section">
        <h3>@L["TrunkEdit_Notes"]</h3>
        <div class="form-field">
            <textarea class="input" @bind="_config.Notes" rows="3" placeholder="Optional notes about this trunk..." style="width:100%;resize:vertical;"></textarea>
        </div>
    </div>

    }

    <div class="form-actions">
        <button class="btn btn-green" @onclick="Save" disabled="@(_saving || !IsFormValid)">@(_saving ? L["Btn_Saving"] : L["Btn_Save"])</button>
        <button class="btn" @onclick="NavigateBack">@L["Btn_Cancel"]</button>
    </div>

}

@code {
    [Parameter] public string? ServerId { get; set; }
    [Parameter] public string? TrunkName { get; set; }

    [SupplyParameterFromQuery] public string? Server { get; set; }
    [SupplyParameterFromQuery] public string? Tech { get; set; }

    private bool IsNew => TrunkName is null;
    private TrunkConfig _config = new();
    private List<DiscoveredContext> _userContexts = [];
    private bool _loading = true;
    private bool _saving;

    private static readonly string[] _availableCodecs = ["ulaw", "alaw", "g729", "opus", "gsm", "g722"];

    private bool _isAdvanced;
    private bool _nameTouched, _hostTouched, _portTouched, _userTouched, _secretTouched, _codecTouched;

    private bool _nameValid => FormValidator.IsRequired(_config.Name);
    private bool _hostValid => FormValidator.IsValidHost(_config.Host);
    private bool _portValid => FormValidator.IsValidPort(_config.Port);
    private bool _userValid => FormValidator.IsRequired(_config.Username);
    private bool _secretValid => FormValidator.IsRequired(_config.Secret);
    private bool _codecValid => FormValidator.HasCodecs(_config.Codecs);
    private bool IsFormValid => _nameValid && _hostValid && _portValid && _userValid && _secretValid && _codecValid;

    private string ValidationCss(bool touched, bool valid) =>
        !touched ? "" : valid ? "valid" : "invalid";

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerId ?? Server ?? Monitor.Servers.Select(s => s.Key).FirstOrDefault();

        if (!IsNew && serverId is not null)
        {
            var technology = Enum.TryParse<TrunkTechnology>(Tech, true, out var t) ? t : TrunkTechnology.PjSip;
            var detail = await TrunkSvc.GetTrunkDetailAsync(serverId, TrunkName!, technology);
            if (detail is not null)
            {
                _config = detail.Config;
            }
        }
        else
        {
            _config.Port = 5060;
        }

        // Load discovered contexts for dropdown
        if (serverId is not null)
        {
            var snapshot = await DiscoverySvc.GetSnapshotAsync(serverId);
            if (snapshot is not null)
                _userContexts = DialplanDiscoveryService.GetUserContexts(snapshot).ToList();
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { _isAdvanced = await JS.InvokeAsync<bool>("HelpInterop.getAdvanced"); StateHasChanged(); }
    }

    private bool IsCodecEnabled(string codec)
    {
        var codecs = _config.Codecs.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return codecs.Contains(codec, StringComparer.OrdinalIgnoreCase);
    }

    private void ToggleCodec(string codec, bool enabled)
    {
        var codecs = _config.Codecs
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (enabled && !codecs.Contains(codec, StringComparer.OrdinalIgnoreCase))
            codecs.Add(codec);
        else if (!enabled)
            codecs.RemoveAll(c => string.Equals(c, codec, StringComparison.OrdinalIgnoreCase));

        _config.Codecs = string.Join(",", codecs);
        _codecTouched = true;
    }

    private async Task Save()
    {
        _nameTouched = _hostTouched = _portTouched = _userTouched = _secretTouched = _codecTouched = true;
        if (!IsFormValid) return;

        var serverId = ServerId ?? Server ?? Monitor.Servers.Select(s => s.Key).FirstOrDefault();
        if (serverId is null)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, "No server selected.");
            return;
        }

        _saving = true;

        try
        {
            var opName = IsNew ? "Creating Trunk" : "Updating Trunk";
            using var _ = ConfigOp.Begin(opName, serverId, _config.Name);
            bool success;
            if (IsNew)
            {
                success = await TrunkSvc.CreateTrunkAsync(serverId, _config);
            }
            else
            {
                success = await TrunkSvc.UpdateTrunkAsync(serverId, _config);
            }

            if (success)
            {
                Nav.NavigateTo("/trunks");
            }
            else
            {
                Toast.Show(L["Toast_Error"], ToastLevel.Error, "Failed to save trunk. Check server logs for details.");
            }
        }
        catch (Exception ex)
        {
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void NavigateBack() => Nav.NavigateTo("/trunks");
}
