@page "/extensions"
@using PbxAdmin.Services
@using PbxAdmin.Models
@inject ISelectedServerService ServerSvc
@inject IExtensionService ExtSvc
@inject IConfigProviderResolver ConfigResolver
@inject IConfigOperationState ConfigOp
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@L["Ext_Title"]</PageTitle>

<h2>@L["Ext_Heading"]</h2>

<HelpPanel SectionKey="Extensions_Overview">@L["Ext_Heading"]</HelpPanel>

@{
    var activeServer = ServerSvc.SelectedServerId;
    if (activeServer is not null)
    {
        var mode = ConfigResolver.GetConfigMode(activeServer);
        var modeBadge = mode == ConfigMode.Realtime ? "badge-realtime" : "badge-file";
        <p class="text-muted" style="margin-top: 0.25rem;">@L["Ext_ConfigBackend"] <span class="badge @modeBadge">@mode</span></p>
    }
}

<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_extensions.Count</div>
        <div class="kpi-label">@L["Ext_Total"]</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@_extensions.Count(e => e.Status == ExtensionStatus.Registered)</div>
        <div class="kpi-label">@L["Ext_Registered"]</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-value">@_extensions.Count(e => e.Status == ExtensionStatus.Unregistered)</div>
        <div class="kpi-label">@L["Ext_Unregistered"]</div>
    </div>
    <div class="kpi-card kpi-gray">
        <div class="kpi-value">@_extensions.Count(e => e.VoicemailEnabled)</div>
        <div class="kpi-label">@L["Ext_WithVoicemail"]</div>
    </div>
</div>

<div class="chip-bar">
    <span style="font-weight: 600; margin-right: 0.25rem;">@L["Lbl_Tech"]</span>
    <button class="chip @(_techFilter == "All" ? "chip-active" : "")" @onclick="@(() => SetTechFilter("All"))">@L["Lbl_All"]</button>
    <button class="chip @(_techFilter == "PJSIP" ? "chip-active" : "")" @onclick="@(() => SetTechFilter("PJSIP"))">PJSIP</button>
    <button class="chip @(_techFilter == "SIP" ? "chip-active" : "")" @onclick="@(() => SetTechFilter("SIP"))">SIP</button>
    <button class="chip @(_techFilter == "IAX2" ? "chip-active" : "")" @onclick="@(() => SetTechFilter("IAX2"))">IAX2</button>
    <span style="font-weight: 600; margin-left: 0.75rem; margin-right: 0.25rem;">@L["Lbl_StatusFilter"]</span>
    <button class="chip @(_statusFilter == "All" ? "chip-active" : "")" @onclick="@(() => SetStatusFilter("All"))">@L["Lbl_All"]</button>
    <button class="chip @(_statusFilter == "Registered" ? "chip-active" : "")" @onclick="@(() => SetStatusFilter("Registered"))">@L["Ext_Registered"]</button>
    <button class="chip @(_statusFilter == "Unregistered" ? "chip-active" : "")" @onclick="@(() => SetStatusFilter("Unregistered"))">@L["Ext_Unregistered"]</button>
    <button class="chip @(_statusFilter == "Unreachable" ? "chip-active" : "")" @onclick="@(() => SetStatusFilter("Unreachable"))">@L["Lbl_Unreachable"]</button>
</div>

<div style="margin-bottom: 1rem; display: flex; gap: 0.5rem; align-items: center;">
    <input type="text" placeholder="@L["Ext_Search"]" @bind="_searchFilter" @bind:event="oninput"
           style="padding: 0.4rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--card-bg); color: var(--text);" />
    <button class="btn btn-blue" @onclick="NavigateNew">@L["Ext_NewExt"]</button>
</div>

<div class="card-grid">
    @foreach (var ext in FilteredExtensions)
    {
        var statusClass = GetStatusClass(ext.Status);
        var techBadge = GetTechBadge(ext.Technology);
        <div class="trunk-card @statusClass">
            <div class="trunk-card-header">
                <span class="status-dot @GetDotClass(ext.Status)"></span>
                <strong>@ext.Extension</strong>
                @if (!string.IsNullOrEmpty(ext.Name))
                {
                    <span style="opacity: 0.7;">@ext.Name</span>
                }
                <span class="badge @techBadge">@ext.Technology</span>
                <span class="badge badge-muted">@ext.Status</span>
            </div>
            <div class="trunk-card-body">
                @if (!string.IsNullOrEmpty(ext.IpAddress))
                {
                    <div>IP: @ext.IpAddress</div>
                }
                @if (!string.IsNullOrEmpty(ext.UserAgent))
                {
                    <div>UA: @ext.UserAgent</div>
                }
                <div style="display: flex; gap: 0.35rem; margin-top: 0.25rem;">
                    @if (ext.VoicemailEnabled)
                    {
                        <span title="Voicemail enabled">&#x1F4EC;</span>
                    }
                    @if (ext.DndEnabled)
                    {
                        <span title="Do Not Disturb">&#x1F507;</span>
                    }
                    @if (!string.IsNullOrEmpty(ext.CallForwardTo))
                    {
                        <span title="Call Forward to @ext.CallForwardTo">&#x21AA;&#xFE0F; @ext.CallForwardTo</span>
                    }
                </div>
            </div>
            <div class="trunk-card-actions">
                <button class="btn btn-sm btn-blue" @onclick="() => NavigateDetail(ext)">@L["Ext_Detail"]</button>
                <button class="btn btn-sm btn-yellow" @onclick="() => NavigateEdit(ext)">@L["Btn_Edit"]</button>
                <button class="btn btn-sm btn-red" @onclick="() => ConfirmDelete(ext)">@L["Btn_Delete"]</button>
            </div>
        </div>
    }
</div>

<ConfirmDialog @ref="_deleteDialog"
    Title="@L["Confirm_DeleteTitle"]"
    Message="@L["Ext_DeleteConfirm", _deletingExtension?.Extension ?? ""]"
    ConfirmText="@L["Btn_Delete"]"
    CancelText="@L["Btn_Cancel"]"
    ConfirmStyle="danger"
    OnConfirm="ExecuteDelete" />

@code {
    private Timer? _timer;
    private string _techFilter = "All";
    private string _statusFilter = "All";
    private string _searchFilter = "";
    private List<ExtensionViewModel> _extensions = [];
    private ExtensionViewModel? _deletingExtension;
    private ConfirmDialog? _deleteDialog;

    private IEnumerable<ExtensionViewModel> FilteredExtensions
    {
        get
        {
            IEnumerable<ExtensionViewModel> result = _extensions;

            if (_techFilter != "All")
            {
                var tech = _techFilter switch
                {
                    "PJSIP" => ExtensionTechnology.PjSip,
                    "SIP" => ExtensionTechnology.Sip,
                    "IAX2" => ExtensionTechnology.Iax2,
                    _ => (ExtensionTechnology?)null
                };
                if (tech.HasValue)
                    result = result.Where(e => e.Technology == tech.Value);
            }

            if (_statusFilter != "All")
            {
                var status = _statusFilter switch
                {
                    "Registered" => ExtensionStatus.Registered,
                    "Unregistered" => ExtensionStatus.Unregistered,
                    "Unreachable" => ExtensionStatus.Unreachable,
                    _ => (ExtensionStatus?)null
                };
                if (status.HasValue)
                    result = result.Where(e => e.Status == status.Value);
            }

            if (!string.IsNullOrWhiteSpace(_searchFilter))
            {
                var search = _searchFilter.Trim();
                result = result.Where(e =>
                    e.Extension.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (e.Name is not null && e.Name.Contains(search, StringComparison.OrdinalIgnoreCase)));
            }

            return result;
        }
    }

    protected override void OnInitialized()
    {
        _timer = new Timer(async _ =>
        {
            await LoadExtensions();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task LoadExtensions()
    {
        try
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is null) return;
            _extensions = await ExtSvc.GetExtensionsAsync(serverId);
        }
        catch
        {
            // Silently handle errors during polling
        }
    }

    private void SetTechFilter(string value) => _techFilter = value;
    private void SetStatusFilter(string value) => _statusFilter = value;

    private void NavigateNew() =>
        Nav.NavigateTo($"/extensions/new?server={ServerSvc.SelectedServerId}");

    private void NavigateDetail(ExtensionViewModel ext) =>
        Nav.NavigateTo($"/extensions/{ServerSvc.SelectedServerId}/{ext.Extension}?tech={ext.Technology}");

    private void NavigateEdit(ExtensionViewModel ext) =>
        Nav.NavigateTo($"/extensions/edit/{ServerSvc.SelectedServerId}/{ext.Extension}?tech={ext.Technology}");

    private void ConfirmDelete(ExtensionViewModel ext)
    {
        _deletingExtension = ext;
        _deleteDialog?.Show();
    }

    private async Task ExecuteDelete()
    {
        if (_deletingExtension is null) return;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var extNumber = _deletingExtension.Extension;
        try
        {
            using var _ = ConfigOp.Begin("Deleting Extension", serverId, extNumber);
            var success = await ExtSvc.DeleteExtensionAsync(serverId, extNumber, _deletingExtension.Technology);
            _deletingExtension = null;

            if (success)
                Toast.Show(L["Toast_Deleted"], ToastLevel.Success, extNumber);
            else
                Toast.Show(L["Toast_Error"], ToastLevel.Error);

            await LoadExtensions();
        }
        catch (Exception ex)
        {
            _deletingExtension = null;
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
    }

    private static string GetStatusClass(ExtensionStatus status) => status switch
    {
        ExtensionStatus.Registered => "trunk-registered",
        ExtensionStatus.Unregistered => "trunk-unregistered",
        ExtensionStatus.Unreachable => "trunk-unreachable",
        _ => "trunk-unknown"
    };

    private static string GetDotClass(ExtensionStatus status) => status switch
    {
        ExtensionStatus.Registered => "dot-green",
        ExtensionStatus.Unregistered => "dot-red",
        ExtensionStatus.Unreachable => "dot-yellow",
        _ => "dot-gray"
    };

    private static string GetTechBadge(ExtensionTechnology tech) => tech switch
    {
        ExtensionTechnology.PjSip => "badge-pjsip",
        ExtensionTechnology.Sip => "badge-sip",
        ExtensionTechnology.Iax2 => "badge-iax",
        _ => "badge-muted"
    };

    public void Dispose() => _timer?.Dispose();
}
