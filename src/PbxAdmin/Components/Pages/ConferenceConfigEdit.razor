@page "/conferences/config/new"
@page "/conferences/config/{Id:int}"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject ConferenceConfigService ConfConfigSvc
@inject MohService MohSvc
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@(_isNew ? L["ConfEdit_NewTitle"] : $"{L["ConfEdit_EditTitle"]} {_config.Name}")</PageTitle>

<div class="page-header-row">
    <button class="btn btn-sm btn-muted" @onclick="GoBack">&#8592; @L["Btn_Back"]</button>
    <h2>@(_isNew ? L["ConfEdit_New"] : $"{L["ConfEdit_Edit"]}: {_config.Name}")</h2>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="form-section">
    <HelpPanel SectionKey="ConfEdit_BridgeSettings">@L["ConfEdit_BridgeSettings"]</HelpPanel>

    <div class="form-group">
        <label>@L["Lbl_Name"] <HelpIcon HelpKey="ConfName" /></label>
        <input type="text" @bind="_config.Name" class="form-control"
               placeholder="alphanumeric, hyphens, underscores" />
    </div>

    <div class="form-group">
        <label>@L["ConfEdit_NumberExt"] <HelpIcon HelpKey="ConfNumber" /></label>
        <input type="text" @bind="_config.Number" class="form-control"
               placeholder="e.g. 6000" />
        <small class="text-muted">@L["ConfEdit_NumberHint"]</small>
    </div>

    <div class="form-group">
        <label>@L["ConfEdit_MaxMembers"] <HelpIcon HelpKey="ConfMaxMembers" /></label>
        <input type="number" @bind="_config.MaxMembers" class="form-control" min="0" />
        <small class="text-muted">@L["ConfEdit_MaxHint"]</small>
    </div>
</div>

<div class="form-section">
    <HelpPanel SectionKey="ConfEdit_Security">@L["ConfEdit_Security"]</HelpPanel>

    <div class="form-group">
        <label>@L["ConfEdit_UserPin"] <HelpIcon HelpKey="ConfUserPin" /></label>
        <input type="text" @bind="_config.Pin" class="form-control"
               placeholder="Digits only (leave empty for no PIN)" />
    </div>

    <div class="form-group">
        <label>@L["ConfEdit_AdminPin"] <HelpIcon HelpKey="ConfAdminPin" /></label>
        <input type="text" @bind="_config.AdminPin" class="form-control"
               placeholder="Digits only (leave empty for no admin PIN)" />
    </div>
</div>

<div class="form-section">
    <HelpPanel SectionKey="ConfEdit_Options">@L["ConfEdit_Options"]</HelpPanel>

    <div class="form-group">
        <label>
            <input type="checkbox" @bind="_config.Record" />
            @L["ConfEdit_AutoRecord"] <HelpIcon HelpKey="ConfAutoRecord" />
        </label>
    </div>

    <div class="form-group">
        <label>@L["ConfEdit_MohClass"] <HelpIcon HelpKey="ConfMohClass" /></label>
        <select @bind="_config.MusicOnHold" class="form-control">
            <option value="default">default</option>
            @foreach (var cls in _mohClasses)
            {
                <option value="@cls.Name">@cls.Name</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_config.MusicOnHold) && _config.MusicOnHold != "default")
        {
            <button type="button" class="btn btn-sm btn-muted" @onclick="PreviewMoh"
                    disabled="@_previewPlaying">&#9654;</button>
        }
        @if (_previewPlaying && _previewUrl is not null)
        {
            <div class="audio-player mt-1">
                <audio controls autoplay src="@_previewUrl"
                       @onended="() => _previewPlaying = false"></audio>
            </div>
        }
    </div>
</div>

<div class="form-actions">
    <button class="btn btn-muted" @onclick="GoBack">@L["Btn_Cancel"]</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
        @(_saving ? L["Btn_Saving"] : L["Btn_Save"])
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private ConferenceConfig _config = new() { MusicOnHold = "default" };
    private List<MohClass> _mohClasses = [];
    private bool _isNew => Id == 0;
    private bool _saving;
    private bool _previewPlaying;
    private string? _previewUrl;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        // Load MOH classes for dropdown
        try { _mohClasses = await MohSvc.GetClassesAsync(serverId); }
        catch { /* MOH list is optional */ }

        if (!_isNew)
        {
            var existing = await ConfConfigSvc.GetConfigAsync(Id);
            if (existing is not null)
                _config = existing;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_config.Name))
        {
            _error = "Name is required";
            return;
        }

        _saving = true;
        _error = null;
        try
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is null) { _error = "No server selected"; return; }

            var (success, error) = _isNew
                ? await ConfConfigSvc.CreateConfigAsync(serverId, _config)
                : await ConfConfigSvc.UpdateConfigAsync(serverId, _config);

            if (success)
                Nav.NavigateTo("/conferences");
            else
                _error = error;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task PreviewMoh()
    {
        var cls = _mohClasses.FirstOrDefault(c => c.Name == _config.MusicOnHold);
        if (cls is null) return;
        var files = await MohSvc.GetAudioFilesAsync(cls.Id);
        if (files.Count == 0) return;
        _previewUrl = $"/api/moh/{cls.Id}/files/{files[0].Name}";
        _previewPlaying = true;
    }

    private void GoBack() => Nav.NavigateTo("/conferences");
}
