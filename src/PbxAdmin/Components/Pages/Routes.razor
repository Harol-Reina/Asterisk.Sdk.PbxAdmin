@page "/routes"
@using PbxAdmin.Services
@using PbxAdmin.Services.CallFlow
@using PbxAdmin.Models
@inject ISelectedServerService ServerSvc
@inject RouteService RouteSvc
@inject TimeConditionService TcSvc
@inject CallFlowService FlowSvc
@inject ITrunkService TrunkSvc
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast

<PageTitle>@L["Routes_Title"]</PageTitle>

<h2>@L["Routes_Heading"]</h2>

<div class="chip-bar" style="margin-bottom: 1rem;">
    <button class="chip @(_activeTab == "inbound" ? "chip-active" : "")" @onclick="@(() => _activeTab = "inbound")">@L["Routes_Inbound"]</button>
    <button class="chip @(_activeTab == "outbound" ? "chip-active" : "")" @onclick="@(() => _activeTab = "outbound")">@L["Routes_Outbound"]</button>
</div>

@if (_activeTab == "inbound")
{
    <HelpPanel SectionKey="Routes_Inbound">@L["Routes_Inbound"]</HelpPanel>

    <div class="kpi-grid kpi-grid-sm">
        <div class="kpi-card kpi-blue">
            <div class="kpi-value">@_inbound.Count</div>
            <div class="kpi-label">@L["Ext_Total"]</div>
        </div>
        <div class="kpi-card kpi-green">
            <div class="kpi-value">@_inbound.Count(r => r.Enabled)</div>
            <div class="kpi-label">@L["Lbl_Enabled"]</div>
        </div>
        <div class="kpi-card kpi-red">
            <div class="kpi-value">@_inbound.Count(r => !r.Enabled)</div>
            <div class="kpi-label">@L["Lbl_Disabled"]</div>
        </div>
    </div>

    <div style="margin-bottom: 1rem;">
        <button class="btn btn-blue" @onclick="NavigateNewInbound">@L["Routes_NewInbound"]</button>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_Priority"]</th>
                <th>@L["Lbl_Name"]</th>
                <th>@L["Col_DIDPattern"]</th>
                <th>@L["Lbl_Destination"]</th>
                <th>@L["Lbl_Status"]</th>
                <th>@L["Lbl_Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var route in _inbound.OrderBy(r => r.Priority))
            {
                <tr>
                    <td>@route.Priority</td>
                    <td>@route.Name</td>
                    <td><code>@route.DidPattern</code></td>
                    <td>
                        <span class="badge @GetDestBadge(route.DestinationType)">@GetDestTypeLabel(route.DestinationType)</span>
                        @(route.DestinationLabel ?? route.Destination)
                        @{
                            var flowSummary = GetFlowSummary(route);
                        }
                        @if (flowSummary is not null)
                        {
                            <div class="route-flow-summary">@flowSummary</div>
                        }
                    </td>
                    <td>
                        <span class="badge @(route.Enabled ? "badge-green" : "badge-muted")">@(route.Enabled ? L["Lbl_Enabled"] : L["Lbl_Disabled"])</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-yellow" @onclick="() => NavigateEditInbound(route.Id)">@L["Btn_Edit"]</button>
                        <button class="btn btn-sm btn-red" @onclick="() => ConfirmDeleteInbound(route)">@L["Btn_Delete"]</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <HelpPanel SectionKey="Routes_Outbound">@L["Routes_Outbound"]</HelpPanel>

    <div style="margin-bottom: 1rem;">
        <button class="btn btn-blue" @onclick="NavigateNewOutbound">@L["Routes_NewOutbound"]</button>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>@L["Col_Priority"]</th>
                <th>@L["Lbl_Name"]</th>
                <th>@L["Col_DialPattern"]</th>
                <th>@L["Col_Trunks"]</th>
                <th>@L["Col_PrependPrefix"]</th>
                <th>@L["Lbl_Status"]</th>
                <th>@L["Lbl_Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var route in _outbound.OrderBy(r => r.Priority))
            {
                <tr>
                    <td>@route.Priority</td>
                    <td>@route.Name</td>
                    <td>
                        <code>@route.DialPattern</code>
                        @{
                            var humanDesc = DialPatternHumanizer.Describe(route.DialPattern ?? "");
                        }
                        @if (!string.IsNullOrEmpty(humanDesc) && humanDesc != (route.DialPattern ?? ""))
                        {
                            <div class="text-muted" style="font-size: 0.78rem;">@humanDesc</div>
                        }
                    </td>
                    <td>
                        @{
                            var orderedTrunks = route.Trunks.OrderBy(t => t.Sequence).ToList();
                        }
                        @for (var i = 0; i < orderedTrunks.Count; i++)
                        {
                            var trunk = orderedTrunks[i];
                            var isUp = _trunkStatus.TryGetValue(trunk.TrunkName, out var registered) && registered;
                            @if (i > 0)
                            {
                                <span style="margin: 0 0.15rem; color: var(--text-muted);">&rarr;</span>
                            }
                            <span class="badge badge-blue" style="margin-right: 0.15rem;">@(i + 1). @trunk.TrunkName <span class="trunk-dot @(isUp ? "dot-green" : "dot-red")"></span></span>
                        }
                    </td>
                    <td>
                        @{
                            var prepend = _outboundConfigs.TryGetValue(route.Id, out var cfg) ? cfg.Prepend : null;
                            var prefix = cfg?.Prefix;
                            var preview = NumberManipulator.Preview(prefix, prepend);
                        }
                        @if (!string.IsNullOrEmpty(preview))
                        {
                            <code style="font-size: 0.8rem;">@preview</code>
                        }
                        else
                        {
                            <span class="text-muted">&mdash;</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(route.Enabled ? "badge-green" : "badge-muted")">@(route.Enabled ? L["Lbl_Enabled"] : L["Lbl_Disabled"])</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-yellow" @onclick="() => NavigateEditOutbound(route.Id)">@L["Btn_Edit"]</button>
                        <button class="btn btn-sm btn-red" @onclick="() => ConfirmDeleteOutbound(route)">@L["Btn_Delete"]</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDialog @ref="_deleteDialog"
    Title="@L["Routes_DeleteTitle"]"
    Message="@L["Routes_DeleteConfirm", _deletingName ?? ""]"
    ConfirmText="@L["Btn_Delete"]"
    CancelText="@L["Btn_Cancel"]"
    ConfirmStyle="danger"
    OnConfirm="ExecuteDelete" />

<style>
    .data-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--card-bg);
        border-radius: 8px;
        overflow: hidden;
    }
    .data-table th, .data-table td {
        padding: 0.6rem 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
    }
    .data-table th {
        background: rgba(255,255,255,0.04);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--text-muted);
    }
    .data-table tbody tr:hover {
        background: rgba(255,255,255,0.03);
    }
    .badge-green { background: #22c55e22; color: #4ade80; }
    .badge-blue { background: #3b82f622; color: #60a5fa; }
    .badge-purple { background: #a855f722; color: #c084fc; }
    .trunk-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-left: 4px; vertical-align: middle; }
    .dot-green { background: #4ade80; }
    .dot-red { background: #f87171; }
    .route-flow-summary { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem; }
</style>

@code {
    private string _activeTab = "inbound";
    private List<InboundRouteViewModel> _inbound = [];
    private List<OutboundRouteViewModel> _outbound = [];
    private Dictionary<int, OutboundRouteConfig> _outboundConfigs = new();
    private Dictionary<string, bool> _trunkStatus = new(StringComparer.OrdinalIgnoreCase);
    private CallFlowGraph? _graph;
    private string? _deletingName;
    private int _deletingId;
    private bool _deletingIsInbound;
    private ConfirmDialog? _deleteDialog;

    private void NavigateNewInbound() => Nav.NavigateTo("/routes/inbound/new");
    private void NavigateNewOutbound() => Nav.NavigateTo("/routes/outbound/new");
    private void NavigateEditInbound(int id) => Nav.NavigateTo($"/routes/inbound/edit/{id}");
    private void NavigateEditOutbound(int id) => Nav.NavigateTo($"/routes/outbound/edit/{id}");

    protected override async Task OnInitializedAsync()
    {
        await LoadRoutes();
    }

    private async Task LoadRoutes()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        _inbound = await RouteSvc.GetInboundRoutesAsync(serverId);
        _outbound = await RouteSvc.GetOutboundRoutesAsync(serverId);

        // Load outbound configs for prepend/prefix display
        _outboundConfigs.Clear();
        foreach (var ob in _outbound)
        {
            var cfg = await RouteSvc.GetOutboundRouteAsync(ob.Id);
            if (cfg is not null) _outboundConfigs[ob.Id] = cfg;
        }

        // Load trunk status for health indicators
        var trunks = await TrunkSvc.GetTrunksAsync(serverId);
        _trunkStatus = trunks.ToDictionary(
            t => t.Name,
            t => t.Status == TrunkStatus.Registered,
            StringComparer.OrdinalIgnoreCase);

        // Load call flow graph for inbound flow summaries
        _graph = await FlowSvc.BuildFlowAsync(serverId);
    }

    private void ConfirmDeleteInbound(InboundRouteViewModel route)
    {
        _deletingId = route.Id;
        _deletingName = route.Name;
        _deletingIsInbound = true;
        _deleteDialog?.Show();
    }

    private void ConfirmDeleteOutbound(OutboundRouteViewModel route)
    {
        _deletingId = route.Id;
        _deletingName = route.Name;
        _deletingIsInbound = false;
        _deleteDialog?.Show();
    }

    private async Task ExecuteDelete()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var deletingName = _deletingName;
        try
        {
            using var _ = ConfigOp.Begin("Deleting Route", serverId, deletingName);
            bool success;
            if (_deletingIsInbound)
                success = await RouteSvc.DeleteInboundRouteAsync(_deletingId, serverId);
            else
                success = await RouteSvc.DeleteOutboundRouteAsync(_deletingId, serverId);

            _deletingName = null;

            if (success)
                Toast.Show(L["Toast_Deleted"], ToastLevel.Success, deletingName);
            else
                Toast.Show(L["Toast_Error"], ToastLevel.Error);

            await LoadRoutes();
        }
        catch (Exception ex)
        {
            _deletingName = null;
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
    }

    private string? GetFlowSummary(InboundRouteViewModel route)
    {
        if (_graph is null) return null;
        var did = _graph.InboundFlows.FirstOrDefault(d =>
            string.Equals(d.RouteName, route.Name, StringComparison.OrdinalIgnoreCase));
        if (did?.Destination is null) return null;
        return did.Destination switch
        {
            TimeConditionNode tc => $"\u2192 TC {tc.Label}: Open \u2192 {DescribeNode(tc.OpenBranch)} / Closed \u2192 {DescribeNode(tc.ClosedBranch)}",
            IvrNode ivr => $"\u2192 IVR {ivr.Label} ({ivr.Options.Count} options)",
            QueueNode q => $"\u2192 Queue {q.Label}",
            ExtensionNode ext => $"\u2192 Ext {ext.Number}",
            _ => null
        };
    }

    private static string DescribeNode(CallFlowNode? node) => node switch
    {
        QueueNode q => $"Queue {q.Label}",
        ExtensionNode ext => $"Ext {ext.Number}",
        IvrNode ivr => $"IVR {ivr.Label}",
        VoicemailNode vm => $"VM {vm.Extension}",
        HangupNode => "Hangup",
        _ => "?"
    };

    private static string GetDestBadge(string type) => type switch
    {
        "time_condition" => "badge-green",
        "queue" => "badge-blue",
        "extension" => "badge-purple",
        _ => "badge-muted"
    };

    private static string GetDestTypeLabel(string type) => type switch
    {
        "time_condition" => "TC",
        "queue" => "Queue",
        "extension" => "Ext",
        _ => type
    };
}
