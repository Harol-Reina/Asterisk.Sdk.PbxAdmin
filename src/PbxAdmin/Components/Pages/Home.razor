@page "/"
@using PbxAdmin.Services
@inject IStringLocalizer<SharedStrings> L
@inject ISelectedServerService ServerSvc
@inject ICallSessionManager Sessions
@implements IDisposable

<PageTitle>@L["Home_Title"]</PageTitle>

<h2>@L["Home_Heading"]</h2>

<StatusSemaphore />

<HelpPanel SectionKey="Home_KPIs">@L["Home_Heading"]</HelpPanel>

<div class="kpi-grid">
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_activeCalls</div>
        <div class="kpi-label">@L["Home_ActiveCalls"]</div>
    </div>
    <div class="kpi-card kpi-purple">
        <div class="kpi-value">@_queueCount</div>
        <div class="kpi-label">@L["Nav_Queues"]</div>
    </div>
    <div class="kpi-card @(_waitingCallers > 0 ? "kpi-red" : "kpi-gray")">
        <div class="kpi-value">@_waitingCallers</div>
        <div class="kpi-label">@L["Home_WaitingCallers"]</div>
    </div>
</div>

<HelpPanel SectionKey="Home_CallFlowMetrics">@L["Home_CallFlowMetrics"]</HelpPanel>
<div class="kpi-grid kpi-grid-sm">
    <div class="kpi-card kpi-blue">
        <div class="kpi-value">@_callsTracked</div>
        <div class="kpi-label">@L["Home_CallsTracked"]</div>
    </div>
    <div class="kpi-card kpi-orange">
        <div class="kpi-value">@_avgWaitTime</div>
        <div class="kpi-label">@L["Home_AvgWait"]</div>
    </div>
    <div class="kpi-card kpi-green">
        <div class="kpi-value">@_avgTalkTime</div>
        <div class="kpi-label">@L["Home_AvgTalk"]</div>
    </div>
    <div class="kpi-card kpi-red">
        <div class="kpi-value">@_abandonRate</div>
        <div class="kpi-label">@L["Home_AbandonPct"]</div>
    </div>
</div>

<HelpPanel SectionKey="Home_QueueSummary">@L["Home_QueueSummary"]</HelpPanel>

<table class="data-table">
    <thead>
        <tr>
            <th>@L["Col_Queue"]</th>
            <th>@L["Col_Members"]</th>
            <th>@L["Col_Waiting"]</th>
            <th>@L["Col_Completed"]</th>
            <th>@L["Col_Abandoned"]</th>
            <th>@L["Col_AvgHold"]</th>
            <th>@L["Col_AvgTalk"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var (serverId, entry) in ServerSvc.GetServers())
        {
            foreach (var queue in entry.Server.Queues.Queues)
            {
                <tr>
                    <td><a href="/queue/@serverId/@queue.Name">@queue.Name</a></td>
                    <td>@queue.MemberCount</td>
                    <td class="@(queue.EntryCount > 0 ? "text-red" : "")">@queue.EntryCount</td>
                    <td>@queue.Completed</td>
                    <td>@queue.Abandoned</td>
                    <td>@FormatSeconds(queue.HoldTime)</td>
                    <td>@FormatSeconds(queue.TalkTime)</td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private Timer? _timer;
    private int _activeCalls, _queueCount, _waitingCallers;
    private int _callsTracked;
    private string _avgWaitTime = "—", _avgTalkTime = "—", _abandonRate = "—";

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => { Refresh(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private void Refresh()
    {
        var servers = ServerSvc.GetServers();
        _activeCalls = servers.Sum(s => s.Value.Server.Channels.ChannelCount);
        _queueCount = servers.Sum(s => s.Value.Server.Queues.QueueCount);
        _waitingCallers = servers
            .SelectMany(s => s.Value.Server.Queues.Queues)
            .Sum(q => q.EntryCount);

        var serverId = ServerSvc.SelectedServerId;
        var recent = Sessions.GetRecentCompleted(200).ToList();
        var allCalls = Sessions.ActiveSessions.Concat(recent);
        var calls = serverId is not null
            ? allCalls.Where(s => s.ServerId == serverId).ToList()
            : allCalls.ToList();

        _callsTracked = calls.Count;

        var queueCalls = calls.Where(s => s.QueueName is not null).ToList();
        if (queueCalls.Count > 0)
        {
            var avgWait = queueCalls
                .Where(s => s.WaitTime.HasValue)
                .Select(s => s.WaitTime!.Value.TotalSeconds)
                .DefaultIfEmpty(0).Average();
            _avgWaitTime = FormatSeconds((int)avgWait);

            var avgTalk = queueCalls
                .Where(s => s.ConnectedAt is not null && s.TalkTime.HasValue)
                .Select(s => s.TalkTime!.Value.TotalSeconds)
                .DefaultIfEmpty(0).Average();
            _avgTalkTime = FormatSeconds((int)avgTalk);

            var totalQueue = queueCalls.Count;
            var abandoned = queueCalls.Count(s => s.AgentId is null
                && s.State is CallSessionState.Completed or CallSessionState.Failed);
            _abandonRate = $"{(double)abandoned / totalQueue * 100:F0}%";
        }
        else
        {
            _avgWaitTime = "—";
            _avgTalkTime = "—";
            _abandonRate = "—";
        }
    }

    private static string FormatSeconds(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 ? $"{(int)ts.TotalMinutes}m{ts.Seconds:D2}s" : $"{ts.Seconds}s";
    }

    public void Dispose() => _timer?.Dispose();
}
