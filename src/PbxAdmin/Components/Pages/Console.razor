@page "/console"
@using Asterisk.Sdk
@using Asterisk.Sdk.Ami.Actions
@using Asterisk.Sdk.Ami.Responses
@using PbxAdmin.Services
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["Con_Title"]</PageTitle>

<h2>@L["Con_Heading"]</h2>
<HelpPanel SectionKey="Console_Overview">@L["Con_Heading"]</HelpPanel>

<div class="chip-bar">
    @foreach (var cmd in _quickCommands)
    {
        var captured = cmd;
        <button class="chip" @onclick="() => RunQuickCommand(captured)">@captured</button>
    }
</div>

<div class="inline-form">
    <input @bind="_command"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           placeholder="@L["Con_Placeholder"]"
           class="input"
           style="flex: 1;" />
    <button class="btn btn-blue" @onclick="RunCommand" disabled="@_running">
        @(_running ? L["Con_Running"] : L["Con_Run"])
    </button>
</div>

@if (_currentOutput is not null)
{
    <div style="margin-top: 1rem; background: #0a0d12; padding: 1rem; border-radius: 0.5rem; font-family: 'JetBrains Mono', monospace; white-space: pre-wrap; color: #22d3ee; max-height: 400px; overflow-y: auto; font-size: 0.85rem; line-height: 1.5;">@_currentOutput</div>
}

@if (_history.Count > 0)
{
    <h3 style="margin-top: 2rem;">@L["Con_History"]</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 160px;">@L["Col_Time"]</th>
                <th style="width: 300px;">@L["Col_Command"]</th>
                <th>@L["Col_Result"]</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in _history)
            {
                <tr>
                    <td class="mono">@entry.Timestamp.ToString("HH:mm:ss.fff")</td>
                    <td class="mono">@entry.Command</td>
                    <td>
                        @if (entry.Error is not null)
                        {
                            <span style="color: #f87171;">@entry.Error</span>
                        }
                        else
                        {
                            <span style="color: #4ade80;">OK</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm" @onclick="() => ShowOutput(entry)">@L["Con_View"]</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private static readonly string[] _quickCommands =
    [
        "core show channels",
        "sip show peers",
        "pjsip show endpoints",
        "queue show",
        "confbridge list"
    ];

    private string _command = "";
    private string? _currentOutput;
    private bool _running;
    private readonly List<HistoryEntry> _history = new();

    private const int MaxHistory = 20;

    private Task RunQuickCommand(string command)
    {
        _command = command;
        return RunCommand();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_running)
        {
            await RunCommand();
        }
    }

    private async Task RunCommand()
    {
        if (string.IsNullOrWhiteSpace(_command))
            return;

        var entry = ServerSvc.GetSelectedServer();
        if (entry is null)
        {
            _currentOutput = "No server selected. Please select a server first.";
            return;
        }

        _running = true;
        _currentOutput = null;

        var commandText = _command.Trim();
        var historyEntry = new HistoryEntry { Command = commandText, Timestamp = DateTime.Now };

        try
        {
            var serverId = ServerSvc.SelectedServerId ?? "unknown";
            using var _ = ConfigOp.Begin("Running Command", serverId, commandText);
            var action = new CommandAction { Command = commandText };
            var response = await entry.ConfigConnection.SendActionAsync<CommandResponse>(action);

            if (response.Output is not null)
            {
                historyEntry.Output = response.Output;
                _currentOutput = response.Output;
            }
            else
            {
                historyEntry.Output = response.Message ?? "(no output)";
                _currentOutput = historyEntry.Output;
            }

            if (string.Equals(response.Response, "Error", StringComparison.OrdinalIgnoreCase))
            {
                historyEntry.Error = response.Message ?? "Command failed";
            }
        }
        catch (Exception ex)
        {
            historyEntry.Error = ex.Message;
            historyEntry.Output = ex.Message;
            _currentOutput = $"Error: {ex.Message}";
        }
        finally
        {
            _running = false;
        }

        _history.Insert(0, historyEntry);
        if (_history.Count > MaxHistory)
        {
            _history.RemoveAt(_history.Count - 1);
        }
    }

    private void ShowOutput(HistoryEntry entry)
    {
        _currentOutput = entry.Output;
        _command = entry.Command;
    }

    private sealed class HistoryEntry
    {
        public required string Command { get; init; }
        public required DateTime Timestamp { get; init; }
        public string? Output { get; set; }
        public string? Error { get; set; }
    }
}
