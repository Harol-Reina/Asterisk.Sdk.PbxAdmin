@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims
@inject IConfiguration Configuration
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject IStringLocalizer<SharedStrings> L

<div class="access-popup">
    <div class="access-popup-bar">
        <span class="access-popup-dot"></span>
        <span class="access-popup-title">@L["Login_Title"]</span>
        <span class="access-popup-id">SEC-01</span>
    </div>

    <div class="access-popup-body">
        <div class="access-popup-prompt">
            <span class="access-prompt-caret">&gt;</span>
            @L["Login_Prompt"]
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="login-error">
                <span class="login-error-icon">!</span>
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
            <div class="access-field">
                <label class="access-label">@L["Login_Operator"]</label>
                <div class="access-input-wrap">
                    <span class="access-input-prefix">usr://</span>
                    <InputText @bind-Value="_model.Username" class="access-input" placeholder="admin" />
                </div>
            </div>
            <div class="access-field">
                <label class="access-label">@L["Login_Passphrase"]</label>
                <div class="access-input-wrap">
                    <span class="access-input-prefix">key://</span>
                    <InputText @bind-Value="_model.Password" type="password" class="access-input" placeholder="••••••••" />
                </div>
            </div>
            <button type="submit" class="access-submit">
                <span class="access-submit-text">@L["Login_Authorize"]</span>
                <span class="access-submit-arrow">&rarr;</span>
            </button>
        </EditForm>
    </div>

    <div class="access-popup-footer">
        <span>TLS 1.3</span>
        <span>Session: ephemeral</span>
        <span>v0.1.0-beta</span>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private LoginModel _model { get; set; } = null!;

    protected override void OnInitialized()
    {
        _model ??= new();
    }

    private string? _error;

    private async Task HandleLogin()
    {
        var expectedUsername = Configuration["Auth:Username"] ?? "admin";
        var expectedPassword = Configuration["Auth:Password"] ?? "admin";

        if (_model.Username != expectedUsername || _model.Password != expectedPassword)
        {
            _error = "Invalid credentials. Access denied.";
            return;
        }

        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, _model.Username!)
        };
        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        var httpContext = HttpContextAccessor.HttpContext!;
        await httpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties { IsPersistent = true });

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private sealed class LoginModel
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
    }
}
