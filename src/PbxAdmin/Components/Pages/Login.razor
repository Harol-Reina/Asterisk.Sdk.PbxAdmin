@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedStrings> L

<div class="access-popup">
    <div class="access-popup-bar">
        <span class="access-popup-dot"></span>
        <span class="access-popup-title">@L["Login_Title"]</span>
        <span class="access-popup-id">SEC-01</span>
    </div>

    <div class="access-popup-body">
        <div class="access-popup-prompt">
            <span class="access-prompt-caret">&gt;</span>
            @L["Login_Prompt"]
        </div>

        @if (_hasError)
        {
            <div class="login-error">
                <span class="login-error-icon">!</span>
                @L["Login_InvalidCreds"]
            </div>
        }

        <form method="post" action="/account/login" data-enhance="false">
            <input type="hidden" name="ReturnUrl" value="@_returnUrl" />
            <div class="access-field">
                <label class="access-label">@L["Login_Operator"]</label>
                <div class="access-input-wrap">
                    <span class="access-input-prefix">usr://</span>
                    <input type="text" name="Username" class="access-input" placeholder="admin" />
                </div>
            </div>
            <div class="access-field">
                <label class="access-label">@L["Login_Passphrase"]</label>
                <div class="access-input-wrap">
                    <span class="access-input-prefix">key://</span>
                    <input type="password" name="Password" class="access-input" placeholder="••••••••" />
                </div>
            </div>
            <button type="submit" class="access-submit">
                <span class="access-submit-text">@L["Login_Authorize"]</span>
                <span class="access-submit-arrow">&rarr;</span>
            </button>
        </form>
    </div>

    <div class="access-popup-footer">
        <span>TLS 1.3</span>
        <span>Session: ephemeral</span>
        <span>v0.1.0-beta</span>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? ErrorParam { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrlParam { get; set; }

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    private string? ReturnUrlParam2 { get; set; }

    private bool _hasError;
    private string _returnUrl = "/";

    protected override void OnInitialized()
    {
        _hasError = ErrorParam == "1";
        _returnUrl = ReturnUrlParam ?? ReturnUrlParam2 ?? "/";
    }
}
