@page "/recordings/edit/new"
@page "/recordings/edit/{Id:int}"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject RecordingService RecSvc
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@(_isNew ? L["RecEdit_NewTitle"] : $"{L["RecEdit_EditTitle"]} {_policy.Name}")</PageTitle>

<div class="page-header-row">
    <button class="btn btn-sm btn-muted" @onclick="GoBack">&#8592; @L["Btn_Back"]</button>
    <h2>@(_isNew ? L["RecEdit_New"] : $"{L["RecEdit_Edit"]}: {_policy.Name}")</h2>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="form-section">
    <HelpPanel SectionKey="RecEdit_PolicySettings">@L["RecEdit_PolicySettings"]</HelpPanel>

    <div class="form-group">
        <label>@L["Lbl_Name"] <HelpIcon HelpKey="RecName" /></label>
        <input type="text" @bind="_policy.Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>@L["Col_Mode"] <HelpIcon HelpKey="RecMode" /></label>
        <div class="radio-group">
            @foreach (var mode in Enum.GetValues<RecordingMode>())
            {
                var capturedMode = mode;
                <label>
                    <input type="radio" name="mode" value="@capturedMode"
                           checked="@(_policy.Mode == capturedMode)"
                           @onchange="() => _policy.Mode = capturedMode" /> @capturedMode
                </label>
            }
        </div>
    </div>

    <div class="form-group">
        <label>@L["Col_Format"] <HelpIcon HelpKey="RecFormat" /></label>
        <select @bind="_policy.Format" class="form-control">
            <option value="wav">wav</option>
            <option value="wav49">wav49</option>
            <option value="gsm">gsm</option>
        </select>
    </div>

    <div class="form-group">
        <label>@L["RecEdit_StoragePath"] <HelpIcon HelpKey="RecStoragePath" /></label>
        <input type="text" @bind="_policy.StoragePath" class="form-control" />
    </div>

    <div class="form-group">
        <label>@L["RecEdit_RetentionDays"] <HelpIcon HelpKey="RecRetentionDays" /></label>
        <input type="number" @bind="_policy.RetentionDays" min="0" class="form-control" />
    </div>

    <div class="form-group">
        <label>@L["RecEdit_MixMonitorOpts"] <HelpIcon HelpKey="RecMixMonitorOpts" /></label>
        <input type="text" @bind="_policy.MixMonitorOptions" class="form-control"
               placeholder="e.g. r for read, t for write" />
    </div>
</div>

<div class="form-section">
    <HelpPanel SectionKey="RecEdit_Targets">@L["RecEdit_Targets"]</HelpPanel>
    <button class="btn btn-sm btn-primary" @onclick="AddTarget">@L["RecEdit_AddTarget"]</button>

    @if (_policy.Targets.Count > 0)
    {
        <table class="table mt-2">
            <thead>
                <tr><th>@L["Lbl_Type"]</th><th>@L["Col_Value"]</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var target in _policy.Targets)
                {
                    <tr>
                        <td>
                            <select @bind="target.TargetType" class="form-control">
                                <option value="extension">@L["Lbl_Extension"]</option>
                                <option value="queue">@L["Lbl_Queue"]</option>
                                <option value="trunk">@L["Lbl_Trunk"]</option>
                            </select>
                        </td>
                        <td>
                            <input type="text" @bind="target.TargetValue" class="form-control" />
                        </td>
                        <td>
                            <button class="btn btn-sm btn-danger" @onclick="() => _policy.Targets.Remove(target)" title="@L["Btn_Remove"]">&#x2715;</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="form-actions">
    <button class="btn btn-muted" @onclick="GoBack">@L["Btn_Cancel"]</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
        @(_saving ? L["Btn_Saving"] : L["Btn_Save"])
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private RecordingPolicy _policy = new()
    {
        StoragePath = "/var/spool/asterisk/monitor/",
        Targets = [new PolicyTarget { TargetType = "extension" }]
    };
    private bool _isNew => Id == 0;
    private bool _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!_isNew)
        {
            var existing = await RecSvc.GetPolicyAsync(Id);
            if (existing is not null) _policy = existing;
        }
        else
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is not null)
            {
                _policy.StoragePath = Config[$"Asterisk:Servers:{serverId}:RecordingsPath"]
                    ?? "/var/spool/asterisk/monitor/";
            }
        }
    }

    private void AddTarget() =>
        _policy.Targets.Add(new PolicyTarget { TargetType = "extension" });

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var serverId = ServerSvc.SelectedServerId;
            if (serverId is null) { _error = "No server selected"; return; }

            var (success, error) = _isNew
                ? await RecSvc.CreatePolicyAsync(serverId, _policy)
                : await RecSvc.UpdatePolicyAsync(serverId, _policy);

            if (success)
                Nav.NavigateTo("/recordings");
            else
                _error = error;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/recordings");
}
