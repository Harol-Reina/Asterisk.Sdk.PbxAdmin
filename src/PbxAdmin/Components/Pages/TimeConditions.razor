@page "/time-conditions"
@using PbxAdmin.Services
@using PbxAdmin.Services.CallFlow
@using PbxAdmin.Models
@inject TimeConditionService TcSvc
@inject CallFlowService FlowSvc
@inject ISelectedServerService ServerSvc
@inject IConfigOperationState ConfigOp
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L
@inject IToastService Toast

<PageTitle>@L["TC_Title"]</PageTitle>

<h2>@L["TC_Heading"]</h2>

<HelpPanel SectionKey="TimeConditions_Overview">@L["TC_Heading"]</HelpPanel>

<div style="margin-bottom: 1rem;">
    <button class="btn btn-blue" @onclick="NavigateNew">@L["TC_NewTC"]</button>
</div>

<div class="tc-grid">
    @foreach (var tc in _conditions)
    {
        <div class="tc-card" @onclick="() => NavigateEdit(tc.Id)" style="cursor: pointer;">
            <div class="tc-card-header">
                <strong>@tc.Name</strong>
                <span class="badge @GetStateBadge(tc.CurrentState)">@GetStateLabel(tc.CurrentState)</span>
            </div>
            <div class="tc-card-body">
                <div class="text-muted" style="font-size: 0.85rem;">
                    @tc.RangeCount @L["TC_DayRanges"]
                    @if (tc.HolidayCount > 0)
                    {
                        <span> · @tc.HolidayCount @L["TC_Holidays"]</span>
                    }
                </div>
                <div style="margin-top: 0.5rem; font-size: 0.9rem;">
                    <div>Match: <span class="badge badge-green" style="font-size: 0.8rem;">@(tc.MatchDestLabel ?? tc.MatchDest)</span></div>
                    <div>No match: <span class="badge badge-muted" style="font-size: 0.8rem;">@(tc.NoMatchDestLabel ?? tc.NoMatchDest)</span></div>
                </div>
            </div>
            <div class="xref-line">
                @{ var refs = GetRefsForTc(tc.Name); }
                @if (refs.Count > 0)
                {
                    <span class="text-muted">@L["XRef_UsedBy"] @string.Join(", ", refs.Select(r => r.SourceLabel))</span>
                }
                else
                {
                    <span class="xref-warning">@L["XRef_NotReferenced"]</span>
                }
            </div>
            <div class="tc-card-actions" @onclick:stopPropagation="true">
                <button class="btn btn-sm btn-green" @onclick="() => SetOverride(tc, true)">@L["TC_ForceOpen"]</button>
                <button class="btn btn-sm btn-red" @onclick="() => SetOverride(tc, false)">@L["TC_ForceClosed"]</button>
                <button class="btn btn-sm" @onclick="() => SetOverride(tc, null)">@L["TC_ResetAuto"]</button>
                <button class="btn btn-sm btn-red" style="margin-left: auto;" @onclick="() => ConfirmDelete(tc)">@L["Btn_Delete"]</button>
            </div>
        </div>
    }
</div>

@if (_conditions.Count == 0)
{
    <p class="text-muted">@L["TC_NoConditions"]</p>
}

<ConfirmDialog @ref="_deleteDialog"
    Title="@L["TC_DeleteTitle"]"
    Message="@L["TC_DeleteConfirm", _deletingTc?.Name ?? ""]"
    ConfirmText="@L["Btn_Delete"]"
    CancelText="@L["Btn_Cancel"]"
    ConfirmStyle="danger"
    OnConfirm="ExecuteDelete" />

<style>
    .tc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 1rem;
    }
    .tc-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }
    .tc-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border);
    }
    .tc-card-body {
        padding: 0.75rem 1rem;
    }
    .tc-card-actions {
        display: flex;
        gap: 0.35rem;
        padding: 0.5rem 1rem 0.75rem;
        flex-wrap: wrap;
    }
    .badge-green { background: #22c55e22; color: #4ade80; }
    .badge-orange { background: #f9731622; color: #fb923c; }
    .badge-red-state { background: #ef444422; color: #f87171; }
    .xref-line { padding: 0.25rem 1rem 0.5rem; font-size: 0.8rem; }
    .xref-warning { color: #fbbf24; font-size: 0.8rem; font-style: italic; }
</style>

@code {
    private List<TimeConditionViewModel> _conditions = [];
    private CallFlowGraph? _graph;
    private TimeConditionViewModel? _deletingTc;
    private ConfirmDialog? _deleteDialog;

    private void NavigateNew() => Nav.NavigateTo("/time-conditions/new");
    private void NavigateEdit(int id) => Nav.NavigateTo($"/time-conditions/edit/{id}");

    protected override async Task OnInitializedAsync()
    {
        await LoadConditions();
    }

    private async Task LoadConditions()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        _conditions = await TcSvc.GetTimeConditionsAsync(serverId);
        _graph = await FlowSvc.BuildFlowAsync(serverId);

        // Enrich with override state
        var overrides = await TcSvc.GetOverridesBatchAsync(serverId);
        foreach (var tc in _conditions)
        {
            if (overrides.TryGetValue(tc.Name, out var value))
            {
                tc.CurrentState = string.Equals(value, "OPEN", StringComparison.OrdinalIgnoreCase)
                    ? TimeConditionState.OverrideOpen
                    : TimeConditionState.OverrideClosed;
            }
        }
    }

    private async Task SetOverride(TimeConditionViewModel tc, bool? forceOpen)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        await TcSvc.SetOverrideAsync(serverId, tc.Name, forceOpen);
        await LoadConditions();
    }

    private void ConfirmDelete(TimeConditionViewModel tc)
    {
        _deletingTc = tc;
        _deleteDialog?.Show();
    }

    private async Task ExecuteDelete()
    {
        if (_deletingTc is null) return;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var tcName = _deletingTc.Name;
        try
        {
            using var _ = ConfigOp.Begin("Deleting Time Condition", serverId, tcName);
            var (success, error) = await TcSvc.DeleteTimeConditionAsync(_deletingTc.Id, serverId);
            _deletingTc = null;

            if (success)
            {
                Toast.Show(L["Toast_Deleted"], ToastLevel.Success, tcName);
                await LoadConditions();
            }
            else
            {
                Toast.Show(L["Toast_Error"], ToastLevel.Error, error);
            }
        }
        catch (Exception ex)
        {
            _deletingTc = null;
            Toast.Show(L["Toast_Error"], ToastLevel.Error, ex.Message);
        }
    }

    private static string GetStateBadge(TimeConditionState state) => state switch
    {
        TimeConditionState.Open => "badge-green",
        TimeConditionState.Closed => "badge-red-state",
        TimeConditionState.OverrideOpen => "badge-orange",
        TimeConditionState.OverrideClosed => "badge-orange",
        _ => "badge-muted"
    };

    private static string GetStateLabel(TimeConditionState state) => state switch
    {
        TimeConditionState.Open => "Open",
        TimeConditionState.Closed => "Closed",
        TimeConditionState.OverrideOpen => "OVERRIDE: OPEN",
        TimeConditionState.OverrideClosed => "OVERRIDE: CLOSED",
        _ => "Unknown"
    };

    private List<CrossReference> GetRefsForTc(string name)
    {
        if (_graph is null) return [];
        return CallFlowService.GetReferencesFor(_graph, "time_condition", name);
    }
}
