@page "/queues"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject IStringLocalizer<SharedStrings> L
@inject ISelectedServerService ServerSvc
@inject IQueueConfigService QueueCfgSvc
@inject IConfigProviderResolver ProviderResolver
@inject IToastService Toast
@implements IDisposable

<PageTitle>@L["Queues_Title"]</PageTitle>

<div class="page-header-row">
    <h2>@L["Queues_Heading"]</h2>
    <div>
        <button class="btn btn-sm btn-muted" @onclick="RefreshStateAsync" disabled="@_refreshing">@L["DP_Refresh"]</button>
        @foreach (var (serverId, _) in ServerSvc.GetServers())
        {
            <a href="/queue-config/@serverId/new" class="btn btn-blue btn-sm">@L["Queues_NewQueue"]</a>
        }
    </div>
</div>

<HelpPanel SectionKey="Queues_Overview">@L["Queues_Heading"]</HelpPanel>

<div class="kpi-row">
    <div class="kpi-card">
        <span class="kpi-value">@_configuredQueues.Count</span>
        <span class="kpi-label">@L["Queues_Configured"]</span>
    </div>
</div>

<div class="card-grid">
    @foreach (var (serverId, entry) in ServerSvc.GetServers())
    {
        foreach (var queue in entry.Server.Queues.Queues)
        {
            var healthClass = queue.EntryCount switch
            {
                0 when queue.MemberCount == 0 => "health-gray",
                0 => "health-green",
                <= 3 => "health-yellow",
                _ => "health-red"
            };

            <div class="queue-card @healthClass">
                <div class="queue-card-header">
                    <a href="/queue/@serverId/@queue.Name"><strong>@queue.Name</strong></a>
                    @{
                        var configKey = $"{serverId}:{queue.Name}";
                        var hasConfig = _configuredQueues.TryGetValue(configKey, out var configId);
                    }
                    <a href="@(hasConfig ? $"/queue-config/{serverId}/{configId}" : $"/queue-config/{serverId}/new?name={queue.Name}")"
                       class="btn btn-sm btn-muted" title="Configure">&#9881;</a>
                </div>
                <div class="queue-card-meta">
                    @if (queue.Strategy is not null)
                    {
                        <span>@queue.Strategy</span>
                    }
                </div>
                <div class="queue-card-stats">
                    <div class="stat">
                        <span class="stat-value">@queue.MemberCount</span>
                        <span class="stat-label">@L["Col_Members"]</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value @(queue.EntryCount > 0 ? "text-red badge-pulse" : "")">@queue.EntryCount</span>
                        <span class="stat-label">@L["Col_Waiting"]</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value">@queue.Completed</span>
                        <span class="stat-label">@L["Queues_Done"]</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value">@queue.Abandoned</span>
                        <span class="stat-label">@L["Queues_Dropped"]</span>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private const int AutoRefreshEveryNTicks = 5; // 5 × 2s = 10s
    private Timer? _timer;
    private int _tickCount;
    private bool _refreshing;
    private Dictionary<string, int> _configuredQueues = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguredQueuesAsync();
        _timer = new Timer(async _ =>
        {
            _tickCount++;
            if (_tickCount >= AutoRefreshEveryNTicks)
            {
                _tickCount = 0;
                await RefreshStateInternalAsync();
            }
            await LoadConfiguredQueuesAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task RefreshStateAsync()
    {
        _refreshing = true;
        try
        {
            // Manual refresh: reload module (clears stale members) + clear SDK state + re-query
            foreach (var (serverId, entry) in ServerSvc.GetServers())
            {
                var provider = ProviderResolver.GetProvider(serverId);
                await provider.ReloadModuleAsync(serverId, "app_queue.so");
                ClearQueueState(entry.Server);
                await entry.Server.RequestInitialStateAsync();
            }
            Toast.Show("Queue state refreshed", ToastLevel.Success);
        }
        finally
        {
            _refreshing = false;
        }
    }

    private async Task RefreshStateInternalAsync()
    {
        // Auto-poll: clear stale state then re-query (no module reload — safe during active calls)
        foreach (var (serverId, entry) in ServerSvc.GetServers())
        {
            ClearQueueState(entry.Server);
            await entry.Server.RequestInitialStateAsync();
        }
    }

    private static void ClearQueueState(Asterisk.Sdk.Live.Server.AsteriskServer server)
    {
        foreach (var queue in server.Queues.Queues)
        {
            queue.Members.Clear();
            queue.Entries.Clear();
        }
    }

    private async Task LoadConfiguredQueuesAsync()
    {
        _configuredQueues.Clear();
        foreach (var (serverId, _) in ServerSvc.GetServers())
        {
            var queues = await QueueCfgSvc.GetQueuesAsync(serverId);
            foreach (var q in queues)
                _configuredQueues[$"{serverId}:{q.Name}"] = q.Id;
        }
    }

    public void Dispose() => _timer?.Dispose();
}
