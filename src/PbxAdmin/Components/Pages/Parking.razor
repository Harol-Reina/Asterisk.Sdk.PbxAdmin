@page "/parking"
@using PbxAdmin.Models
@using PbxAdmin.Services
@using Asterisk.Sdk.Ami.Actions
@using Asterisk.Sdk.Ami.Events
@inject ISelectedServerService ServerSvc
@inject FeatureCodeService FeatureSvc
@inject IStringLocalizer<SharedStrings> L
@implements IDisposable

<PageTitle>@L["Parking_Title"]</PageTitle>

<h2>@L["Parking_Heading"]</h2>

<div class="chip-bar">
    <button class="chip @(_activeTab == "live" ? "chip-active" : "")" @onclick='() => _activeTab = "live"'>@L["Parking_ParkedCalls"]</button>
    <button class="chip @(_activeTab == "config" ? "chip-active" : "")" @onclick="SwitchToConfig">@L["Parking_LotConfig"]</button>
</div>

@if (_activeTab == "live")
{
    <HelpPanel SectionKey="Parking_Live">@L["Parking_ParkedCalls"]</HelpPanel>
    <div class="kpi-grid">
        <div class="kpi-card kpi-blue">
            <span class="kpi-value">@_parkedCalls.Count</span>
            <span class="kpi-label">@L["Parking_TotalParked"]</span>
        </div>
    </div>

    @if (_error is not null)
    {
        <p class="text-muted">@_error</p>
    }
    else if (_parkedCalls.Count == 0)
    {
        <p class="text-muted">@L["Parking_NoParked"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Col_Space"]</th>
                    <th>@L["Col_Channel"]</th>
                    <th>@L["Col_CallerID"]</th>
                    <th>@L["Col_Context"]</th>
                    <th>@L["Col_Timeout"]</th>
                    <th>@L["Col_Duration"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var call in _parkedCalls)
                {
                    <tr>
                        <td><span class="badge badge-blue">@call.Exten</span></td>
                        <td class="mono">@call.Channel</td>
                        <td>
                            @if (!string.IsNullOrEmpty(call.CallerIdName))
                            {
                                <span>@call.CallerIdName</span>
                                <span class="text-muted"> &lt;@call.CallerIdNum&gt;</span>
                            }
                            else
                            {
                                <span>@call.CallerIdNum</span>
                            }
                        </td>
                        <td>@call.Context</td>
                        <td class="mono">@call.Timeout</td>
                        <td class="caller-timer">@FormatDuration(call.ParkedSince)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{
    @* ---------- Parking Lot Configuration ---------- *@
    <HelpPanel SectionKey="Parking_LotConfig">@L["Parking_LotConfig"]</HelpPanel>

    @if (_configError is not null)
    {
        <div class="alert alert-danger">@_configError</div>
    }

    <div class="page-header-row">
        <h3>@L["Parking_ParkingLots"]</h3>
        <button class="btn btn-primary" @onclick="ShowNewLot">@L["Parking_NewLot"]</button>
    </div>

    @if (_lots.Count == 0)
    {
        <p class="text-muted">@L["Parking_NoLots"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Lbl_Name"]</th>
                    <th>@L["Col_Slots"]</th>
                    <th>@L["Col_Timeout"]</th>
                    <th>@L["Col_Context"]</th>
                    <th>@L["Col_MOH"]</th>
                    <th>@L["Lbl_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lot in _lots)
                {
                    <tr>
                        <td><strong>@lot.Name</strong></td>
                        <td class="mono">@lot.ParkingStartSlot-@lot.ParkingEndSlot</td>
                        <td>@lot.ParkingTimeout s</td>
                        <td>@lot.Context</td>
                        <td>@lot.MusicOnHold</td>
                        <td>
                            <button class="btn btn-sm btn-blue" @onclick="() => EditLot(lot)">@L["Btn_Edit"]</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteLot(lot.Id)">@L["Btn_Delete"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_editingLot is not null)
    {
        <div class="form-section mt-2">
            <h4>@(_editingLot.Id == 0 ? "New Parking Lot" : $"Edit: {_editingLot.Name}")</h4>

            <div class="form-group">
                <label>@L["Lbl_Name"] <HelpIcon HelpKey="ParkLotName" /></label>
                <input type="text" @bind="_editingLot.Name" class="form-control" placeholder="default" />
            </div>

            <div class="form-group">
                <label>@L["Lbl_StartSlot"] <HelpIcon HelpKey="ParkStartSlot" /></label>
                <input type="number" @bind="_editingLot.ParkingStartSlot" class="form-control" min="1" />
            </div>

            <div class="form-group">
                <label>@L["Lbl_EndSlot"] <HelpIcon HelpKey="ParkEndSlot" /></label>
                <input type="number" @bind="_editingLot.ParkingEndSlot" class="form-control" min="1" />
            </div>

            <div class="form-group">
                <label>@L["Lbl_Timeout"] <HelpIcon HelpKey="ParkTimeout" /></label>
                <input type="number" @bind="_editingLot.ParkingTimeout" class="form-control" min="0" />
            </div>

            <div class="form-group">
                <label>@L["Lbl_Context"] <HelpIcon HelpKey="ParkContext" /></label>
                <input type="text" @bind="_editingLot.Context" class="form-control" placeholder="parkedcalls" />
            </div>

            <div class="form-group">
                <label>@L["Lbl_MusicOnHold"] <HelpIcon HelpKey="ParkMoh" /></label>
                <input type="text" @bind="_editingLot.MusicOnHold" class="form-control" placeholder="default" />
            </div>

            <div class="form-actions">
                <button class="btn btn-muted" @onclick="CancelLotEdit">@L["Btn_Cancel"]</button>
                <button class="btn btn-primary" @onclick="SaveLot" disabled="@_lotSaving">
                    @(_lotSaving ? L["Btn_Saving"] : L["Btn_Save"])
                </button>
            </div>
        </div>
    }
}

@code {
    private Timer? _timer;
    private string _activeTab = "live";

    // Live tab
    private List<ParkedCallViewModel> _parkedCalls = [];
    private string? _error;

    // Config tab
    private List<ParkingLotConfig> _lots = [];
    private ParkingLotConfig? _editingLot;
    private bool _lotSaving;
    private string? _configError;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => InvokeAsync(RefreshAsync),
            null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private async Task SwitchToConfig()
    {
        _activeTab = "config";
        await LoadLotsAsync();
    }

    private async Task LoadLotsAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        try
        {
            _lots = await FeatureSvc.GetParkingLotsAsync(serverId);
            _configError = null;
        }
        catch (Exception ex)
        {
            _configError = $"Failed to load parking lots: {ex.Message}";
        }
    }

    private void ShowNewLot()
    {
        _editingLot = new ParkingLotConfig();
    }

    private void EditLot(ParkingLotConfig lot)
    {
        _editingLot = lot with { };
    }

    private void CancelLotEdit() => _editingLot = null;

    private async Task SaveLot()
    {
        if (_editingLot is null) return;

        if (string.IsNullOrWhiteSpace(_editingLot.Name))
        {
            _configError = "Name is required";
            return;
        }
        if (_editingLot.ParkingStartSlot >= _editingLot.ParkingEndSlot)
        {
            _configError = "Start slot must be less than end slot";
            return;
        }

        _lotSaving = true;
        _configError = null;

        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) { _configError = "No server selected"; _lotSaving = false; return; }

        var (success, error) = _editingLot.Id == 0
            ? await FeatureSvc.CreateParkingLotAsync(serverId, _editingLot)
            : await FeatureSvc.UpdateParkingLotAsync(serverId, _editingLot);

        _lotSaving = false;

        if (success)
        {
            _editingLot = null;
            await LoadLotsAsync();
        }
        else
        {
            _configError = error;
        }
    }

    private async Task DeleteLot(int id)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;

        var (success, error) = await FeatureSvc.DeleteParkingLotAsync(serverId, id);
        if (success)
            await LoadLotsAsync();
        else
            _configError = error;
    }

    private async Task RefreshAsync()
    {
        if (_activeTab != "live") return;

        try
        {
            var entry = ServerSvc.GetSelectedServer();
            if (entry is null)
            {
                _parkedCalls = [];
                _error = null;
                StateHasChanged();
                return;
            }

            var connection = entry.Connection;
            var action = new ParkedCallsAction();
            var calls = new List<ParkedCallViewModel>();
            var now = DateTimeOffset.UtcNow;

            await foreach (var evt in connection.SendEventGeneratingActionAsync(action))
            {
                if (evt is ParkedCallEvent parked)
                {
                    calls.Add(new ParkedCallViewModel
                    {
                        Exten = parked.Exten ?? "?",
                        Channel = parked.Channel ?? "",
                        CallerIdNum = parked.CallerIdNum ?? "",
                        CallerIdName = parked.CallerIdName,
                        Context = parked.Context ?? "",
                        Timeout = parked.Timeout,
                        ParkedSince = parked.Timestamp.HasValue
                            ? now - DateTimeOffset.FromUnixTimeSeconds((long)parked.Timestamp.Value)
                            : TimeSpan.Zero,
                    });
                }
            }

            _parkedCalls = calls;
            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Failed to retrieve parked calls: {ex.Message}";
            _parkedCalls = [];
        }

        StateHasChanged();
    }

    private static string FormatDuration(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours}:{ts.Minutes:D2}:{ts.Seconds:D2}"
            : $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";

    private sealed class ParkedCallViewModel
    {
        public string Exten { get; init; } = "";
        public string Channel { get; init; } = "";
        public string CallerIdNum { get; init; } = "";
        public string? CallerIdName { get; init; }
        public string Context { get; init; } = "";
        public int? Timeout { get; init; }
        public TimeSpan ParkedSince { get; init; }
    }

    public void Dispose() => _timer?.Dispose();
}
