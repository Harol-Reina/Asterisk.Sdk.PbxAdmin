@page "/recordings"
@using PbxAdmin.Models
@using PbxAdmin.Services
@inject RecordingService RecSvc
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["Rec_Title"]</PageTitle>

<div class="page-header-row">
    <h2>@L["Rec_Heading"]</h2>
    <button class="btn btn-primary" @onclick="NewPolicy">@L["Rec_NewPolicy"]</button>
</div>

<div class="chip-bar">
    <button class="chip @(_activeTab == "policies" ? "chip-active" : "")" @onclick='() => _activeTab = "policies"'>@L["Rec_Policies"]</button>
    <button class="chip @(_activeTab == "files" ? "chip-active" : "")" @onclick='() => _activeTab = "files"'>@L["Rec_Files"]</button>
    <button class="chip @(_activeTab == "active" ? "chip-active" : "")" @onclick='() => _activeTab = "active"'>@L["Rec_Active"]</button>
</div>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_activeTab == "policies")
{
    <HelpPanel SectionKey="Recordings_Policies">@L["Rec_Policies"]</HelpPanel>
    if (_policies.Count == 0)
    {
        <p class="text-muted">@L["Rec_NoPolicies"]</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>@L["Lbl_Name"]</th>
                    <th>@L["Col_Mode"]</th>
                    <th>@L["Col_Format"]</th>
                    <th>@L["Col_Retention"]</th>
                    <th>@L["Col_Targets"]</th>
                    <th>@L["Lbl_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _policies)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Mode</td>
                        <td>@p.Format</td>
                        <td>@(p.RetentionDays == 0 ? "∞" : $"{p.RetentionDays}d")</td>
                        <td><span class="badge">@p.Targets.Count</span></td>
                        <td>
                            <button class="btn btn-sm btn-muted" @onclick="() => EditPolicy(p.Id)">@L["Btn_Edit"]</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeletePolicy(p)">@L["Btn_Delete"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else if (_activeTab == "files")
{
    <HelpPanel SectionKey="Recordings_Files">@L["Rec_Files"]</HelpPanel>
    if (!_fileAccessAvailable)
    {
        <div class="alert alert-warning">@L["Rec_FileAccessUnavail"]</div>
    }
    else
    {
        if (_retentionWarnings.Count > 0)
        {
            <div class="alert alert-warning">&#9888; @_retentionWarnings.Count file(s) exceed retention policy</div>
        }

        <table class="table">
            <thead>
                <tr><th>@L["Col_Filename"]</th><th>@L["Col_Size"]</th><th>@L["Col_Date"]</th><th>@L["Col_Duration"]</th><th>@L["Lbl_Actions"]</th></tr>
            </thead>
            <tbody>
                @foreach (var f in _files)
                {
                    <tr>
                        <td>@f.Name</td>
                        <td>@FormatSize(f.Size)</td>
                        <td>@f.LastModified.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(f.Duration?.ToString(@"m\:ss") ?? "—")</td>
                        <td>
                            <button class="btn btn-sm btn-muted" @onclick="() => PlayFile(f.Name)">&#9654;</button>
                            <a href="/api/recordings/files/@f.Name?download=true" class="btn btn-sm btn-muted" download>&#11015;</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        if (_playingFile is not null)
        {
            <div class="audio-player">
                <strong>@_playingFile</strong>
                <audio controls autoplay src="/api/recordings/files/@_playingFile"></audio>
            </div>
        }
    }
}
else if (_activeTab == "active")
{
    <HelpPanel SectionKey="Recordings_Active">@L["Rec_Active"]</HelpPanel>
    var activeList = RecSvc.GetActiveRecordings();
    if (activeList.Count == 0)
    {
        <p class="text-muted">@L["Rec_NoActive"]</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr><th>@L["Col_Channel"]</th><th>@L["Col_File"]</th><th>@L["Col_Started"]</th><th>@L["Lbl_Actions"]</th></tr>
            </thead>
            <tbody>
                @foreach (var r in activeList)
                {
                    <tr>
                        <td>@r.Channel</td>
                        <td>@r.FileName</td>
                        <td>@r.StartedAt.ToString("HH:mm:ss")</td>
                        <td><button class="btn btn-sm btn-danger" @onclick="() => StopRecording(r.Channel)">@L["Rec_Stop"]</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private string _activeTab = "policies";
    private List<RecordingPolicy> _policies = [];
    private List<AudioFileInfo> _files = [];
    private List<RetentionWarning> _retentionWarnings = [];
    private bool _loading = true;
    private bool _fileAccessAvailable;
    private string? _playingFile;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is not null)
        {
            _policies = await RecSvc.GetPoliciesAsync(serverId);

            var storagePath = Config[$"Asterisk:Servers:{serverId}:RecordingsPath"]
                ?? "/var/spool/asterisk/monitor";
            _fileAccessAvailable = RecordingService.IsFileAccessAvailable(storagePath);

            if (_fileAccessAvailable)
            {
                _files = await RecSvc.GetRecordingFilesAsync(storagePath);
                _retentionWarnings = await RecSvc.GetRetentionWarningsAsync(serverId);
            }
        }
        _loading = false;
    }

    private void NewPolicy() => Nav.NavigateTo("/recordings/edit/new");
    private void EditPolicy(int id) => Nav.NavigateTo($"/recordings/edit/{id}");
    private void PlayFile(string name) => _playingFile = name;

    private async Task DeletePolicy(RecordingPolicy policy)
    {
        var (success, error) = await RecSvc.DeletePolicyAsync(policy.Id);
        if (success) _policies.Remove(policy);
        else _error = error;
    }

    private async Task StopRecording(string channel)
    {
        var serverId = ServerSvc.SelectedServerId;
        if (serverId is null) return;
        var (success, error) = await RecSvc.StopRecordingAsync(serverId, channel);
        if (!success) _error = error;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
