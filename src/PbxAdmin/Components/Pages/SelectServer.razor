@page "/select-server"
@attribute [Authorize]
@layout LoginLayout
@using PbxAdmin.Services
@using Asterisk.Sdk.Enums
@inject AsteriskMonitorService Monitor
@inject ISelectedServerService ServerSvc
@inject NavigationManager Nav
@inject IStringLocalizer<SharedStrings> L

<div class="server-select-page">
    <div class="server-select-header">
        <h2>@L["SS_Heading"]</h2>
        <p class="text-muted">@L["SS_Choose"]</p>
    </div>

    <div class="server-select-grid">
        @foreach (var (id, entry) in Monitor.Servers)
        {
            var state = entry.Connection.State;
            var dotClass = state switch
            {
                AmiConnectionState.Connected => "dot-green",
                AmiConnectionState.Reconnecting or AmiConnectionState.Connecting => "dot-yellow",
                _ => "dot-red"
            };
            var modeBadge = entry.ConfigMode == ConfigMode.Realtime ? "badge-realtime" : "badge-file";

            <div class="server-select-card" @onclick="() => PickServer(id)">
                <div class="server-select-card-header">
                    <span class="status-dot @dotClass"></span>
                    <strong>@id</strong>
                </div>
                <div class="server-select-card-body">
                    <div>
                        <span class="badge @modeBadge">@entry.ConfigMode</span>
                    </div>
                    <div class="text-muted" style="font-size: 0.8rem; margin-top: 0.5rem;">@state</div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        var servers = Monitor.Servers.ToList();

        if (servers.Count == 1)
        {
            ServerSvc.Select(servers[0].Key);
            Nav.NavigateTo("/", replace: true);
        }
    }

    private void PickServer(string serverId)
    {
        ServerSvc.Select(serverId);
        Nav.NavigateTo("/", replace: true);
    }
}
